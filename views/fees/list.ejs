<div class="w-full px-6 py-8 space-y-6">
  <!-- Flash messages -->
  <%- include('../flash.ejs') %>

  <!-- Simplified Page Header -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 pb-5 border-b border-slate-200 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-900 tracking-tight">💰 Fees Analytics Dashboard</h1>
    </div>
    <!-- Actions Panel -->
    <div class="flex flex-wrap gap-2.5">
      <a href="/fees/export/excel" class="inline-flex items-center gap-1.5 bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2.5 rounded-xl font-bold text-xs shadow-sm transition">
        <i class="fas fa-file-excel text-[11px]"></i> Download Excel
      </a>
      <a href="/fees/date-wise" class="inline-flex items-center gap-1.5 bg-white hover:bg-slate-50 text-slate-700 border border-slate-300 px-4 py-2.5 rounded-xl font-bold text-xs shadow-sm transition">
        <i class="fas fa-calendar-alt text-[11px]"></i> Date-wise Logs
      </a>
      <a href="/fees/new" class="inline-flex items-center gap-1.5 bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2.5 rounded-xl font-bold text-xs shadow-sm transition">
        <i class="fas fa-plus text-[11px]"></i> Add Fee Record
      </a>
    </div>
  </div>

  <!-- Metrics Cards Grid -->
  <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="bg-white border border-slate-100 rounded-3xl p-5 shadow-sm flex items-center justify-between">
      <div class="space-y-1">
        <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Total Enrolled Students</p>
        <p class="text-3xl font-extrabold text-slate-850" id="metricStudents">0</p>
        <p class="text-[10px] text-slate-400 font-semibold">With fee records</p>
      </div>
      <div class="p-3.5 rounded-2xl bg-indigo-50 text-indigo-500">
        <i class="fas fa-users text-xl"></i>
      </div>
    </div>

    <div class="bg-white border border-slate-100 rounded-3xl p-5 shadow-sm flex items-center justify-between">
      <div class="space-y-1">
        <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Total Fee Planned</p>
        <p class="text-2xl font-extrabold text-slate-850" id="metricTotal">Rs 0</p>
        <p class="text-[10px] text-slate-400 font-semibold">Sum of class schedules</p>
      </div>
      <div class="p-3.5 rounded-2xl bg-slate-50 text-slate-500">
        <i class="fas fa-money-bill-wave text-xl"></i>
      </div>
    </div>

    <div class="bg-white border border-slate-100 rounded-3xl p-5 shadow-sm flex items-center justify-between">
      <div class="space-y-1">
        <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Total Collected</p>
        <p class="text-2xl font-extrabold text-emerald-700" id="metricPaid">Rs 0</p>
        <p class="text-[10px] text-emerald-650 font-bold">Payments received (<span id="metricPaidPct">0%</span>)</p>
      </div>
      <div class="p-3.5 rounded-2xl bg-emerald-50 text-emerald-500">
        <i class="fas fa-check-double text-xl"></i>
      </div>
    </div>

    <div class="bg-white border border-slate-100 rounded-3xl p-5 shadow-sm flex items-center justify-between">
      <div class="space-y-1">
        <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Total Pending Dues</p>
        <p class="text-2xl font-extrabold text-rose-700" id="metricBalance">Rs 0</p>
        <p class="text-[10px] text-rose-650 font-bold">Outstanding balance (<span id="metricBalancePct">0%</span>)</p>
      </div>
      <div class="p-3.5 rounded-2xl bg-rose-50 text-rose-500">
        <i class="fas fa-exclamation-triangle text-xl"></i>
      </div>
    </div>
  </section>

  <!-- Charts Block -->
  <section class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm">
      <div class="flex justify-between items-start mb-4">
        <div>
          <h2 class="text-lg font-bold text-slate-800">Class-wise Fee Split</h2>
          <p class="text-xs text-slate-450 mt-0.5">Planned vs Paid vs Balance</p>
        </div>
      </div>
      <div class="h-80 relative">
        <canvas id="classwiseBarChart"></canvas>
      </div>
    </div>

    <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm">
      <div class="flex justify-between items-start mb-4">
        <div>
          <h2 class="text-lg font-bold text-slate-800">Balance Share By Class</h2>
          <p class="text-xs text-slate-450 mt-0.5">Where pending dues are concentrated</p>
        </div>
      </div>
      <div class="h-80 relative">
        <canvas id="balanceDonutChart"></canvas>
      </div>
    </div>
  </section>

  <!-- Batch-wise Monitor Block -->
  <section class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm mb-8 space-y-6">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
      <div>
        <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
          <i class="fas fa-sliders-h text-slate-400"></i> Batch-wise Monitor
        </h2>
        <p class="text-xs text-slate-450 mt-0.5">Filter fee performance variables by specific batches</p>
      </div>
      
      <select id="batchMonitorSelect" 
              class="border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl px-4 py-2.5 text-xs outline-none bg-white font-semibold text-slate-700 min-w-[260px] shadow-sm">
        <option value="">Select class</option>
      </select>
    </div>

    <!-- Batch-specific Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="border border-slate-100 rounded-2xl p-4 bg-slate-50/50">
        <p class="text-[9px] uppercase font-bold text-slate-400 tracking-wider">Batch Students</p>
        <p class="text-2xl font-extrabold text-slate-850 mt-1" id="batchStudentsMetric">0</p>
      </div>
      <div class="border border-slate-100 rounded-2xl p-4 bg-slate-50/50">
        <p class="text-[9px] uppercase font-bold text-slate-400 tracking-wider">Batch Total Fee</p>
        <p class="text-2xl font-extrabold text-slate-850 mt-1" id="batchTotalMetric">Rs 0</p>
      </div>
      <div class="border border-slate-100 rounded-2xl p-4 bg-slate-50/50">
        <p class="text-[9px] uppercase font-bold text-slate-400 tracking-wider">Batch Collected</p>
        <p class="text-2xl font-extrabold text-emerald-700 mt-1" id="batchPaidMetric">Rs 0</p>
        <p class="text-[10px] text-slate-400 font-semibold mt-1.5" id="batchPaidPct">0% of batch total</p>
      </div>
      <div class="border border-slate-100 rounded-2xl p-4 bg-slate-50/50">
        <p class="text-[9px] uppercase font-bold text-slate-400 tracking-wider">Batch Pending Dues</p>
        <p class="text-2xl font-extrabold text-rose-700 mt-1" id="batchBalanceMetric">Rs 0</p>
        <p class="text-[10px] text-slate-400 font-semibold mt-1.5" id="batchBalancePct">0% of batch total</p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 pt-2">
      <!-- Students Mini Table -->
      <div class="space-y-3">
        <h3 class="font-bold text-slate-800 text-sm">Students In Selected Batch</h3>
        <div class="max-h-72 overflow-y-auto border border-slate-150 rounded-2xl shadow-inner bg-slate-50/30">
          <table class="w-full text-left text-xs text-slate-650">
            <thead class="bg-slate-50 border-b border-slate-100 font-bold uppercase tracking-wider text-[9px] text-slate-700">
              <tr>
                <th class="p-3">Student Name</th>
                <th class="p-3 text-center">Total</th>
                <th class="p-3 text-center">Collected</th>
                <th class="p-3 text-center">Pending</th>
              </tr>
            </thead>
            <tbody id="batchStudentsTableBody" class="divide-y divide-slate-100">
              <tr>
                <td colspan="4" class="p-4 text-center text-slate-400 font-medium">Select a class to view details.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Student balance chart -->
      <div class="space-y-3">
        <h3 class="font-bold text-slate-800 text-sm">Batch Student-wise Balance</h3>
        <div class="h-72 relative border border-slate-150 rounded-2xl p-4 bg-slate-50/30">
          <canvas id="batchStudentBalanceChart"></canvas>
        </div>
      </div>
    </div>
  </section>

  <!-- Collection Trends & Top Pending -->
  <section class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm">
      <div class="flex justify-between items-start mb-4">
        <div>
          <h2 class="text-lg font-bold text-slate-800">Monthly Collection Trend</h2>
          <p class="text-xs text-slate-450 mt-0.5">Based on payment transaction logs</p>
        </div>
      </div>
      <div class="h-80 relative">
        <canvas id="monthlyTrendChart"></canvas>
      </div>
    </div>

    <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm flex flex-col justify-between">
      <div class="mb-4">
        <h2 class="text-lg font-bold text-slate-800">Top Outstanding Balances</h2>
        <p class="text-xs text-slate-450 mt-0.5">Active accounts sorted by highest dues</p>
      </div>
      <div id="topPendingList" class="space-y-2.5 max-h-[300px] overflow-y-auto pr-1"></div>
    </div>
  </section>

  <!-- Student Fee Table Master Section -->
  <section class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm space-y-4">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
      <div>
        <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
          <i class="fas fa-wallet text-slate-400"></i> Student Fee Table
        </h2>
        <p class="text-xs text-slate-450 mt-0.5">Search and inspect complete payments ledgers</p>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 w-full lg:w-auto">
        <input id="search" placeholder="Search by name or roll..." 
               class="border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl px-4 py-2.5 text-xs outline-none transition w-full sm:w-60 bg-slate-50/50 focus:bg-white" />
        <select id="batchFilter" 
                class="border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl px-4 py-2.5 text-xs outline-none bg-white font-semibold text-slate-700 min-w-[200px]">
          <option value="">All Classes</option>
        </select>
      </div>
    </div>

    <div class="overflow-x-auto border border-slate-100 rounded-2xl shadow-sm">
      <table class="w-full text-left text-sm text-slate-650">
        <thead class="bg-slate-50 border-b border-slate-100 font-bold uppercase tracking-wider text-xs text-slate-700">
          <tr>
            <th class="py-4 px-6">Student Name</th>
            <th class="py-4 px-6">Assigned Batch</th>
            <th class="py-4 px-6 text-center">Total Planned</th>
            <th class="py-4 px-6 text-center">Collected</th>
            <th class="py-4 px-6 text-center">Pending Balance</th>
            <th class="py-4 px-6 text-center">Actions</th>
          </tr>
        </thead>
        <tbody id="feeTable" class="divide-y divide-slate-100">
          <% fees.forEach(f => {
            const paid = f.payments.reduce((s,p)=>s+p.amount,0);
            const balance = f.totalFee - paid;
          %>
            <tr class="hover:bg-slate-50/50 transition fee-row"
                data-name="<%= f.student?.name || '' %>"
                data-roll="<%= f.student?.rollNumber || '' %>"
                data-batch="<%= f.student?.batch?.name || 'Unassigned' %>"
                data-total="<%= f.totalFee || 0 %>"
                data-paid="<%= paid || 0 %>"
                data-balance="<%= balance || 0 %>"
                data-payments='<%- JSON.stringify((f.payments || []).map(p => ({ amount: p.amount, date: p.date }))) %>'>
              
              <td class="py-3.5 px-6">
                <div class="font-bold text-slate-850"><%= f.student?.name || 'Unknown' %></div>
                <div class="text-xs text-slate-450 font-mono mt-0.5">Roll No: <%= f.student?.rollNumber || '-' %></div>
              </td>
              
              <td class="py-3.5 px-6">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-indigo-50 text-indigo-700 border border-indigo-150">
                  <%= f.student?.batch?.name || 'Unassigned' %>
                </span>
              </td>

              <td class="py-3.5 px-6 text-center font-bold text-slate-800">Rs <%= f.totalFee || 0 %></td>
              
              <td class="py-3.5 px-6 text-center">
                <span class="inline-flex px-3 py-1 text-xs font-bold bg-emerald-50 text-emerald-700 rounded-full border border-emerald-150">Rs <%= paid %></span>
              </td>

              <td class="py-3.5 px-6 text-center">
                <span class="inline-flex px-3 py-1 text-xs font-bold bg-rose-50 text-rose-700 rounded-full border border-rose-150">Rs <%= balance %></span>
              </td>

              <td class="py-3.5 px-6 text-center">
                <a href="/fees/student/<%= f.student?._id %>" 
                   class="inline-flex items-center gap-1 bg-indigo-55 hover:bg-indigo-100 text-indigo-750 font-bold text-xs px-3.5 py-1.5 rounded-xl transition">
                  <i class="fas fa-folder-open text-[10px]"></i> View Ledger
                </a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  (function () {
    const rows = Array.from(document.querySelectorAll(".fee-row"));
    const search = document.getElementById("search");
    const batchFilter = document.getElementById("batchFilter");
    const batchMonitorSelect = document.getElementById("batchMonitorSelect");
    const batchStudentsMetric = document.getElementById("batchStudentsMetric");
    const batchTotalMetric = document.getElementById("batchTotalMetric");
    const batchPaidMetric = document.getElementById("batchPaidMetric");
    const batchBalanceMetric = document.getElementById("batchBalanceMetric");
    const batchPaidPct = document.getElementById("batchPaidPct");
    const batchBalancePct = document.getElementById("batchBalancePct");
    const batchStudentsTableBody = document.getElementById("batchStudentsTableBody");

    const inr = (value) => `Rs ${Number(value || 0).toLocaleString("en-IN")}`;

    const batchMap = new Map();
    const monthMap = new Map();
    let totalStudents = 0;
    let overallTotal = 0;
    let overallPaid = 0;
    let overallBalance = 0;
    let batchStudentChart = null;

    const rowData = rows.map((row) => ({
      name: row.dataset.name || "Unknown",
      roll: row.dataset.roll || "-",
      batch: row.dataset.batch || "Unassigned",
      total: Number(row.dataset.total || 0),
      paid: Number(row.dataset.paid || 0),
      balance: Number(row.dataset.balance || 0),
    }));

    rows.forEach((row) => {
      totalStudents += 1;

      const batch = row.dataset.batch || "Unassigned";
      const total = Number(row.dataset.total || 0);
      const paid = Number(row.dataset.paid || 0);
      const balance = Number(row.dataset.balance || 0);

      overallTotal += total;
      overallPaid += paid;
      overallBalance += balance;

      if (!batchMap.has(batch)) {
        batchMap.set(batch, { total: 0, paid: 0, balance: 0, students: 0 });
      }
      const stat = batchMap.get(batch);
      stat.total += total;
      stat.paid += paid;
      stat.balance += balance;
      stat.students += 1;

      const payments = JSON.parse(row.dataset.payments || "[]");
      payments.forEach((payment) => {
        if (!payment || !payment.date) return;
        const dt = new Date(payment.date);
        if (Number.isNaN(dt.getTime())) return;

        const key = `${dt.getFullYear()}-${String(dt.getMonth() + 1).padStart(2, "0")}`;
        monthMap.set(key, (monthMap.get(key) || 0) + Number(payment.amount || 0));
      });
    });

    document.getElementById("metricStudents").textContent = totalStudents;
    document.getElementById("metricTotal").textContent = inr(overallTotal);
    document.getElementById("metricPaid").textContent = inr(overallPaid);
    document.getElementById("metricBalance").textContent = inr(overallBalance);
    const overallPaidPercent = overallTotal > 0 ? ((overallPaid / overallTotal) * 100).toFixed(1) : "0.0";
    const overallBalancePercent = overallTotal > 0 ? ((overallBalance / overallTotal) * 100).toFixed(1) : "0.0";
    document.getElementById("metricPaidPct").textContent = `${overallPaidPercent}%`;
    document.getElementById("metricBalancePct").textContent = `${overallBalancePercent}%`;

    const batchEntries = Array.from(batchMap.entries())
      .sort((a, b) => b[1].total - a[1].total);

    const batchLabels = batchEntries.map(([name]) => name);
    const batchTotals = batchEntries.map(([, values]) => values.total);
    const batchPaid = batchEntries.map(([, values]) => values.paid);
    const batchBalance = batchEntries.map(([, values]) => values.balance);

    const monthlyEntries = Array.from(monthMap.entries()).sort((a, b) => a[0].localeCompare(b[0]));
    const monthlyLabels = monthlyEntries.map(([key]) => {
      const [year, month] = key.split("-");
      return new Date(Number(year), Number(month) - 1, 1).toLocaleDateString("en-IN", {
        month: "short",
        year: "numeric",
      });
    });
    const monthlyValues = monthlyEntries.map(([, amount]) => amount);

    if (batchLabels.length) {
      new Chart(document.getElementById("classwiseBarChart"), {
        type: "bar",
        data: {
          labels: batchLabels,
          datasets: [
            {
              label: "Planned",
              data: batchTotals,
              backgroundColor: "rgba(99, 102, 241, 0.85)",
              borderRadius: 6
            },
            {
              label: "Collected",
              data: batchPaid,
              backgroundColor: "rgba(16, 185, 129, 0.85)",
              borderRadius: 6
            },
            {
              label: "Outstanding",
              data: batchBalance,
              backgroundColor: "rgba(244, 63, 94, 0.85)",
              borderRadius: 6
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { position: "top" },
          },
          scales: {
            y: { beginAtZero: true },
          },
        },
      });

      new Chart(document.getElementById("balanceDonutChart"), {
        type: "doughnut",
        data: {
          labels: batchLabels,
          datasets: [
            {
              data: batchBalance,
              backgroundColor: [
                "rgba(99, 102, 241, 0.85)",
                "rgba(16, 185, 129, 0.85)",
                "rgba(244, 63, 94, 0.85)",
                "rgba(245, 158, 11, 0.85)",
                "rgba(139, 92, 246, 0.85)",
                "rgba(6, 182, 212, 0.85)",
                "rgba(100, 116, 139, 0.85)",
                "rgba(236, 72, 153, 0.85)",
              ],
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { position: "bottom" },
          },
        },
      });
    }

    if (monthlyLabels.length) {
      new Chart(document.getElementById("monthlyTrendChart"), {
        type: "line",
        data: {
          labels: monthlyLabels,
          datasets: [
            {
              label: "Monthly Collection",
              data: monthlyValues,
              borderColor: "rgb(99, 102, 241)",
              backgroundColor: "rgba(99, 102, 241, 0.1)",
              fill: true,
              tension: 0.3,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
          },
          scales: {
            y: { beginAtZero: true },
          },
        },
      });
    }

    const topPending = rows
      .map((row) => ({
        name: row.dataset.name || "Unknown",
        roll: row.dataset.roll || "-",
        batch: row.dataset.batch || "Unassigned",
        balance: Number(row.dataset.balance || 0),
      }))
      .sort((a, b) => b.balance - a.balance)
      .slice(0, 8);

    const topPendingList = document.getElementById("topPendingList");
    topPendingList.innerHTML = topPending
      .map((student, index) => `
        <div class="flex items-center justify-between border border-slate-100 rounded-2xl p-3 bg-slate-50/50 hover:bg-slate-50 transition">
          <div>
            <p class="font-bold text-slate-800 text-sm">${index + 1}. ${student.name}</p>
            <p class="text-xs text-slate-400 font-semibold mt-0.5">Roll No: ${student.roll} | Batch: ${student.batch}</p>
          </div>
          <span class="text-sm font-extrabold text-rose-750">${inr(student.balance)}</span>
        </div>
      `)
      .join("");

    [...new Set(rows.map((row) => row.dataset.batch))]
      .filter(Boolean)
      .sort((a, b) => a.localeCompare(b))
      .forEach((batch) => {
        batchFilter.innerHTML += `<option value="${batch}">${batch}</option>`;
        if (batchMonitorSelect) {
          batchMonitorSelect.innerHTML += `<option value="${batch}">${batch}</option>`;
        }
      });

    function renderBatchMonitor(batch) {
      if (!batch) {
        batchStudentsMetric.textContent = "0";
        batchTotalMetric.textContent = inr(0);
        batchPaidMetric.textContent = inr(0);
        batchBalanceMetric.textContent = inr(0);
        if (batchPaidPct) batchPaidPct.textContent = "0% of batch total";
        if (batchBalancePct) batchBalancePct.textContent = "0% of batch total";
        batchStudentsTableBody.innerHTML = `
          <tr>
            <td colspan="4" class="p-4 text-center text-slate-400 font-semibold">Select a class to view details.</td>
          </tr>
        `;
        if (batchStudentChart) {
          batchStudentChart.destroy();
          batchStudentChart = null;
        }
        return;
      }

      const students = rowData.filter((item) => item.batch === batch);
      const totals = students.reduce((acc, item) => {
        acc.total += item.total;
        acc.paid += item.paid;
        acc.balance += item.balance;
        return acc;
      }, { total: 0, paid: 0, balance: 0 });

      batchStudentsMetric.textContent = String(students.length);
      batchTotalMetric.textContent = inr(totals.total);
      batchPaidMetric.textContent = inr(totals.paid);
      batchBalanceMetric.textContent = inr(totals.balance);
      const paidPercent = totals.total > 0 ? ((totals.paid / totals.total) * 100).toFixed(1) : "0.0";
      const balancePercent = totals.total > 0 ? ((totals.balance / totals.total) * 100).toFixed(1) : "0.0";
      if (batchPaidPct) batchPaidPct.textContent = `${paidPercent}% of batch total`;
      if (batchBalancePct) batchBalancePct.textContent = `${balancePercent}% of batch total`;

      if (!students.length) {
        batchStudentsTableBody.innerHTML = `
          <tr>
            <td colspan="4" class="p-4 text-center text-slate-400 font-medium">No fee data found for this class.</td>
          </tr>
        `;
      } else {
        batchStudentsTableBody.innerHTML = students
          .sort((a, b) => b.balance - a.balance)
          .map((student) => `
            <tr class="hover:bg-slate-50/50 transition">
              <td class="p-3">
                <p class="font-bold text-slate-800">${student.name}</p>
                <p class="text-[10px] text-slate-450 font-mono mt-0.5">Roll: ${student.roll}</p>
              </td>
              <td class="p-3 text-center font-bold text-slate-700">${inr(student.total)}</td>
              <td class="p-3 text-center text-emerald-700 font-extrabold">${inr(student.paid)}</td>
              <td class="p-3 text-center text-rose-700 font-extrabold">${inr(student.balance)}</td>
            </tr>
          `)
          .join("");
      }

      const labels = students.map((s) => s.name);
      const balanceData = students.map((s) => s.balance);

      if (batchStudentChart) {
        batchStudentChart.destroy();
      }

      batchStudentChart = new Chart(document.getElementById("batchStudentBalanceChart"), {
        type: "bar",
        data: {
          labels,
          datasets: [
            {
              label: "Outstanding Balance",
              data: balanceData,
              backgroundColor: "rgba(244, 63, 94, 0.85)",
              borderRadius: 6,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
          },
          scales: {
            y: { beginAtZero: true },
          },
        },
      });
    }

    batchMonitorSelect?.addEventListener("change", (event) => {
      renderBatchMonitor(event.target.value);
    });

    if (batchMonitorSelect && batchMonitorSelect.options.length > 1) {
      batchMonitorSelect.value = batchMonitorSelect.options[1].value;
      renderBatchMonitor(batchMonitorSelect.value);
    } else {
      renderBatchMonitor("");
    }

    function filterTable() {
      const s = search.value.toLowerCase();
      const b = batchFilter.value;

      rows.forEach((row) => {
        const visible =
          (row.dataset.name.toLowerCase().includes(s) || row.dataset.roll.toLowerCase().includes(s)) &&
          (!b || row.dataset.batch === b);

        row.style.display = visible ? "" : "none";
      });
    }

    search.addEventListener("input", filterTable);
    batchFilter.addEventListener("change", filterTable);
  })();
</script>
