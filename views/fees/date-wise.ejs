<div class="w-full px-6 py-8 space-y-6">
  <!-- Flash messages -->
  <%- include('../flash.ejs') %>

  <!-- Simplified Page Header -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 pb-5 border-b border-slate-200 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-900 tracking-tight">📅 Date-wise Fee Ledger</h1>
    </div>
    <a href="/fees" 
       class="inline-flex items-center gap-1.5 bg-white hover:bg-slate-50 text-slate-700 border border-slate-300 px-4 py-2 rounded-xl font-bold text-xs shadow-sm transition">
      <i class="fas fa-chevron-left text-[10px]"></i> Back
    </a>
  </div>

  <!-- Filter Selector Card -->
  <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm space-y-5">
    <form method="GET" action="/fees/date-wise" class="flex flex-col sm:flex-row gap-3 sm:items-end">
      <div class="space-y-1.5 flex-1 max-w-xs">
        <label for="date" class="block text-xs font-bold text-slate-500 uppercase tracking-wider">Payment Transaction Date</label>
        <input
          id="date"
          name="date"
          type="date"
          value="<%= selectedDate %>"
          required
          class="w-full border border-slate-300 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl px-4 py-2.5 text-xs outline-none transition font-semibold text-slate-700"
        />
      </div>

      <button
        type="submit"
        class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-xs px-5 py-3 rounded-xl shadow-sm transition"
      >
        Filter Records
      </button>
    </form>

    <div class="flex flex-wrap items-center gap-2 pt-2 border-t border-slate-100">
      <span class="text-xs font-bold text-slate-500 mr-2">Quick Presets:</span>
      <a href="/fees/date-wise?preset=today" class="px-3.5 py-1.5 rounded-xl text-xs font-bold border transition <%= preset === 'today' ? 'bg-indigo-600 text-white border-indigo-600 shadow-sm' : 'bg-white text-slate-700 border-slate-200 hover:bg-slate-50' %>">
        Today
      </a>
      <a href="/fees/date-wise?preset=yesterday" class="px-3.5 py-1.5 rounded-xl text-xs font-bold border transition <%= preset === 'yesterday' ? 'bg-indigo-600 text-white border-indigo-600 shadow-sm' : 'bg-white text-slate-700 border-slate-200 hover:bg-slate-50' %>">
        Yesterday
      </a>
      <a href="/fees/date-wise?preset=this-month" class="px-3.5 py-1.5 rounded-xl text-xs font-bold border transition <%= preset === 'this-month' ? 'bg-indigo-600 text-white border-indigo-600 shadow-sm' : 'bg-white text-slate-700 border-slate-200 hover:bg-slate-50' %>">
        This Month
      </a>
      <a href="/fees/date-wise" class="px-3.5 py-1.5 rounded-xl text-xs font-bold border bg-slate-100 text-slate-700 border-transparent hover:bg-slate-200 transition">
        Clear Filter
      </a>
    </div>
  </div>

  <% if (hasFilter) { %>
    <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm space-y-4">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 pb-3 border-b border-slate-100">
        <div>
          <p class="text-xs font-bold text-slate-500 uppercase tracking-wider">Filtered Payment Logs</p>
          <h2 class="text-lg font-bold text-slate-800 mt-1">
            Date Interval: <span class="text-indigo-650"><%= filterLabel %></span>
          </h2>
        </div>
        <div class="bg-emerald-50 border border-emerald-150 px-4 py-2.5 rounded-2xl text-emerald-800 font-extrabold text-sm shadow-sm">
          Total Collection: Rs <%= totalAmount.toLocaleString("en-IN") %>
        </div>
      </div>

      <div class="overflow-x-auto border border-slate-100 rounded-2xl shadow-sm">
        <table class="w-full text-left text-sm text-slate-650">
          <thead class="bg-slate-50 border-b border-slate-100 font-bold uppercase tracking-wider text-xs text-slate-700">
            <tr>
              <th class="py-4 px-6">Timestamp</th>
              <th class="py-4 px-6">Student Name</th>
              <th class="py-4 px-6">Roll Number</th>
              <th class="py-4 px-6">Class Batch</th>
              <th class="py-4 px-6 text-center">Amount Paid</th>
              <th class="py-4 px-6 text-center">Payment Mode</th>
              <th class="py-4 px-6 text-center">Receipt Number</th>
              <th class="py-4 px-6 text-center">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% if (rows.length === 0) { %>
              <tr>
                <td colspan="8" class="py-8 px-6 text-center text-slate-550 font-semibold italic">No fee payments logged for this filter date range.</td>
              </tr>
            <% } %>

            <% rows.forEach(row => { %>
              <tr class="hover:bg-slate-50/50 transition">
                <td class="py-3.5 px-6 font-semibold text-slate-700">
                  <%= new Date(row.paymentDate).toLocaleTimeString("en-IN", { hour: "2-digit", minute: "2-digit" }) %>
                </td>
                <td class="py-3.5 px-6 font-bold text-slate-850">
                  <%= row.studentName %>
                </td>
                <td class="py-3.5 px-6 font-mono text-xs text-slate-500 font-bold">
                  <%= row.rollNumber %>
                </td>
                <td class="py-3.5 px-6">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-indigo-50 text-indigo-700 border border-indigo-150">
                    <%= row.batchName %>
                  </span>
                </td>
                <td class="py-3.5 px-6 text-center font-extrabold text-slate-800">
                  Rs <%= Number(row.amount || 0).toLocaleString("en-IN") %>
                </td>
                <td class="py-3.5 px-6 text-center font-semibold text-slate-700">
                  <%= row.mode %>
                </td>
                <td class="py-3.5 px-6 text-center font-mono text-xs text-slate-550 font-bold">
                  <%= row.receiptNo %>
                </td>
                <td class="py-3.5 px-6 text-center">
                  <a href="/fees/student/<%= row.studentId %>" class="inline-flex items-center gap-1 bg-indigo-55 hover:bg-indigo-100 text-indigo-700 font-bold text-xs px-3 py-1.5 rounded-xl transition">
                    View Ledger
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>
</div>
