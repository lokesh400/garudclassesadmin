<div class="w-full px-6 py-8">
  <!-- Flash messages -->
  <%- include('../flash.ejs') %>

  <!-- Simplified Page Header -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 pb-5 border-b border-slate-200 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-900 tracking-tight">💰 Assign Student Fee Parameters</h1>
    </div>
    <a href="/fees" 
       class="inline-flex items-center gap-1.5 bg-white hover:bg-slate-50 text-slate-700 border border-slate-300 px-4 py-2 rounded-xl font-bold text-xs shadow-sm transition">
      <i class="fas fa-chevron-left text-[10px]"></i> Back
    </a>
  </div>

  <!-- Search and Stats Grid -->
  <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm mb-8 space-y-4">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <input id="studentSearch" type="text" placeholder="Search by student name, roll number, or class..." 
             class="border border-slate-300 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl px-4 py-2.5 text-xs outline-none transition w-full sm:max-w-md bg-white font-semibold text-slate-750" />
      <p id="studentCount" class="text-xs text-slate-500 font-bold bg-slate-100 px-3 py-1 rounded-full"><%= students.length %> active students</p>
    </div>

    <div class="overflow-x-auto border border-slate-100 rounded-2xl shadow-sm">
      <table class="w-full text-left text-sm text-slate-650">
        <thead class="bg-slate-50 border-b border-slate-100 font-bold uppercase tracking-wider text-xs text-slate-700">
          <tr>
            <th class="py-4 px-6">Name</th>
            <th class="py-4 px-6">Roll Number</th>
            <th class="py-4 px-6">Batch</th>
            <th class="py-4 px-6">Fee Status</th>
            <th class="py-4 px-6 text-center">Action</th>
          </tr>
        </thead>
        <tbody id="studentsTableBody" class="divide-y divide-slate-100">
          <% students.forEach(student => { %>
            <tr class="student-row hover:bg-slate-50/50 transition"
                data-name="<%= student.name.toLowerCase() %>"
                data-roll="<%= (student.rollNumber || '').toLowerCase() %>"
                data-batch="<%= (student.batch?.name || '').toLowerCase() %>">
              
              <td class="py-3.5 px-6 font-bold text-slate-850"><%= student.name %></td>
              <td class="py-3.5 px-6 font-mono text-xs text-slate-500 font-bold"><%= student.rollNumber || '-' %></td>
              <td class="py-3.5 px-6">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-indigo-50 text-indigo-700 border border-indigo-150">
                  <%= student.batch?.name || '-' %>
                </span>
              </td>
              <td class="py-3.5 px-6">
                <% if (studentFeeMap.has(String(student._id))) { %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-indigo-50 text-indigo-700 border border-indigo-150 uppercase tracking-wider">
                    Already Exists
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-amber-50 text-amber-700 border border-amber-150 uppercase tracking-wider">
                    Not Added
                  </span>
                <% } %>
              </td>
              <td class="py-3.5 px-6 text-center">
                <button
                  type="button"
                  class="open-fee-modal inline-flex items-center gap-1 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-xs px-4 py-2 rounded-xl transition"
                  data-student-id="<%= student._id %>"
                  data-student-name="<%= student.name %>"
                  data-student-roll="<%= student.rollNumber || '-' %>"
                  data-student-batch="<%= student.batch?.name || '-' %>"
                  data-admission-fee="<%= feeByStudent[String(student._id)]?.admissionFee || 0 %>"
                  data-tuition-fee="<%= feeByStudent[String(student._id)]?.tuitionFee || 0 %>"
                  data-transport-fee="<%= feeByStudent[String(student._id)]?.transportFee || 0 %>"
                  data-other-fee="<%= feeByStudent[String(student._id)]?.otherFee || 0 %>"
                >
                  Configure Fee
                </button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Modal Fee Form Sheet Backdrop -->
  <div id="feeModalBackdrop" class="hidden fixed inset-0 bg-slate-950/40 z-40 transition-all duration-300"></div>

  <!-- Modal sheet -->
  <div id="feeModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 overflow-y-auto" role="dialog" aria-modal="true" aria-labelledby="feeModalTitle">
    <div class="bg-white rounded-3xl shadow-xl w-full max-w-xl p-6 relative border border-slate-100">
      <button id="closeFeeModalTop" type="button" class="absolute top-4 right-4 text-slate-400 hover:text-slate-650 transition">
        <i class="fas fa-times text-lg"></i>
      </button>

      <div class="text-center mb-6">
        <span class="inline-flex p-3 bg-indigo-50 text-indigo-650 rounded-2xl mb-2">
          <i class="fas fa-wallet text-xl"></i>
        </span>
        <h2 id="feeModalTitle" class="text-xl font-extrabold text-slate-850">Assign Student Fee Structure</h2>
        <p id="feeStudentMeta" class="text-slate-500 text-xs mt-1.5 font-bold"></p>
      </div>

      <form method="POST" action="/fees/new" class="space-y-4">
        <input type="hidden" id="modalStudentId" name="studentId" />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5" for="modalAdmissionFee">Admission Fee</label>
            <div class="relative">
              <span class="absolute left-3.5 top-3 text-xs font-bold text-slate-400">Rs</span>
              <input id="modalAdmissionFee" class="w-full pl-9 pr-4 py-2.5 border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl text-xs outline-none transition font-semibold text-slate-700" type="number" min="0" name="admissionFee" value="0" required />
            </div>
          </div>

          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5" for="modalTuitionFee">Tuition Fee</label>
            <div class="relative">
              <span class="absolute left-3.5 top-3 text-xs font-bold text-slate-400">Rs</span>
              <input id="modalTuitionFee" class="w-full pl-9 pr-4 py-2.5 border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl text-xs outline-none transition font-semibold text-slate-700" type="number" min="0" name="tuitionFee" value="0" required />
            </div>
          </div>

          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5" for="modalTransportFee">Transport Fee</label>
            <div class="relative">
              <span class="absolute left-3.5 top-3 text-xs font-bold text-slate-400">Rs</span>
              <input id="modalTransportFee" class="w-full pl-9 pr-4 py-2.5 border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl text-xs outline-none transition font-semibold text-slate-700" type="number" min="0" name="transportFee" value="0" required />
            </div>
          </div>

          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5" for="modalOtherFee">Other Fee</label>
            <div class="relative">
              <span class="absolute left-3.5 top-3 text-xs font-bold text-slate-400">Rs</span>
              <input id="modalOtherFee" class="w-full pl-9 pr-4 py-2.5 border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl text-xs outline-none transition font-semibold text-slate-700" type="number" min="0" name="otherFee" value="0" required />
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-3">
          <button id="closeFeeModalBottom" type="button" class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold text-xs py-3 rounded-xl transition">Cancel</button>
          <button type="submit" class="bg-indigo-650 hover:bg-indigo-700 text-white font-bold text-xs py-3 rounded-xl transition shadow-sm">Save Fee Structure</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  (function () {
    const searchInput = document.getElementById("studentSearch");
    const rows = Array.from(document.querySelectorAll(".student-row"));
    const studentCount = document.getElementById("studentCount");
    const openButtons = Array.from(document.querySelectorAll(".open-fee-modal"));
    const modal = document.getElementById("feeModal");
    const modalBackdrop = document.getElementById("feeModalBackdrop");
    const closeFeeModalTop = document.getElementById("closeFeeModalTop");
    const closeFeeModalBottom = document.getElementById("closeFeeModalBottom");

    const modalStudentId = document.getElementById("modalStudentId");
    const modalStudentMeta = document.getElementById("feeStudentMeta");
    const modalAdmissionFee = document.getElementById("modalAdmissionFee");
    const modalTuitionFee = document.getElementById("modalTuitionFee");
    const modalTransportFee = document.getElementById("modalTransportFee");
    const modalOtherFee = document.getElementById("modalOtherFee");

    if (searchInput && rows.length) {
      searchInput.addEventListener("input", () => {
        const query = searchInput.value.trim().toLowerCase();
        let visibleCount = 0;

        rows.forEach((row) => {
          const matches =
            row.dataset.name.includes(query) ||
            row.dataset.roll.includes(query) ||
            row.dataset.batch.includes(query);

          row.style.display = matches ? "" : "none";
          if (matches) visibleCount += 1;
        });

        if (studentCount) {
          studentCount.textContent = `${visibleCount} active student${visibleCount === 1 ? "" : "s"}`;
        }
      });
    }

    function closeModal() {
      if (modal) modal.classList.add("hidden");
      if (modalBackdrop) modalBackdrop.classList.add("hidden");
      document.body.style.overflow = "";
    }

    function openModalFromButton(button) {
      if (!button || !modal || !modalBackdrop) return;

      const studentId = button.dataset.studentId || "";
      const studentName = button.dataset.studentName || "";
      const studentRoll = button.dataset.studentRoll || "-";
      const studentBatch = button.dataset.studentBatch || "-";

      if (modalStudentId) modalStudentId.value = studentId;
      if (modalStudentMeta) {
        modalStudentMeta.textContent = `Student Name: ${studentName} | Roll Number: ${studentRoll} | Assigned Batch: ${studentBatch}`;
      }

      if (modalAdmissionFee) modalAdmissionFee.value = button.dataset.admissionFee || "0";
      if (modalTuitionFee) modalTuitionFee.value = button.dataset.tuitionFee || "0";
      if (modalTransportFee) modalTransportFee.value = button.dataset.transportFee || "0";
      if (modalOtherFee) modalOtherFee.value = button.dataset.otherFee || "0";

      modal.classList.remove("hidden");
      modalBackdrop.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    }

    openButtons.forEach((button) => {
      button.addEventListener("click", () => openModalFromButton(button));
    });

    modalBackdrop?.addEventListener("click", closeModal);
    closeFeeModalTop?.addEventListener("click", closeModal);
    closeFeeModalBottom?.addEventListener("click", closeModal);

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeModal();
    });
  })();
</script>
