<div class="space-y-6">

  <!-- Welcome Banner -->
  <div class="bg-gradient-to-r from-indigo-600 via-blue-600 to-cyan-500 rounded-3xl p-6 md:p-8 text-white shadow-xl overflow-hidden relative">

    <div class="absolute top-0 right-0 opacity-10 text-[180px] font-bold leading-none">
      GC
    </div>

    <div class="relative z-10 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">

      <div>
        <p class="uppercase tracking-[3px] text-sm text-blue-100 mb-2">
          Reception Dashboard
        </p>

        <h2 class="text-3xl md:text-4xl font-bold leading-tight">
          Welcome, <%= currUser?.name %> 👋
        </h2>

        <p class="text-blue-100 mt-3 max-w-2xl text-sm md:text-base leading-relaxed">
          Manage admissions, student queries, forms and daily activities with ease.
          Thank you for helping students and parents every day.
        </p>
      </div>

      <div class="bg-white/20 backdrop-blur-lg border border-white/20 px-6 py-5 rounded-3xl min-w-[220px]">
        <p class="text-sm text-blue-100 mb-1">
          Today's Date
        </p>

        <h3 class="text-xl font-semibold">
          <%= new Date().toDateString() %>
        </h3>

        <div class="mt-4 flex items-center gap-2 text-sm text-blue-100">
          <span class="w-2 h-2 bg-green-300 rounded-full animate-pulse"></span>
          System Active
        </div>
      </div>

    </div>

  </div>


  <!-- Motivational Family Quote -->
  <div class="bg-white border border-gray-100 shadow-sm rounded-3xl p-6 md:p-7">

    <div class="flex gap-5 items-start">

      <div class="w-16 h-16 rounded-2xl bg-indigo-100 flex items-center justify-center shrink-0">
        <i class="fas fa-heart text-indigo-600 text-3xl"></i>
      </div>

      <div>

        <h3 class="text-2xl font-bold text-gray-800">
          You Are An Important Part Of The Garud Family 💙
        </h3>

        <p class="text-gray-600 mt-3 leading-relaxed text-[15px]">
          Every student you guide, every parent you help, and every query you solve
          creates trust and positivity. Your hard work is not just administration —
          it is support, care and motivation for hundreds of students chasing their dreams.
        </p>

        <div class="mt-5 bg-indigo-50 border border-indigo-100 rounded-2xl p-4">
          <p class="text-indigo-700 italic font-medium">
            “Great things in education are never done by one person —
            they are achieved together as a family.”
          </p>
        </div>

      </div>

    </div>

  </div>


  <!-- Main Grid -->
  <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">


    <!-- Quick Actions -->
    <div class="xl:col-span-2 bg-white rounded-3xl shadow-sm border border-gray-100 p-6">

      <div class="flex items-center justify-between mb-6">
        <div>
          <h2 class="text-2xl font-bold text-gray-800">
            Quick Actions
          </h2>

          <p class="text-gray-500 text-sm mt-1">
            Frequently used receptionist operations
          </p>
        </div>

        <div class="hidden md:flex items-center gap-2 text-sm text-green-600 font-medium">
          <span class="w-2 h-2 bg-green-500 rounded-full"></span>
          All Systems Running
        </div>
      </div>


      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

        <!-- All Forms -->
        <a href="/forms/list"
          class="group bg-blue-50 hover:bg-blue-100 border border-blue-100 rounded-3xl p-6 transition duration-300 hover:shadow-lg">

          <div class="w-16 h-16 rounded-2xl bg-blue-500 text-white flex items-center justify-center text-3xl mb-5 group-hover:scale-110 transition">
            <i class="fas fa-file-alt"></i>
          </div>

          <h3 class="text-lg font-bold text-gray-800">
            All Forms
          </h3>

          <p class="text-sm text-gray-500 mt-2">
            View and manage all student forms.
          </p>

        </a>


        <!-- Add Query -->
        <a href="/queries/new"
          class="group bg-green-50 hover:bg-green-100 border border-green-100 rounded-3xl p-6 transition duration-300 hover:shadow-lg">

          <div class="w-16 h-16 rounded-2xl bg-green-500 text-white flex items-center justify-center text-3xl mb-5 group-hover:scale-110 transition">
            <i class="fas fa-circle-question"></i>
          </div>

          <h3 class="text-lg font-bold text-gray-800">
            Add Query
          </h3>

          <p class="text-sm text-gray-500 mt-2">
            Register a new student or parent query.
          </p>

        </a>


        <!-- All Queries -->
        <a href="/queries"
          class="group bg-yellow-50 hover:bg-yellow-100 border border-yellow-100 rounded-3xl p-6 transition duration-300 hover:shadow-lg">

          <div class="w-16 h-16 rounded-2xl bg-yellow-500 text-white flex items-center justify-center text-3xl mb-5 group-hover:scale-110 transition">
            <i class="fas fa-comments"></i>
          </div>

          <h3 class="text-lg font-bold text-gray-800">
            All Queries
          </h3>

          <p class="text-sm text-gray-500 mt-2">
            Track and manage all submitted queries.
          </p>

        </a>

      </div>

    </div>



    <!-- Right Side Panel -->
    <div class="space-y-6">

      <!-- User Card -->
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6">

        <div class="flex flex-col items-center text-center">

          <img
            src="https://ui-avatars.com/api/?background=4f46e5&color=fff&name=<%= currUser?.name %>"
            class="w-24 h-24 rounded-full shadow-md border-4 border-indigo-100"
          />

          <h3 class="mt-4 text-xl font-bold text-gray-800">
            <%= currUser?.name %>
          </h3>

          <p class="text-indigo-600 font-medium">
            Receptionist
          </p>

          <div class="mt-5 w-full bg-gray-100 rounded-2xl p-4">

            <div class="flex justify-between text-sm mb-2">
              <span class="text-gray-500">Daily Productivity</span>
              <span class="font-semibold text-indigo-600">92%</span>
            </div>

            <div class="w-full bg-gray-200 rounded-full h-3">
              <div class="bg-indigo-600 h-3 rounded-full w-[92%]"></div>
            </div>

          </div>

        </div>

      </div>



      <!-- Small Quote Card -->
      <div class="bg-gradient-to-br from-indigo-500 to-blue-500 rounded-3xl p-6 text-white shadow-lg">

        <i class="fas fa-quote-left text-3xl opacity-40"></i>

        <p class="mt-4 leading-relaxed text-sm">
          Small acts of kindness and support can change a student's entire future.
        </p>

        <div class="mt-5 text-blue-100 text-sm">
          Garud Classes Team
        </div>

      </div>

    </div>

  </div>

</div>