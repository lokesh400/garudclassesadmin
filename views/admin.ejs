<div class="w-full px-6 py-8">
  <!-- Flash messages -->
  <%- include('./flash.ejs') %>

  <!-- Welcome / Banner Section -->
  <div class="bg-gradient-to-r from-indigo-650 to-purple-650 rounded-3xl p-6 md:p-8 text-white shadow-lg mb-8 relative overflow-hidden">
    <!-- Decorative background vector blobs -->
    <div class="absolute w-80 h-80 bg-white/5 rounded-full -top-10 -right-10 blur-2xl"></div>
    <div class="absolute w-40 h-40 bg-white/10 rounded-full bottom-0 right-20 blur-xl"></div>
    
    <div class="relative z-10 max-w-2xl">
      <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight">Welcome back, <%= currUser?.name || 'Admin' %>! 👋</h2>
    </div>
  </div>

  <!-- Statistics Grid -->
  <section class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <!-- Staff Management Card (Clickable Link) -->
    <a href="/admin/staff" class="group bg-white border border-slate-100 rounded-2xl p-6 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition duration-300 flex items-center justify-between">
      <div class="space-y-1">
        <p class="text-xs uppercase font-extrabold text-slate-500 tracking-wider">Staff Records</p>
        <p class="text-xl font-extrabold text-slate-850 group-hover:text-indigo-650 transition">Staff Documents</p>
      </div>
      <div class="p-4 rounded-xl bg-amber-50 text-amber-600 group-hover:bg-amber-100 transition duration-300">
        <i class="fas fa-users-cog text-2xl"></i>
      </div>
    </a>

    <!-- Students Count Card -->
    <div class="bg-white border border-slate-100 rounded-2xl p-6 shadow-sm flex items-center justify-between">
      <div class="space-y-1">
        <p class="text-xs uppercase font-extrabold text-slate-500 tracking-wider">Active Students</p>
        <p class="text-3xl font-extrabold text-slate-850"><%= students %></p>
      </div>
      <div class="p-4 rounded-xl bg-blue-50 text-blue-650">
        <i class="fas fa-user-graduate text-2xl"></i>
      </div>
    </div>

    <!-- Batches Count Card -->
    <div class="bg-white border border-slate-100 rounded-2xl p-6 shadow-sm flex items-center justify-between">
      <div class="space-y-1">
        <p class="text-xs uppercase font-extrabold text-slate-500 tracking-wider">Created Batches</p>
        <p class="text-3xl font-extrabold text-slate-850"><%= batches %></p>
      </div>
      <div class="p-4 rounded-xl bg-purple-50 text-purple-650">
        <i class="fas fa-layer-group text-2xl"></i>
      </div>
    </div>
  </section>

  <!-- Recent Activity / Admissions Grid -->
  <section class="bg-white border border-slate-100 rounded-3xl shadow-sm overflow-hidden">
    <div class="p-6 border-b border-slate-100">
      <h3 class="text-lg font-bold text-slate-850 flex items-center gap-2">
        <i class="fas fa-history text-slate-600"></i> Recent Admissions Activity
      </h3>
      <p class="text-slate-500 text-xs mt-1">Overview of latest student registrations and enrolled tracks</p>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-left text-sm text-slate-700">
        <thead class="bg-slate-50 text-slate-800 border-b border-slate-100 font-bold uppercase tracking-wider text-xs">
          <tr>
            <th class="py-4 px-6 text-center">#</th>
            <th class="py-4 px-6">Student Name</th>
            <th class="py-4 px-6">Assigned Batch</th>
            <th class="py-4 px-6">Contact Number</th>
            <th class="py-4 px-6">Admission Date</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <tr class="hover:bg-slate-50/50 transition">
            <td class="py-3.5 px-6 font-bold text-slate-500 text-center">1</td>
            <td class="py-3.5 px-6 font-bold text-slate-850">
              <div class="flex items-center gap-3">
                <img src="https://ui-avatars.com/api/?name=Aarav+Sharma&background=random" class="w-8 h-8 rounded-full border border-slate-100" alt="Aarav Sharma">
                <span>Aarav Sharma</span>
              </div>
            </td>
            <td class="py-3.5 px-6">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-blue-50 text-blue-700 border border-blue-150">
                11th JEE
              </span>
            </td>
            <td class="py-3.5 px-6 font-bold text-slate-700">+91 9876543210</td>
            <td class="py-3.5 px-6 text-slate-500 font-semibold">25 Oct 2025</td>
          </tr>
          <tr class="hover:bg-slate-50/50 transition">
            <td class="py-3.5 px-6 font-bold text-slate-500 text-center">2</td>
            <td class="py-3.5 px-6 font-bold text-slate-850">
              <div class="flex items-center gap-3">
                <img src="https://ui-avatars.com/api/?name=Priya+Patel&background=random" class="w-8 h-8 rounded-full border border-slate-100" alt="Priya Patel">
                <span>Priya Patel</span>
              </div>
            </td>
            <td class="py-3.5 px-6">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-emerald-50 text-emerald-700 border border-emerald-150">
                12th NEET
              </span>
            </td>
            <td class="py-3.5 px-6 font-bold text-slate-700">+91 9123456789</td>
            <td class="py-3.5 px-6 text-slate-500 font-semibold">23 Oct 2025</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
</div>
