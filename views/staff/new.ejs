<div class="w-full px-6 py-8">
  <!-- Flash messages -->
  <%- include('../flash.ejs') %>

  <!-- Top Dashboard Banner -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8 bg-white border border-slate-200 p-6 rounded-3xl shadow-sm">
    <div>
      <div class="flex items-center gap-2 text-sm text-slate-500 font-medium mb-1">
        <a href="/admin/staff" class="hover:text-indigo-650 transition">Staff Directory</a>
        <span>&bull;</span>
        <span class="text-slate-805 font-bold">New Staff Record</span>
      </div>
      <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight flex items-center gap-3">
        <span>👤 Register New Staff Member</span>
      </h1>
      <p class="text-slate-500 text-sm mt-1">Register the employee, assign their department, and set their user account role.</p>
    </div>

    <a href="/admin/staff" class="inline-flex items-center gap-1.5 bg-slate-100 hover:bg-slate-200 text-slate-700 px-4 py-2.5 rounded-xl font-bold text-xs transition">
      <i class="fas fa-chevron-left text-[10px]"></i> Back to Directory
    </a>
  </div>

  <div class="max-w-xl mx-auto">
    <form action="/admin/staff/add" method="POST" class="bg-white border border-slate-200 rounded-3xl p-6 md:p-8 shadow-sm space-y-6">
      <div class="space-y-4">
        <h3 class="text-xs font-extrabold text-indigo-600 uppercase tracking-widest flex items-center gap-1.5 pb-2 border-b border-slate-100">
          <i class="fas fa-id-card"></i> Profile & Account Details
        </h3>
        
        <div class="space-y-4">
          <!-- Full Name -->
          <div>
            <label class="block mb-1.5 text-xs font-bold text-slate-500 uppercase tracking-wider">Full Name <span class="text-red-500">*</span></label>
            <div class="relative">
              <span class="absolute left-4 top-3.5 text-slate-400 text-sm">
                <i class="fas fa-user"></i>
              </span>
              <input type="text" name="name" placeholder="Enter employee full name" required
                     class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl text-xs outline-none font-semibold text-slate-700 transition" />
            </div>
          </div>

          <!-- Email Address -->
          <div>
            <label class="block mb-1.5 text-xs font-bold text-slate-500 uppercase tracking-wider">Email Address <span class="text-red-500">*</span></label>
            <div class="relative">
              <span class="absolute left-4 top-3.5 text-slate-400 text-sm">
                <i class="fas fa-envelope"></i>
              </span>
              <input type="email" name="email" placeholder="Enter employee email address" required
                     class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl text-xs outline-none font-semibold text-slate-700 transition" />
            </div>
          </div>

          <!-- Department -->
          <div>
            <label class="block mb-1.5 text-xs font-bold text-slate-500 uppercase tracking-wider">Department <span class="text-red-500">*</span></label>
            <select id="departmentSelect" name="department" required 
                    class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-3 text-xs outline-none bg-white font-semibold text-slate-750 transition">
              <option value="" disabled selected>-- Select Department --</option>
              <option value="Academics">Academics</option>
              <option value="Non Teaching">Non Teaching</option>
              <option value="House Keeping">House Keeping</option>
            </select>
          </div>

          <!-- Assigned User Role -->
          <div>
            <label class="block mb-1.5 text-xs font-bold text-slate-500 uppercase tracking-wider">Assign Portal Role <span class="text-red-500">*</span></label>
            <select id="roleSelect" name="role" required disabled
                    class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-3 text-xs outline-none bg-slate-50 font-semibold text-slate-400 transition">
              <option value="" disabled selected>-- Select Department First --</option>
            </select>
          </div>

          <!-- Subjects (Only for Academics) -->
          <div id="subjectsSection" class="hidden space-y-2">
            <label class="block mb-1.5 text-xs font-bold text-slate-500 uppercase tracking-wider">Academics Subjects <span class="text-slate-455 font-normal">(Select one or more)</span></label>
            <div class="flex gap-2">
              <select id="subjectDropdown" class="flex-1 border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none bg-white font-semibold text-slate-750 transition">
                <option value="" disabled selected>-- Select Subject --</option>
                <option value="Maths">Maths</option>
                <option value="Physics">Physics</option>
                <option value="Chemistry">Chemistry</option>
                <option value="Biology">Biology</option>
                <option value="English">English</option>
                <option value="Social Studies">Social Studies</option>
                <option value="GK">General Knowledge (GK)</option>
                <option value="custom">-- Add Custom Subject --</option>
              </select>
              <button type="button" id="addSubjectBtn" class="bg-indigo-50 hover:bg-indigo-100 text-indigo-700 font-bold text-xs px-4 py-2.5 rounded-2xl transition">
                Add
              </button>
            </div>
            
            <div id="customSubjectDiv" class="hidden flex gap-2 mt-2">
              <input type="text" id="customSubjectInput" placeholder="Enter custom subject name"
                     class="flex-1 border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
              <button type="button" id="confirmCustomSubjectBtn" class="bg-teal-50 hover:bg-teal-100 text-teal-700 font-bold text-xs px-4 py-2.5 rounded-2xl transition">
                Confirm
              </button>
            </div>

            <div id="subjectChipsContainer" class="flex flex-wrap gap-2 pt-2"></div>
            <div id="hiddenSubjectsInputs"></div>
          </div>
        </div>
      </div>

      <!-- Submit & Action buttons -->
      <div class="pt-6 border-t border-slate-100 flex items-center justify-end gap-3">
        <a href="/admin/staff" class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold text-sm px-6 py-3 rounded-xl transition">
          Cancel
        </a>
        <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-sm px-6 py-3 rounded-xl transition shadow-md flex items-center gap-2">
          <i class="fas fa-user-plus"></i> Register & Send Credentials
        </button>
      </div>

    </form>
  </div>
</div>

<script>
  (function() {
    const deptSelect = document.getElementById("departmentSelect");
    const roleSelect = document.getElementById("roleSelect");

    // Mapping Department to Role options
    const roleMap = {
      "Academics": [
        { value: "teacher", label: "Teacher / Faculty" }
      ],
      "Non Teaching": [
        { value: "admin", label: "Admin" },
        { value: "receptionist", label: "Receptionist" }
      ],
      "House Keeping": [
        { value: "mts", label: "Multi-Tasking Staff (MTS)" }
      ]
    };

    // Subjects selection handling
    const subjectsSection = document.getElementById("subjectsSection");
    const subjectDropdown = document.getElementById("subjectDropdown");
    const addSubjectBtn = document.getElementById("addSubjectBtn");
    const customSubjectDiv = document.getElementById("customSubjectDiv");
    const customSubjectInput = document.getElementById("customSubjectInput");
    const confirmCustomSubjectBtn = document.getElementById("confirmCustomSubjectBtn");
    const subjectChipsContainer = document.getElementById("subjectChipsContainer");
    const hiddenInputsContainer = document.getElementById("hiddenSubjectsInputs");

    let selectedSubjects = [];

    const updateChips = () => {
      subjectChipsContainer.innerHTML = "";
      hiddenInputsContainer.innerHTML = "";

      selectedSubjects.forEach(sub => {
        // Render Chip
        const chip = document.createElement("div");
        chip.className = "inline-flex items-center gap-1 bg-indigo-50 border border-indigo-150 text-indigo-700 px-2.5 py-1 rounded-xl text-[10px] font-bold";
        chip.innerHTML = `
          <span>${sub}</span>
          <button type="button" class="text-indigo-400 hover:text-indigo-700 font-bold ml-1 outline-none">&times;</button>
        `;
        chip.querySelector("button").addEventListener("click", () => {
          selectedSubjects = selectedSubjects.filter(s => s !== sub);
          updateChips();
        });
        subjectChipsContainer.appendChild(chip);

        // Hidden input
        const hiddenInput = document.createElement("input");
        hiddenInput.type = "hidden";
        hiddenInput.name = "subjects";
        hiddenInput.value = sub;
        hiddenInputsContainer.appendChild(hiddenInput);
      });
    };

    addSubjectBtn.addEventListener("click", () => {
      const val = subjectDropdown.value;
      if (!val) return;

      if (val === "custom") {
        customSubjectDiv.classList.remove("hidden");
        customSubjectInput.focus();
      } else {
        if (!selectedSubjects.includes(val)) {
          selectedSubjects.push(val);
          updateChips();
        }
        subjectDropdown.value = "";
      }
    });

    confirmCustomSubjectBtn.addEventListener("click", () => {
      const val = customSubjectInput.value.trim();
      if (val) {
        if (!selectedSubjects.includes(val)) {
          selectedSubjects.push(val);
          updateChips();
        }
        customSubjectInput.value = "";
        customSubjectDiv.classList.add("hidden");
        subjectDropdown.value = "";
      }
    });

    deptSelect.addEventListener("change", function() {
      const selectedDept = deptSelect.value;
      const roles = roleMap[selectedDept] || [];

      // Clear existing options
      roleSelect.innerHTML = "";

      if (selectedDept === "Academics") {
        subjectsSection.classList.remove("hidden");
      } else {
        subjectsSection.classList.add("hidden");
        selectedSubjects = [];
        updateChips();
      }

      if (roles.length > 0) {
        roleSelect.disabled = false;
        roleSelect.classList.remove("bg-slate-50", "text-slate-400");
        roleSelect.classList.add("bg-white", "text-slate-750");

        roles.forEach(role => {
          const opt = document.createElement("option");
          opt.value = role.value;
          opt.textContent = role.label;
          roleSelect.appendChild(opt);
        });
      } else {
        roleSelect.disabled = true;
        roleSelect.classList.add("bg-slate-50", "text-slate-400");
        roleSelect.classList.remove("bg-white", "text-slate-750");
        
        const opt = document.createElement("option");
        opt.value = "";
        opt.textContent = "-- Select Department First --";
        roleSelect.appendChild(opt);
      }
    });
  })();
</script>
