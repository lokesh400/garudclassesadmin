
<div class="flex justify-between mb-6">
  <h2 class="text-2xl font-semibold">Staff</h2>
  <a href="/admin/staff/new"
     class="bg-green-600 text-white px-4 py-2 rounded">
    + Add Staff
  </a>
</div>

<table class="w-full bg-white rounded shadow">
  <thead class="bg-gray-200">
    <tr>
      <th class="p-3">Name</th>
      <th>Department</th>
      <th>Designation</th>
      <th>Status</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% staff.forEach(s => { %>
      <tr class="border-b">
        <td class="p-3"><%= s.name %></td>
        <td><%= s.department %></td>
        <td><%= s.designation %></td>
        <td>
          <span class="px-2 py-1 rounded text-sm 
            <%= s.status === 'Active' ? 'bg-green-200' : 'bg-gray-200' %>">
            <%= s.status %>
          </span>
        </td>
        <td>
          <a href="/admin/staff/<%= s._id %>" class="text-blue-600">View</a>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>
