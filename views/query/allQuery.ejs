<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<div class="w-full px-2 lg:px-4">

  <!-- ========================= -->
  <!-- FILTERS -->
  <!-- ========================= -->

  <div class="flex flex-wrap gap-3 items-end mb-4 bg-white p-3 lg:p-4 rounded-2xl shadow-sm border border-gray-100">

    <!-- Student -->
    <div>
      <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">
        Student
      </label>

      <input
        type="text"
        id="studentNameFilter"
        placeholder="Student name..."
        class="border rounded-xl px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
    </div>

    <!-- Status -->
    <div>
      <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">
        Status
      </label>

      <select
        id="statusFilter"
        class="border rounded-xl px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none">

        <option value="">All</option>
        <option value="Open">Open</option>
        <option value="Closed">Closed</option>

      </select>
    </div>

    <!-- Query Date -->
    <div>
      <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">
        Query Date
      </label>

      <input
        type="date"
        id="queryDateFilter"
        class="border rounded-xl px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
    </div>

    <!-- Follow-up Date -->
    <div>
      <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">
        Follow-up Date
      </label>

      <input
        type="date"
        id="followUpDateFilter"
        class="border rounded-xl px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
    </div>

    <!-- Staff Filter -->
    <% if(currUser.role === 'admin' || currUser.role === 'superadmin'){ %>

      <div>
        <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">
          Staff
        </label>

        <select
          id="userFilter"
          class="border rounded-xl px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none">

          <option value="">All Staff</option>

          <% 
            const uniqueUsers = [...new Map(
              queries
                .filter(q => q.createdBy)
                .map(q => [q.createdBy.name, q.createdBy])
            ).values()];
          %>

          <% uniqueUsers.forEach(user => { %>

            <option value="<%= user.name.toLowerCase() %>">
              <%= user.name %>
            </option>

          <% }) %>

        </select>
      </div>

    <% } %>

    <!-- Reset -->
    <button
      onclick="clearFilters()"
      class="bg-red-50 hover:bg-red-100 text-red-500 px-4 py-2 rounded-xl text-sm font-semibold transition">

      Reset

    </button>

  </div>



  <!-- ========================= -->
  <!-- DESKTOP TABLE -->
  <!-- ========================= -->

  <div class="hidden lg:block bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">

    <table class="min-w-full text-sm">

      <thead class="bg-gray-50 border-b">

        <tr class="text-left text-gray-600 uppercase text-xs">

          <th class="px-5 py-4">Student</th>
          <th class="px-5 py-4">Mobile</th>
          <th class="px-5 py-4">Description</th>
          <th class="px-5 py-4">Latest Follow-up</th>
          <th class="px-5 py-4">Status</th>

          <% if(currUser.role === 'admin' || currUser.role === 'superadmin'){ %>
            <th class="px-5 py-4">Created By</th>
          <% } %>

          <th class="px-5 py-4">Created At</th>
          <th class="px-5 py-4 text-center">Actions</th>

        </tr>

      </thead>

      <tbody class="divide-y divide-gray-100">

        <% queries.forEach(q => { %>

          <tr
            class="hover:bg-gray-50 transition query-item"

            data-student-name="<%= (q.studentName || '').toLowerCase() %>"
            data-status="<%= q.status %>"
            data-query-date="<%= new Date(q.createdAt).toISOString().split('T')[0] %>"
            data-followup-date="<%= q.latestFollowUp ? new Date(q.latestFollowUp.createdAt).toISOString().split('T')[0] : '' %>"
            data-creator="<%= q.createdBy?.name?.toLowerCase() || '' %>">

            <!-- Student -->
            <td class="px-5 py-4">

              <div class="font-bold text-gray-800">
                <%= q.studentName %>
              </div>

            </td>

            <!-- Mobile -->
            <td class="px-5 py-4">

              <div class="flex items-center gap-3">

                <span class="font-semibold text-blue-700">
                  <%= q.mobileNumber || 'N/A' %>
                </span>

                <% if(q.mobileNumber){ %>

                  <a
                    href="tel:<%= q.mobileNumber %>"
                    class="text-green-600 hover:text-green-700">

                    <i class="fas fa-phone"></i>

                  </a>

                <% } %>

              </div>

            </td>

            <!-- Description -->
            <td class="px-5 py-4 max-w-sm">

              <div class="text-gray-600 line-clamp-2">
                <%= q.description || 'No description available.' %>
              </div>

            </td>

            <!-- Follow-up -->
            <td class="px-5 py-4">

              <% if(q.latestFollowUp){ %>

                <div class="bg-green-50 border border-green-200 rounded-xl p-3">

                  <div class="flex items-center justify-between mb-2">

                    <div class="text-[10px] uppercase font-bold text-green-700">
                      Latest Follow-up
                    </div>

                    <div class="text-[10px] text-green-600 font-semibold">
                      <%= new Date(q.latestFollowUp.createdAt).toLocaleDateString() %>
                    </div>

                  </div>

                  <div class="text-sm text-green-900 line-clamp-2">
                    <%= q.latestFollowUp.note %>
                  </div>

                </div>

              <% } else { %>

                <div class="bg-gray-50 rounded-xl px-3 py-2 text-xs text-gray-400 italic">
                  No follow-up
                </div>

              <% } %>

            </td>

            <!-- Status -->
            <td class="px-5 py-4">

              <span class="<%= q.status === 'Open'
                ? 'bg-yellow-100 text-yellow-700'
                : 'bg-green-100 text-green-700' %>
                px-3 py-1 rounded-full text-xs font-bold">

                <%= q.status %>

              </span>

            </td>

            <!-- Created By -->
            <% if(currUser.role === 'admin' || currUser.role === 'superadmin'){ %>

              <td class="px-5 py-4">

                <div class="inline-flex items-center gap-2 bg-purple-50 text-purple-700 px-3 py-2 rounded-xl">

                  <i class="fas fa-user text-xs"></i>

                  <div>

                    <div class="text-[10px] uppercase font-bold">
                      Staff
                    </div>

                    <div class="text-xs font-semibold">
                      <%= q.createdBy?.name || 'Unknown' %>
                    </div>

                  </div>

                </div>

              </td>

            <% } %>

            <!-- Created Date -->
            <td class="px-5 py-4">

              <div class="inline-flex items-center gap-2 bg-blue-50 text-blue-700 px-3 py-2 rounded-xl">

                <i class="fas fa-calendar-alt text-xs"></i>

                <div>

                  <div class="text-[10px] uppercase font-bold">
                    Created
                  </div>

                  <div class="text-xs font-semibold">
                    <%= new Date(q.createdAt).toLocaleDateString() %>
                  </div>

                </div>

              </div>

            </td>

            <!-- Actions -->
            <td class="px-5 py-4">

              <div class="flex justify-center items-center gap-2">

                <a
                  href="/queries/<%= q._id %>"
                  class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-xl text-xs font-semibold transition">

                  View

                </a>

                <% if(q.mobileNumber){ %>

                  <a
                    href="https://wa.me/91<%= q.mobileNumber %>"
                    target="_blank"
                    class="bg-green-500 hover:bg-green-600 text-white px-3 py-2 rounded-xl transition">

                    <i class="fab fa-whatsapp"></i>

                  </a>

                <% } %>

              </div>

            </td>

          </tr>

        <% }) %>

      </tbody>

    </table>

  </div>



  <!-- ========================= -->
  <!-- MOBILE CARDS -->
  <!-- ========================= -->

  <div class="grid grid-cols-1 gap-3 lg:hidden">

    <% queries.forEach(q => { %>

      <div
        class="query-item bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden w-full"

        data-student-name="<%= (q.studentName || '').toLowerCase() %>"
        data-status="<%= q.status %>"
        data-query-date="<%= new Date(q.createdAt).toISOString().split('T')[0] %>"
        data-followup-date="<%= q.latestFollowUp ? new Date(q.latestFollowUp.createdAt).toISOString().split('T')[0] : '' %>"
        data-creator="<%= q.createdBy?.name?.toLowerCase() || '' %>">

        <div class="p-3">

          <!-- Top -->
          <div class="flex justify-between items-start mb-3">

            <div>

              <h2 class="text-[15px] font-bold text-gray-800 leading-tight">
                <%= q.studentName %>
              </h2>

              <div class="inline-flex items-center gap-1 bg-blue-50 text-blue-700 px-2 py-1 rounded-lg mt-1">

                <i class="fas fa-calendar-alt text-[9px]"></i>

                <span class="text-[10px] font-semibold">
                  <%= new Date(q.createdAt).toLocaleDateString() %>
                </span>

              </div>

            </div>

            <span class="<%= q.status === 'Open'
              ? 'bg-yellow-100 text-yellow-700'
              : 'bg-green-100 text-green-700' %>
              text-[10px] font-bold px-2.5 py-1 rounded-full">

              <%= q.status %>

            </span>

          </div>

          <!-- Description -->
          <div class="bg-gray-50 rounded-xl p-3 mb-3">

            <p class="text-sm text-gray-700 leading-relaxed">
              <%= q.description || 'No description available.' %>
            </p>

          </div>

          <!-- Mobile -->
          <div class="bg-blue-50 rounded-xl px-3 py-2 flex items-center justify-between mb-3">

            <div>

              <div class="text-[10px] text-blue-500 font-bold uppercase">
                Mobile
              </div>

              <div class="font-bold text-blue-800 text-sm">
                <%= q.mobileNumber || 'N/A' %>
              </div>

            </div>

            <% if(q.mobileNumber){ %>

              <a
                href="tel:<%= q.mobileNumber %>"
                class="bg-blue-600 hover:bg-blue-700 text-white px-3 py-2 rounded-xl transition">

                <i class="fas fa-phone"></i>

              </a>

            <% } %>

          </div>

          <!-- Follow-up -->
          <% if(q.latestFollowUp){ %>

            <div class="bg-green-50 border border-green-200 rounded-xl p-2.5 mb-3">

              <div class="flex items-center justify-between mb-1">

                <div class="text-[10px] uppercase font-bold text-green-700">
                  Latest Follow-up
                </div>

                <div class="text-[10px] text-green-600 font-semibold">
                  <%= new Date(q.latestFollowUp.createdAt).toLocaleDateString() %>
                </div>

              </div>

              <div class="text-sm text-green-900 leading-relaxed">
                <%= q.latestFollowUp.note %>
              </div>

            </div>

          <% } else { %>

            <div class="bg-gray-50 rounded-xl px-3 py-2 text-xs text-gray-400 italic mb-3">
              No follow-up
            </div>

          <% } %>

          <!-- Created By -->
          <% if(currUser.role === 'admin' || currUser.role === 'superadmin'){ %>

            <div class="flex items-center justify-between bg-purple-50 border border-purple-100 rounded-xl px-3 py-2 mb-3">

              <div>

                <div class="text-[10px] uppercase font-bold text-purple-600">
                  Created By
                </div>

                <div class="text-sm font-semibold text-purple-900">
                  <%= q.createdBy?.name || 'Unknown' %>
                </div>

              </div>

              <div class="bg-purple-100 text-purple-700 w-8 h-8 rounded-full flex items-center justify-center">

                <i class="fas fa-user text-xs"></i>

              </div>

            </div>

          <% } %>

          <!-- Buttons -->
          <div class="flex gap-2">

            <a
              href="/queries/<%= q._id %>"
              class="flex-1 bg-blue-600 hover:bg-blue-700 text-white text-center py-2.5 rounded-xl font-semibold text-sm transition">

              View Details

            </a>

            <% if(q.mobileNumber){ %>

              <a
                href="https://wa.me/91<%= q.mobileNumber %>"
                target="_blank"
                class="bg-green-500 hover:bg-green-600 text-white px-3 rounded-xl flex items-center justify-center transition">

                <i class="fab fa-whatsapp"></i>

              </a>

            <% } %>

          </div>

        </div>

      </div>

    <% }) %>

  </div>

</div>

<script>

  const studentNameInput =
    document.getElementById('studentNameFilter');

  const statusFilter =
    document.getElementById('statusFilter');

  const queryDateFilter =
    document.getElementById('queryDateFilter');

  const followUpDateFilter =
    document.getElementById('followUpDateFilter');

  const userFilter =
    document.getElementById('userFilter');

  const items =
    document.querySelectorAll('.query-item');



  function applyFilters() {

    const studentName =
      studentNameInput.value.toLowerCase().trim();

    const status =
      statusFilter.value;

    const queryDate =
      queryDateFilter.value;

    const followUpDate =
      followUpDateFilter.value;

    const creator =
      userFilter
        ? userFilter.value.toLowerCase().trim()
        : '';



    items.forEach(item => {

      const rowStudent =
        item.getAttribute('data-student-name') || '';

      const rowStatus =
        item.getAttribute('data-status') || '';

      const rowQueryDate =
        item.getAttribute('data-query-date') || '';

      const rowFollowupDate =
        item.getAttribute('data-followup-date') || '';

      const rowCreator =
        item.getAttribute('data-creator') || '';



      const matchesStudent =
        !studentName ||
        rowStudent.includes(studentName);

      const matchesStatus =
        !status ||
        rowStatus === status;

      const matchesQueryDate =
        !queryDate ||
        rowQueryDate === queryDate;

      const matchesFollowupDate =
        !followUpDate ||
        rowFollowupDate === followUpDate;

      const matchesCreator =
        !creator ||
        rowCreator.includes(creator);



      item.style.display =
        (
          matchesStudent &&
          matchesStatus &&
          matchesQueryDate &&
          matchesFollowupDate &&
          matchesCreator
        )
          ? ''
          : 'none';

    });

  }



  function clearFilters() {

    studentNameInput.value = '';
    statusFilter.value = '';
    queryDateFilter.value = '';
    followUpDateFilter.value = '';

    if(userFilter){
      userFilter.value = '';
    }

    applyFilters();

  }



  [
    studentNameInput,
    statusFilter,
    queryDateFilter,
    followUpDateFilter,
    userFilter
  ].forEach(el => {

    if(el){

      el.addEventListener('input', applyFilters);

    }

  });

</script>