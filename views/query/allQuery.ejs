<div class="w-full px-6 py-8">
  <!-- Flash messages -->
  <%- include('../flash.ejs') %>

  <!-- Simplified Page Header -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 pb-5 border-b border-slate-200 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-900 tracking-tight flex items-center gap-2">
        <span>❓ Student Query Management</span>
      </h1>
    </div>

    <a href="/queries/new" 
       class="inline-flex items-center gap-1.5 bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2.5 rounded-xl font-bold text-xs shadow-sm transition">
      <i class="fas fa-plus text-[10px]"></i> Add New Query
    </a>
  </div>

  <!-- Filters Panel -->
  <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8 bg-white p-5 rounded-3xl shadow-sm border border-slate-100 items-end">
    <!-- Student Filter -->
    <div class="space-y-1.5 col-span-2 md:col-span-1">
      <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider">Student Name</label>
      <input
        type="text"
        id="studentNameFilter"
        placeholder="Search student..."
        class="w-full px-3.5 py-2 border border-slate-300 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl text-xs outline-none transition"
      >
    </div>

    <!-- Status Filter -->
    <div class="space-y-1.5">
      <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider">Status</label>
      <select
        id="statusFilter"
        class="w-full px-3.5 py-2 border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl text-xs outline-none bg-white transition"
      >
        <option value="">All Status</option>
        <option value="Open">Open</option>
        <option value="Closed">Closed</option>
      </select>
    </div>

    <!-- Query Date Filter -->
    <div class="space-y-1.5">
      <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider">Query Date</label>
      <input
        type="date"
        id="queryDateFilter"
        class="w-full px-3.5 py-2 border border-slate-300 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl text-xs outline-none transition"
      >
    </div>

    <!-- Follow-up Date Filter -->
    <div class="space-y-1.5">
      <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider">Follow-up Date</label>
      <input
        type="date"
        id="followUpDateFilter"
        class="w-full px-3.5 py-2 border border-slate-300 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl text-xs outline-none transition"
      >
    </div>

    <!-- Staff Filter (conditional) -->
    <% if(currUser.role === 'admin' || currUser.role === 'superadmin'){ %>
      <div class="space-y-1.5">
        <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider">Created By</label>
        <select
          id="userFilter"
          class="w-full px-3.5 py-2 border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl text-xs outline-none bg-white transition"
        >
          <option value="">All Staff</option>
          <% 
            const uniqueUsers = [...new Map(
              queries
                .filter(q => q.createdBy)
                .map(q => [q.createdBy.name, q.createdBy])
            ).values()];
          %>
          <% uniqueUsers.forEach(user => { %>
            <option value="<%= user.name.toLowerCase() %>"><%= user.name %></option>
          <% }) %>
        </select>
      </div>
    <% } %>

    <!-- Reset Filters Button -->
    <div class="col-span-2 md:col-span-1">
      <button
        onclick="clearFilters()"
        class="w-full bg-slate-100 hover:bg-slate-200 text-slate-700 py-2.5 rounded-xl text-xs font-bold transition outline-none"
      >
        <i class="fas fa-undo mr-1 text-[10px]"></i> Reset Filters
      </button>
    </div>
  </div>

  <!-- DESKTOP DATA TABLE -->
  <div class="hidden lg:block bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
    <table class="w-full text-left text-sm text-slate-650">
      <thead class="bg-slate-50 border-b border-slate-100 font-bold uppercase tracking-wider text-xs text-slate-700">
        <tr>
          <th class="py-4 px-6">Student</th>
          <th class="py-4 px-6">Mobile Number</th>
          <th class="py-4 px-6">Issue Description</th>
          <th class="py-4 px-6">Latest Follow-up</th>
          <th class="py-4 px-6 text-center">Status</th>
          <% if(currUser.role === 'admin' || currUser.role === 'superadmin'){ %>
            <th class="py-4 px-6">Recorded By</th>
          <% } %>
          <th class="py-4 px-6">Created Date</th>
          <th class="py-4 px-6 text-center">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% queries.forEach(q => { %>
          <tr class="hover:bg-slate-50/50 transition query-item"
              data-student-name="<%= (q.studentName || '').toLowerCase() %>"
              data-status="<%= q.status %>"
              data-query-date="<%= new Date(q.createdAt).toISOString().split('T')[0] %>"
              data-followup-date="<%= q.latestFollowUp ? new Date(q.latestFollowUp.createdAt).toISOString().split('T')[0] : '' %>"
              data-creator="<%= q.createdBy?.name?.toLowerCase() || '' %>">
            
            <!-- Student -->
            <td class="py-4 px-6">
              <div class="font-bold text-slate-850"><%= q.studentName %></div>
            </td>

            <!-- Mobile -->
            <td class="py-4 px-6">
              <div class="flex items-center gap-2">
                <span class="font-semibold text-slate-700"><%= q.mobileNumber || 'N/A' %></span>
                <% if(q.mobileNumber){ %>
                  <a href="tel:<%= q.mobileNumber %>" class="text-indigo-650 hover:text-indigo-700 transition">
                    <i class="fas fa-phone-alt text-[10px]"></i>
                  </a>
                <% } %>
              </div>
            </td>

            <!-- Description -->
            <td class="py-4 px-6 max-w-xs">
              <p class="text-slate-650 text-xs line-clamp-2 leading-relaxed"><%= q.description || 'No description available.' %></p>
            </td>

            <!-- Follow-up -->
            <td class="py-4 px-6">
              <% if(q.latestFollowUp){ %>
                <div class="bg-emerald-50/50 border border-emerald-100 rounded-xl p-2.5 max-w-[200px]">
                  <div class="flex justify-between items-center gap-2 mb-1">
                    <span class="text-[8px] uppercase font-bold text-emerald-700 tracking-wider">Latest Update</span>
                    <span class="text-[9px] text-emerald-600 font-bold"><%= new Date(q.latestFollowUp.createdAt).toLocaleDateString() %></span>
                  </div>
                  <p class="text-[11px] text-emerald-950 line-clamp-2 font-bold"><%= q.latestFollowUp.note %></p>
                </div>
              <% } else { %>
                <span class="text-xs text-slate-500 italic font-semibold">No updates logged</span>
              <% } %>
            </td>

            <!-- Status -->
            <td class="py-4 px-6 text-center">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold <%= q.status === 'Open' ? 'bg-amber-50 text-amber-750 border border-amber-150' : 'bg-emerald-50 text-emerald-750 border border-emerald-150' %>">
                <%= q.status %>
              </span>
            </td>

            <!-- Created By -->
            <% if(currUser.role === 'admin' || currUser.role === 'superadmin'){ %>
              <td class="py-4 px-6">
                <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-xs font-semibold bg-purple-50 text-purple-700 border border-purple-150">
                  <i class="fas fa-user-tie text-[10px]"></i> <%= q.createdBy?.name || 'Staff' %>
                </span>
              </td>
            <% } %>

            <!-- Created Date -->
            <td class="py-4 px-6 text-slate-555 font-semibold text-xs">
              <%= new Date(q.createdAt).toLocaleDateString() %>
            </td>

            <!-- Actions -->
            <td class="py-4 px-6">
              <div class="flex items-center justify-center gap-2">
                <a href="/queries/<%= q._id %>" 
                   class="inline-flex items-center gap-1 bg-indigo-55 hover:bg-indigo-100 text-indigo-700 font-bold text-xs px-3.5 py-1.5 rounded-xl transition">
                  <i class="fas fa-eye text-[10px]"></i> View
                </a>
                <% if(q.mobileNumber){ %>
                  <a href="https://wa.me/91<%= q.mobileNumber %>" target="_blank" 
                     class="inline-flex items-center justify-center w-8 h-8 rounded-xl bg-emerald-50 text-emerald-750 hover:bg-emerald-100 transition border border-emerald-150 shadow-sm">
                    <i class="fab fa-whatsapp text-lg"></i>
                  </a>
                <% } %>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- MOBILE CARDS -->
  <div class="grid grid-cols-1 gap-4 lg:hidden">
    <% queries.forEach(q => { %>
      <div class="query-item bg-white border border-slate-100 rounded-3xl p-5 shadow-sm relative overflow-hidden"
           data-student-name="<%= (q.studentName || '').toLowerCase() %>"
           data-status="<%= q.status %>"
           data-query-date="<%= new Date(q.createdAt).toISOString().split('T')[0] %>"
           data-followup-date="<%= q.latestFollowUp ? new Date(q.latestFollowUp.createdAt).toISOString().split('T')[0] : '' %>"
           data-creator="<%= q.createdBy?.name?.toLowerCase() || '' %>">
        
        <div class="flex justify-between items-start gap-4 mb-4">
          <div>
            <h3 class="text-base font-bold text-slate-800"><%= q.studentName %></h3>
            <p class="text-slate-500 text-[10px] font-bold mt-0.5">Recorded: <%= new Date(q.createdAt).toLocaleDateString() %></p>
          </div>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold <%= q.status === 'Open' ? 'bg-amber-50 text-amber-700 border border-amber-150' : 'bg-emerald-50 text-emerald-700 border border-emerald-150' %>">
            <%= q.status %>
          </span>
        </div>

        <div class="bg-slate-50/50 rounded-2xl p-3 border border-slate-150 mb-3 text-xs text-slate-700 leading-relaxed font-medium">
          <%= q.description || 'No description available.' %>
        </div>

        <!-- Phone panel -->
        <div class="flex items-center justify-between bg-slate-50/50 border border-slate-150 rounded-2xl px-3.5 py-2 mb-3">
          <div>
            <span class="text-[9px] font-bold text-slate-500 uppercase tracking-wider block">Phone Directory</span>
            <span class="text-xs font-bold text-slate-800 mt-0.5 block"><%= q.mobileNumber || 'N/A' %></span>
          </div>
          <% if(q.mobileNumber){ %>
            <a href="tel:<%= q.mobileNumber %>" class="w-8 h-8 rounded-xl bg-indigo-50 hover:bg-indigo-100 text-indigo-700 flex items-center justify-center border border-indigo-150 transition">
              <i class="fas fa-phone-alt text-xs"></i>
            </a>
          <% } %>
        </div>

        <!-- Latest Follow-up -->
        <div class="mb-4">
          <% if(q.latestFollowUp){ %>
            <div class="bg-emerald-50/50 border border-emerald-100 rounded-2xl p-3">
              <div class="flex justify-between items-center mb-1">
                <span class="text-[8px] uppercase font-bold text-emerald-700 tracking-wider">Latest Follow-up</span>
                <span class="text-[9px] text-emerald-600 font-bold"><%= new Date(q.latestFollowUp.createdAt).toLocaleDateString() %></span>
              </div>
              <p class="text-xs text-emerald-950 font-bold"><%= q.latestFollowUp.note %></p>
            </div>
          <% } else { %>
            <div class="bg-slate-50 border border-slate-150 border-dashed rounded-2xl p-3 text-center text-xs text-slate-500 italic font-semibold">
              No follow-up updates recorded
            </div>
          <% } %>
        </div>

        <!-- Staff / Actions Footer -->
        <div class="flex items-center justify-between pt-3 border-t border-slate-100 gap-3">
          <div>
            <% if(currUser.role === 'admin' || currUser.role === 'superadmin'){ %>
              <span class="text-[9px] font-bold text-slate-400 uppercase tracking-wider block">Created By</span>
              <span class="text-xs font-semibold text-slate-650 mt-0.5 block"><%= q.createdBy?.name || 'Staff' %></span>
            <% } %>
          </div>

          <div class="flex gap-2">
            <% if(q.mobileNumber){ %>
              <a href="https://wa.me/91<%= q.mobileNumber %>" target="_blank" 
                 class="w-9 h-9 bg-emerald-50 text-emerald-700 hover:bg-emerald-100 border border-emerald-150 rounded-xl flex items-center justify-center transition shadow-sm">
                <i class="fab fa-whatsapp text-base"></i>
              </a>
            <% } %>
            <a href="/queries/<%= q._id %>" 
               class="bg-indigo-650 hover:bg-indigo-700 text-white text-xs font-bold px-4 py-2 rounded-xl transition shadow-sm flex items-center gap-1.5">
              View Info <i class="fas fa-chevron-right text-[9px]"></i>
            </a>
          </div>
        </div>

      </div>
    <% }) %>
  </div>
</div>

<script>
  const studentNameInput = document.getElementById('studentNameFilter');
  const statusFilter = document.getElementById('statusFilter');
  const queryDateFilter = document.getElementById('queryDateFilter');
  const followUpDateFilter = document.getElementById('followUpDateFilter');
  const userFilter = document.getElementById('userFilter');
  const items = document.querySelectorAll('.query-item');

  function applyFilters() {
    const studentName = studentNameInput.value.toLowerCase().trim();
    const status = statusFilter.value;
    const queryDate = queryDateFilter.value;
    const followUpDate = followUpDateFilter.value;
    const creator = userFilter ? userFilter.value.toLowerCase().trim() : '';

    items.forEach(item => {
      const rowStudent = item.getAttribute('data-student-name') || '';
      const rowStatus = item.getAttribute('data-status') || '';
      const rowQueryDate = item.getAttribute('data-query-date') || '';
      const rowFollowupDate = item.getAttribute('data-followup-date') || '';
      const rowCreator = item.getAttribute('data-creator') || '';

      const matchesStudent = !studentName || rowStudent.includes(studentName);
      const matchesStatus = !status || rowStatus === status;
      const matchesQueryDate = !queryDate || rowQueryDate === queryDate;
      const matchesFollowupDate = !followUpDate || rowFollowupDate === followUpDate;
      const matchesCreator = !creator || rowCreator.includes(creator);

      item.style.display = (matchesStudent && matchesStatus && matchesQueryDate && matchesFollowupDate && matchesCreator) ? '' : 'none';
    });
  }

  function clearFilters() {
    studentNameInput.value = '';
    statusFilter.value = '';
    queryDateFilter.value = '';
    followUpDateFilter.value = '';
    if(userFilter) userFilter.value = '';
    applyFilters();
  }

  [studentNameInput, statusFilter, queryDateFilter, followUpDateFilter, userFilter].forEach(el => {
    if(el) el.addEventListener('input', applyFilters);
  });
</script>