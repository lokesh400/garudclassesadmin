<div class="w-full px-6 py-8 space-y-6">

  <!-- Simplified Page Header -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 pb-5 border-b border-slate-200 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-900 tracking-tight">❓ Query Ledger Details</h1>
    </div>
    <a href="/queries" 
       class="inline-flex items-center gap-1.5 bg-white hover:bg-slate-50 text-slate-700 border border-slate-300 px-4 py-2 rounded-xl font-bold text-xs shadow-sm transition">
      <i class="fas fa-chevron-left text-[10px]"></i> Back
    </a>
  </div>

  <!-- Query Overview details -->
  <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between pb-4 border-b border-slate-100 gap-3">
      <div>
        <h2 class="text-xl font-bold text-slate-805"><%= query.studentName %></h2>
        <p class="text-xs text-slate-500 font-bold mt-1">Logged by: <span class="text-slate-700"><%= query.createdBy.name %></span></p>
      </div>

      <div>
        <% if(query.status === "Open") { %>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-750 border border-amber-150">
            Open Ticket
          </span>
        <% } else { %>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-emerald-50 text-emerald-755 border border-emerald-150">
            Closed Ticket
          </span>
        <% } %>
      </div>
    </div>

    <!-- Description Block -->
    <div class="bg-slate-50/50 border border-slate-150 rounded-2xl p-5">
      <span class="text-[9px] font-bold text-slate-500 uppercase tracking-wider block mb-2">Issue Description</span>
      <p class="text-sm text-slate-700 leading-relaxed font-semibold"><%= query.description %></p>
    </div>
  </div>

  <!-- Follow Ups Timeline -->
  <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm space-y-6">
    <h3 class="text-lg font-bold text-slate-800 flex items-center gap-2 border-b border-slate-100 pb-3">
      <i class="fas fa-history text-slate-400"></i> Follow-Up Updates & Timeline
    </h3>

    <% if (followUps.length === 0) { %>
      <div class="text-center py-6 text-slate-500 font-bold italic border border-dashed border-slate-200 rounded-2xl">
        No follow-up updates recorded for this ticket yet.
      </div>
    <% } else { %>
      <div class="relative pl-6 border-l-2 border-slate-150 space-y-6">
        <% followUps.forEach(followUp => { %>
          <div class="relative">
            <!-- Timeline dot -->
            <span class="absolute -left-[31px] top-1.5 w-4 h-4 rounded-full border-2 border-white bg-indigo-500 shadow-sm"></span>
            
            <div class="bg-slate-50/50 border border-slate-100 rounded-2xl p-4">
              <p class="text-xs text-slate-700 font-bold leading-relaxed"><%= followUp.note %></p>
              <span class="text-[10px] text-slate-500 font-semibold block mt-2">
                Logged at: <%= new Date(followUp.createdAt).toLocaleString("en-IN") %>
              </span>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <!-- Add Follow-Up Form -->
    <% if (query.status === "Open") { %>
      <form action="/queries/<%= query.id %>/followups/new" method="POST" id="followUpForm" class="pt-4 border-t border-slate-100 space-y-3">
        <div class="space-y-1.5">
          <label for="note" class="block text-xs font-bold text-slate-500 uppercase tracking-wider">Log New Update Note</label>
          <textarea
            id="note"
            name="note"
            rows="3"
            placeholder="Write a follow-up note detailing parent conversation or updates..."
            class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl p-4 text-xs outline-none transition resize-none font-semibold text-slate-700"
            required
          ></textarea>
        </div>
        
        <button class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-xs px-5 py-2.5 rounded-xl shadow-sm transition">
          Add Update Note
        </button>
      </form>
    <% } %>
  </div>

  <!-- Ticket Status Actions (Close ticket flow) -->
  <% if (query.status === "Open") { %>
    <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm space-y-4">
      <div>
        <h3 class="font-bold text-slate-800 text-sm">Close Query Ticket</h3>
        <p class="text-xs text-slate-500 mt-1">If this student issue has been successfully resolved, please document resolutions and close the ticket.</p>
      </div>

      <button
        class="bg-rose-600 hover:bg-rose-700 text-white font-bold text-xs px-5 py-2.5 rounded-xl shadow-sm transition"
        id="closeBtn">
        Close Ticket
      </button>

      <form
        method="POST"
        action="/queries/<%= query._id %>/close"
        id="form-btn"
        class="hidden pt-4 border-t border-slate-100 space-y-3">

        <div class="space-y-1.5">
          <label for="remarks" class="block text-xs font-bold text-slate-500 uppercase tracking-wider">Resolution Remarks</label>
          <textarea
            id="remarks"
            name="remarks"
            rows="3"
            placeholder="Explain final resolution remarks to document closure..."
            class="w-full border border-slate-200 focus:border-rose-500 focus:ring-2 focus:ring-rose-100 rounded-2xl p-4 text-xs outline-none transition resize-none font-semibold text-slate-700"
            required
          ></textarea>
        </div>

        <button class="bg-rose-600 hover:bg-rose-700 text-white font-bold text-xs px-5 py-2.5 rounded-xl shadow-sm transition">
          Confirm and Close Ticket
        </button>
      </form>
    </div>
  <% } else { %>
    <!-- Closing Remarks Card -->
    <div class="bg-emerald-50/30 border border-emerald-100 rounded-3xl p-6 space-y-4">
      <div>
        <h3 class="font-bold text-emerald-800 text-sm">Ticket Closure Log</h3>
        <p class="text-xs text-emerald-600 mt-1">Details recorded when this query ticket was resolved and closed</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm bg-white border border-emerald-100 rounded-2xl p-4">
        <div>
          <span class="block text-[9px] font-bold text-slate-500 uppercase tracking-wider">Closed By Staff</span>
          <span class="font-bold text-slate-800 mt-0.5 block"><%= query.closedBy?.name || 'Staff' %></span>
        </div>
        <div>
          <span class="block text-[9px] font-bold text-slate-500 uppercase tracking-wider">Closing Remarks</span>
          <span class="font-semibold text-slate-755 mt-0.5 block text-xs leading-relaxed"><%= query.remarks || 'No remarks provided.' %></span>
        </div>
      </div>
    </div>
  <% } %>

</div>

<script>
  (function () {
    const closeBtn = document.getElementById("closeBtn");
    const closeForm = document.getElementById("form-btn");
    const followUpForm = document.getElementById("followUpForm");

    if (closeBtn) {
      closeBtn.addEventListener("click", function (event) {
        if (confirm("Are you sure you want to proceed with closing this query ticket?")) {
          closeBtn.classList.add("hidden");
          if (followUpForm) followUpForm.classList.add("hidden");
          if (closeForm) closeForm.classList.remove("hidden");
        } else {
          event.preventDefault();
        }
      });
    }
  })();
</script>
