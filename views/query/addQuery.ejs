<div class="w-full px-6 py-8 space-y-6">

  <!-- Simplified Page Header -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 pb-5 border-b border-slate-200 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-900 tracking-tight">❓ Record Student Query</h1>
    </div>
    <a href="/queries" 
       class="inline-flex items-center gap-1.5 bg-white hover:bg-slate-50 text-slate-700 border border-slate-300 px-4 py-2 rounded-xl font-bold text-xs shadow-sm transition">
      <i class="fas fa-chevron-left text-[10px]"></i> Back
    </a>
  </div>

  <!-- Form Card -->
  <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden max-w-3xl">

    <!-- Top Gradient -->
    <div class="h-3 bg-gradient-to-r from-indigo-500 via-blue-500 to-cyan-400"></div>

    <form method="POST" class="p-6 md:p-8 space-y-6">

      <!-- Student Name -->
      <div>
        <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">
          Student Name
        </label>

        <div class="relative">
          <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-500">
            <i class="fas fa-user"></i>
          </span>

          <input
            type="text"
            name="studentName"
            placeholder="Enter student name"
            class="w-full pl-12 pr-4 py-4 rounded-2xl border border-slate-200 bg-slate-50/50 focus:bg-white focus:ring-4 focus:ring-indigo-100 focus:border-indigo-500 outline-none transition font-semibold text-slate-755"
            required
          >
        </div>
      </div>


      <!-- Mobile Number -->
      <div>
        <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">
          Mobile Number
        </label>

        <div class="relative">
          <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-500">
            <i class="fas fa-phone"></i>
          </span>

          <input
            type="tel"
            name="mobileNumber"
            placeholder="Enter mobile number"
            class="w-full pl-12 pr-4 py-4 rounded-2xl border border-slate-200 bg-slate-50/50 focus:bg-white focus:ring-4 focus:ring-indigo-100 focus:border-indigo-500 outline-none transition font-semibold text-slate-755"
            required
          >
        </div>
      </div>


      <!-- Description -->
      <div>
        <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">
          Query Description
        </label>

        <div class="relative">
          <span class="absolute left-4 top-5 text-slate-500">
            <i class="fas fa-comment-dots"></i>
          </span>

          <textarea
            name="description"
            rows="6"
            placeholder="Write student or parent query here..."
            class="w-full pl-12 pr-4 py-4 rounded-2xl border border-slate-200 bg-slate-50/50 focus:bg-white focus:ring-4 focus:ring-indigo-100 focus:border-indigo-500 outline-none transition resize-none font-semibold text-slate-755"
            required
          ></textarea>
        </div>
      </div>


      <!-- Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 pt-2">

        <button
          type="submit"
          class="flex-1 bg-gradient-to-r from-indigo-650 to-blue-500 hover:from-indigo-700 hover:to-blue-600 text-white py-4 rounded-2xl font-bold shadow-md transition duration-300"
        >
          <i class="fas fa-save mr-2"></i>
          Save Query
        </button>

        <a
          href="/queries"
          class="flex-1 text-center bg-slate-100 hover:bg-slate-200 text-slate-700 py-4 rounded-2xl font-bold transition flex items-center justify-center"
        >
          Cancel
        </a>

      </div>

    </form>

  </div>


  <!-- Bottom Motivation -->
  <div class="mt-6 bg-indigo-50/50 border border-indigo-100 rounded-3xl p-5 max-w-3xl">

    <div class="flex gap-4 items-start">

      <div class="w-12 h-12 rounded-2xl bg-indigo-100 flex items-center justify-center shrink-0">
        <i class="fas fa-heart text-indigo-600"></i>
      </div>

      <div>
        <h3 class="font-bold text-indigo-700">
          Every Query Matters 💙
        </h3>

        <p class="text-indigo-600 mt-1 text-xs leading-relaxed font-semibold">
          Helping students and parents with care builds trust and creates
          a positive learning environment for the entire Garud family.
        </p>
      </div>

    </div>

  </div>

</div>