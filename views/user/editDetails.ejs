<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Profile Details | Garud ERP</title>
  
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- FontAwesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  
  <!-- Google Fonts (Plus Jakarta Sans) -->
  <link rel="preconnect" href="https://fonts.gstatic.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <style>
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
    }
  </style>
</head>
<body class="bg-slate-50 min-h-screen text-slate-800 antialiased">

  <!-- Main Container -->
  <div class="w-full px-6 py-8 space-y-6">

    <!-- Top Navigation Row -->
    <div class="flex items-center justify-between gap-4 mb-6">
      <div class="flex items-center gap-2 text-sm text-slate-500 font-medium">
        <a href="/admin" class="hover:text-indigo-650 transition">Dashboard</a>
        <span>&bull;</span>
        <span class="text-slate-805 font-bold">Edit Profile</span>
      </div>

      <div class="flex items-center gap-2">
        <a href="/admin" class="inline-flex items-center gap-1.5 bg-slate-100 hover:bg-slate-200 text-slate-700 px-4 py-2 rounded-xl font-bold text-xs transition">
          <i class="fas fa-chevron-left text-[10px]"></i> Back to Portal
        </a>
      </div>
    </div>

    <!-- Header Banner -->
    <div class="bg-gradient-to-r from-indigo-650 via-purple-650 to-pink-600 rounded-3xl p-6 md:p-8 text-white shadow-lg relative overflow-hidden">
      <div class="absolute w-80 h-80 bg-white/5 rounded-full -top-10 -right-10 blur-2xl"></div>
      <div class="relative z-10">
        <h1 class="text-3xl font-extrabold tracking-tight">Configure User Profile</h1>
        <p class="text-indigo-50/90 text-sm mt-1.5 font-medium">Keep your account details up to date for easy communication and records</p>
      </div>
    </div>

    <!-- Form Container -->
    <form action="/user/profile/edit" method="POST" enctype="multipart/form-data" 
          class="bg-white border border-slate-100 rounded-3xl p-6 md:p-8 shadow-sm space-y-8">

      <!-- Profile Image Block -->
      <div class="flex flex-col items-center justify-center space-y-3 pb-6 border-b border-slate-100">
        <div class="relative group">
          <img id="preview" 
               src="<%= user.image || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.name) + '&background=random' %>" 
               alt="<%= user.name %>"
               class="w-28 h-28 rounded-full border-4 border-indigo-50 shadow-md object-cover transition duration-300">
          <div class="absolute inset-0 bg-black/40 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition duration-300 cursor-pointer" 
               onclick="document.getElementById('profile-pic-input').click()">
            <i class="fas fa-camera text-white text-xl"></i>
          </div>
        </div>
        
        <label for="profile-pic-input" class="cursor-pointer bg-slate-50 hover:bg-slate-100 border border-slate-200 text-slate-700 text-xs font-bold px-4 py-2 rounded-xl transition">
          <i class="fas fa-image mr-1 text-slate-500"></i> Change Image
        </label>
        <input id="profile-pic-input" type="file" name="image" class="hidden" onchange="previewImage(event)">
      </div>

      <!-- Personal details -->
      <div class="space-y-4">
        <h3 class="text-xs font-extrabold text-indigo-650 uppercase tracking-widest flex items-center gap-1.5">
          <i class="fas fa-user-circle"></i> Personal Details
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Full Name <span class="text-red-500">*</span></label>
            <input name="name" value="<%= user.name %>" required
                   class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
          </div>

          <div>
            <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Username</label>
            <input name="username" value="<%= user.username %>" readonly
                   class="w-full border border-slate-200 bg-slate-50 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-500 cursor-not-allowed" />
          </div>

          <div>
            <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Roll Number</label>
            <input name="rollNumber" value="<%= user.rollNumber || '' %>" readonly
                   class="w-full border border-slate-200 bg-slate-50 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-500 cursor-not-allowed" />
          </div>
        </div>
      </div>

      <!-- Contact details -->
      <div class="space-y-4">
        <h3 class="text-xs font-extrabold text-indigo-650 uppercase tracking-widest flex items-center gap-1.5">
          <i class="fas fa-address-book"></i> Contact Information
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Email Address</label>
            <input type="email" name="email" value="<%= user.email || '' %>"
                   class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
          </div>

          <div>
            <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Phone Number</label>
            <input name="number" value="<%= user.number || '' %>"
                   class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
          </div>

          <div class="md:col-span-2">
            <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Home Address</label>
            <input name="address" value="<%= user.address || '' %>"
                   class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
          </div>
        </div>
      </div>

      <!-- Family details -->
      <div class="space-y-4">
        <h3 class="text-xs font-extrabold text-indigo-650 uppercase tracking-widest flex items-center gap-1.5">
          <i class="fas fa-users"></i> Family Details
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Father's Name</label>
            <input name="fatherName" value="<%= user.fatherName || '' %>"
                   class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
          </div>

          <div>
            <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Mother's Name</label>
            <input name="motherName" value="<%= user.motherName || '' %>"
                   class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
          </div>
        </div>
      </div>

      <!-- Buttons -->
      <div class="pt-6 border-t border-slate-100 flex items-center justify-end gap-3">
        <a href="/admin" class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold text-sm px-6 py-2.5 rounded-xl transition">
          Cancel
        </a>
        <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-sm px-6 py-2.5 rounded-xl transition shadow-md">
          Save Changes
        </button>
      </div>

    </form>
  </div>

  <script>
    function previewImage(event) {
      if (event.target.files && event.target.files[0]) {
        document.getElementById("preview").src = URL.createObjectURL(event.target.files[0]);
      }
    }
  </script>

</body>
</html>
