<div class="w-full px-6 py-8 space-y-6">

  <!-- Header Section -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8 bg-white border border-slate-100 p-6 rounded-3xl shadow-sm">
    <div>
      <div class="flex items-center gap-2 text-sm text-slate-500 font-medium mb-1">
        <a href="/api/batches" class="hover:text-indigo-650 transition">Batches</a>
        <span>&bull;</span>
        <span class="text-slate-800 font-semibold">Timetable Configuration</span>
      </div>
      <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight flex items-center gap-3">
        <span>📅 Configure Weekly Schedule</span>
      </h1>
      <p class="text-slate-500 text-sm mt-1">Set subject slots, teachers, and timings for every weekday period</p>
    </div>

    <a href="/api/batches" class="inline-flex items-center gap-1.5 bg-slate-100 hover:bg-slate-200 text-slate-700 px-4 py-2.5 rounded-xl font-bold text-xs transition">
      <i class="fas fa-chevron-left text-[10px]"></i> Back to Batches
    </a>
  </div>

  <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm space-y-6">
    <input type="hidden" id="batchId" value="<%= batchId %>" />
    <input type="hidden" id="hasTimetable" value="<%= hasTimetable %>" />
    <script>const existingTimetable = <%- timetable || 'null' %>;</script>

    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 pb-4 border-b border-slate-100">
      <div class="flex items-center gap-3">
        <label for="periodCount" class="text-xs font-bold text-slate-500 uppercase tracking-wider">No. of Periods:</label>
        <input type="number" id="periodCount" min="1" max="10" value="6" 
               class="border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl px-3 py-1.5 text-xs outline-none w-20 font-semibold text-slate-700">
        <button type="button" id="generatePeriods" 
                class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-xs px-4 py-2 rounded-xl transition">
          Generate Grid
        </button>
      </div>
      <button type="button" id="copyAllBtn" 
              class="bg-emerald-650 hover:bg-emerald-700 text-white font-bold text-xs px-4 py-2 rounded-xl transition shadow-sm">
        <i class="fas fa-copy mr-1"></i> Copy Monday to All Days
      </button>
    </div>

    <div id="timetableContainer" class="overflow-x-auto border border-slate-100 rounded-2xl"></div>

    <div class="pt-4 border-t border-slate-100 flex justify-end">
      <button type="button" id="submitBtn" 
              class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-sm px-6 py-2.5 rounded-xl transition shadow-md">
        <%= hasTimetable ? "Update Weekly Timetable" : "Save Weekly Timetable" %>
      </button>
    </div>
  </div>

  <script>
    const days = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"];

    function generateTable(periodCount = 6) {
      let html = `<table class="w-full text-left text-sm text-slate-650">
        <thead class="bg-slate-50 border-b border-slate-100 font-bold uppercase tracking-wider text-xs text-slate-700">
          <tr>
            <th class="py-4 px-4 w-28 text-center border-r border-slate-100">Day</th>`;
      for (let i = 1; i <= periodCount; i++) {
        html += `<th class="py-4 px-4 text-center min-w-[150px] ${i !== periodCount ? 'border-r border-slate-100' : ''}">Period ${i}</th>`;
      }
      html += `</tr></thead><tbody class="divide-y divide-slate-100">`;

      days.forEach(day => {
        html += `<tr>
          <td class="py-3 px-4 font-bold text-slate-800 text-center bg-slate-50/50 border-r border-slate-100">${day}</td>`;
        for (let i = 1; i <= periodCount; i++) {
          html += `
            <td class="p-2 ${i !== periodCount ? 'border-r border-slate-100' : ''} bg-white space-y-1.5">
              <input type="text" class="subject border border-slate-200 focus:border-indigo-500 rounded-xl px-2.5 py-1.5 text-xs w-full outline-none font-semibold text-slate-700 placeholder-slate-400" placeholder="Subject" data-day="${day}" data-period="${i}">
              <input type="text" class="teacher border border-slate-200 focus:border-indigo-500 rounded-xl px-2.5 py-1.5 text-xs w-full outline-none font-semibold text-slate-700 placeholder-slate-400" placeholder="Teacher" data-day="${day}" data-period="${i}">
              <div class="grid grid-cols-2 gap-1.5">
                <input type="time" class="startTime border border-slate-200 focus:border-indigo-500 rounded-xl p-1 text-[10px] w-full outline-none font-bold text-slate-600" data-day="${day}" data-period="${i}">
                <input type="time" class="endTime border border-slate-200 focus:border-indigo-500 rounded-xl p-1 text-[10px] w-full outline-none font-bold text-slate-600" data-day="${day}" data-period="${i}">
              </div>
            </td>`;
        }
        html += `</tr>`;
      });

      html += `</tbody></table>`;
      document.getElementById("timetableContainer").innerHTML = html;

      // 🟢 Prefill existing data
      if (existingTimetable) {
        existingTimetable.forEach(dayObj => {
          dayObj.periods.forEach((p, index) => {
            const subInput = document.querySelector(`[data-day="${dayObj.day}"][data-period="${index + 1}"].subject`);
            const teachInput = document.querySelector(`[data-day="${dayObj.day}"][data-period="${index + 1}"].teacher`);
            const startInput = document.querySelector(`[data-day="${dayObj.day}"][data-period="${index + 1}"].startTime`);
            const endInput = document.querySelector(`[data-day="${dayObj.day}"][data-period="${index + 1}"].endTime`);
            
            if (subInput) subInput.value = p.subject || "";
            if (teachInput) teachInput.value = p.teacher || "";
            if (startInput) startInput.value = p.startTime || "";
            if (endInput) endInput.value = p.endTime || "";
          });
        });
      }
    }

    // Default load
    generateTable();

    document.getElementById("generatePeriods").addEventListener("click", () => {
      const count = parseInt(document.getElementById("periodCount").value);
      if (count > 0) generateTable(count);
    });

    // Copy Monday → all days
    document.getElementById("copyAllBtn").addEventListener("click", () => {
      const mondaySubjects = document.querySelectorAll('[data-day="Monday"].subject');
      const mondayTeachers = document.querySelectorAll('[data-day="Monday"].teacher');
      const mondayStart = document.querySelectorAll('[data-day="Monday"].startTime');
      const mondayEnd = document.querySelectorAll('[data-day="Monday"].endTime');
      const periodCount = mondaySubjects.length;

      days.slice(1).forEach(day => {
        for (let i = 0; i < periodCount; i++) {
          const sub = document.querySelector(`[data-day="${day}"][data-period="${i+1}"].subject`);
          const tea = document.querySelector(`[data-day="${day}"][data-period="${i+1}"].teacher`);
          const sta = document.querySelector(`[data-day="${day}"][data-period="${i+1}"].startTime`);
          const end = document.querySelector(`[data-day="${day}"][data-period="${i+1}"].endTime`);

          if (sub) sub.value = mondaySubjects[i].value;
          if (tea) tea.value = mondayTeachers[i].value;
          if (sta) sta.value = mondayStart[i].value;
          if (end) end.value = mondayEnd[i].value;
        }
      });
      showToast("✅ Copied Monday’s timetable to all days!", "success");
    });

    // Save or Update
    document.getElementById("submitBtn").addEventListener("click", async () => {
      const batchId = document.getElementById("batchId").value;
      const periodCount = parseInt(document.getElementById("periodCount").value);
      const timetable = [];

      days.forEach(day => {
        const dayPeriods = [];
        for (let i = 1; i <= periodCount; i++) {
          const subject = document.querySelector(`[data-day="${day}"][data-period="${i}"].subject`).value.trim();
          const teacher = document.querySelector(`[data-day="${day}"][data-period="${i}"].teacher`).value.trim();
          const startTime = document.querySelector(`[data-day="${day}"][data-period="${i}"].startTime`).value;
          const endTime = document.querySelector(`[data-day="${day}"][data-period="${i}"].endTime`).value;
          dayPeriods.push({ subject, teacher, startTime, endTime });
        }
        timetable.push({ day, periods: dayPeriods });
      });

      try {
        const res = await fetch("/api/timetable/create", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ batchId, timetable }),
        });

        const data = await res.json();
        showToast(data.message || "Timetable saved successfully!", "success");
      } catch (err) {
        showToast("Failed to save timetable", "error");
      }
    });
  </script>
</div>