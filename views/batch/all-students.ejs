<div class="w-full px-6 py-8 space-y-6">

  <!-- Flash messages -->
  <%- include('../flash.ejs') %>

  <!-- Top Dashboard Banner -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8 bg-white border border-slate-100 p-6 rounded-3xl shadow-sm">
    <div>
      <div class="flex items-center gap-2 text-sm text-slate-500 font-medium mb-1">
        <a href="/api/batches" class="hover:text-indigo-650 transition">Batches</a>
        <span>&bull;</span>
        <span class="text-slate-805 font-bold">Student Roster</span>
      </div>
      <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight flex items-center gap-3">
        <span>👥 Enrolled Students Directory</span>
      </h1>
      <p class="text-slate-500 text-sm mt-1">Manage active student credentials, access permissions, personal records, and file uploads</p>
    </div>

    <!-- Search Input -->
    <div class="w-full md:w-80">
      <div class="relative">
        <span class="absolute left-3.5 top-3 text-slate-400">
          <i class="fas fa-search text-xs"></i>
        </span>
        <input type="text" id="searchInput" placeholder="Search by name, roll, or email..." 
               class="w-full pl-9 pr-4 py-2.5 border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl text-xs outline-none bg-slate-50/50 focus:bg-white font-semibold text-slate-750 transition" />
      </div>
    </div>
  </div>

  <!-- Student Directory Table Card -->
  <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm overflow-hidden">
    <div class="overflow-x-auto border border-slate-100 rounded-2xl shadow-sm">
      <table class="w-full text-left text-sm text-slate-650" id="usersTable">
        <thead class="bg-slate-50 border-b border-slate-100 font-bold uppercase tracking-wider text-xs text-slate-700">
          <tr>
            <th class="py-4 px-6 text-center w-12">S.No</th>
            <th class="py-4 px-6">Avatar</th>
            <th class="py-4 px-6">Student details</th>
            <th class="py-4 px-6">Parent details</th>
            <th class="py-4 px-6">Roll Number</th>
            <th class="py-4 px-6">Assigned Batch</th>
            <th class="py-4 px-6 text-center">Status</th>
            <th class="py-4 px-6 text-center">Actions</th>
          </tr>
        </thead>
        <tbody id="userTableBody" class="divide-y divide-slate-100">
          <% { var i = 1 %>
          <% users.forEach(u => { %>
            <tr class="hover:bg-slate-50/50 transition">
              <td class="py-3.5 px-6 font-bold text-slate-500 text-center"><%= i++ %></td>
              
              <!-- Avatar -->
              <td class="py-3.5 px-6">
                <% if (u.image) { %>
                  <img src="<%= u.image %>" class="w-10 h-10 rounded-full border border-slate-200 object-cover shadow-sm" alt="Student avatar" />
                <% } else { %>
                  <div class="w-10 h-10 rounded-full bg-slate-100 border border-slate-200 flex items-center justify-center font-bold text-slate-600 text-xs">
                    <%= u.name ? u.name.slice(0,2).toUpperCase() : 'ST' %>
                  </div>
                <% } %>
              </td>

              <!-- Student Details -->
              <td class="py-3.5 px-6">
                <div class="font-bold text-slate-850"><%= u.name %></div>
                <div class="text-xs text-slate-500 font-medium mt-0.5"><%= u.username %> &bull; <span class="text-slate-450"><%= u.email %></span></div>
                <div class="text-[10px] text-indigo-650 font-bold mt-1"><%= u.number || '-' %></div>
              </td>

              <!-- Parent Details -->
              <td class="py-3.5 px-6 text-xs font-semibold text-slate-700">
                <div class="font-bold text-slate-800">F: <%= u.fatherName || '-' %></div>
                <div class="mt-0.5 text-slate-500">M: <%= u.motherName || '-' %></div>
              </td>

              <!-- Roll Number -->
              <td class="py-3.5 px-6 font-mono text-xs font-bold text-slate-500"><%= u.rollNumber || '-' %></td>

              <!-- Batch -->
              <td class="py-3.5 px-6">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-indigo-50 text-indigo-750 border border-indigo-150">
                  <%= u.batch ? u.batch.name : 'Unassigned' %>
                </span>
              </td>

              <!-- Status -->
              <td class="py-3.5 px-6 text-center">
                <% if (u.isActive === false) { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-rose-50 text-rose-700 border border-rose-150 uppercase tracking-wider">
                    Inactive
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-50 text-emerald-700 border border-emerald-150 uppercase tracking-wider">
                    Active
                  </span>
                <% } %>
              </td>

              <!-- Actions -->
              <td class="py-3.5 px-6 text-center">
                <div class="flex items-center justify-center gap-1.5">
                  <button
                    type="button"
                    class="bg-amber-50 hover:bg-amber-100 text-amber-700 border border-amber-150 font-extrabold text-[10px] px-3 py-1.5 rounded-xl transition"
                    onclick="openEditModal(
                      '<%= u._id %>', 
                      '<%= u.name %>', 
                      '<%= u.username %>', 
                      '<%= u.email || '' %>', 
                      '<%= u.number || '' %>', 
                      '<%= u.fatherName || '' %>', 
                      '<%= u.motherName || '' %>', 
                      '<%= u.rollNumber || '' %>', 
                      '<%= u.address || '' %>', 
                      '<%= u.role %>', 
                      <%= u.editAllowed || false %>,
                      <%= u.isActive ?? true %>
                    )"
                  >
                    Edit profile
                  </button>
                  <a 
                    href="/api/students/documents/<%= u._id %>"
                    class="bg-indigo-50 hover:bg-indigo-100 text-indigo-700 border border-indigo-150 font-extrabold text-[10px] px-3 py-1.5 rounded-xl transition"
                  >
                    Documents
                  </a>
                </div>
              </td>
            </tr>
          <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<!-- ✏️ Edit User Modal -->
<div id="editModal" class="hidden fixed inset-0 bg-slate-950/40 items-center justify-center z-50 p-4 transition-all duration-300">
  <div class="bg-white rounded-3xl shadow-xl w-full max-w-xl p-6 relative border border-slate-100 max-h-[90vh] overflow-y-auto">
    <button onclick="closeEditModal()" class="absolute top-4 right-4 text-slate-400 hover:text-slate-650 transition">
      <i class="fas fa-times text-lg"></i>
    </button>

    <div class="text-center mb-6">
      <span class="inline-flex p-3 bg-amber-50 text-amber-600 rounded-2xl mb-2">
        <i class="fas fa-user-edit text-xl"></i>
      </span>
      <h2 class="text-xl font-extrabold text-slate-850">Update Student Information</h2>
      <p class="text-slate-500 text-xs mt-1">Modify personal details, link permissions, and account settings</p>
    </div>

    <form id="editUserForm" class="space-y-5">
      <!-- Hidden ID Field -->
      <input type="hidden" id="editUserId" name="id" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Full Name <span class="text-red-500">*</span></label>
          <input type="text" id="editName" name="name" required
                 class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl px-3.5 py-2 text-xs outline-none font-semibold text-slate-700 transition" />
        </div>

        <div>
          <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Username</label>
          <input type="text" id="editUsername" name="username" readonly
                 class="w-full border border-slate-200 bg-slate-50 rounded-xl px-3.5 py-2 text-xs outline-none font-semibold text-slate-500 cursor-not-allowed" />
        </div>

        <div>
          <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Email Address</label>
          <input type="email" id="editEmail" name="email"
                 class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl px-3.5 py-2 text-xs outline-none font-semibold text-slate-700 transition" />
        </div>

        <div>
          <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Phone Number</label>
          <input type="text" id="editNumber" name="number"
                 class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl px-3.5 py-2 text-xs outline-none font-semibold text-slate-700 transition" />
        </div>

        <div>
          <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Father's Name</label>
          <input type="text" id="editFatherName" name="fatherName"
                 class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl px-3.5 py-2 text-xs outline-none font-semibold text-slate-700 transition" />
        </div>

        <div>
          <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Mother's Name</label>
          <input type="text" id="editMotherName" name="motherName"
                 class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl px-3.5 py-2 text-xs outline-none font-semibold text-slate-700 transition" />
        </div>

        <div>
          <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Roll Number</label>
          <input type="text" id="editRollNumber" name="rollNumber" readonly
                 class="w-full border border-slate-200 bg-slate-50 rounded-xl px-3.5 py-2 text-xs outline-none font-semibold text-slate-500 cursor-not-allowed" />
        </div>

        <div>
          <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Role</label>
          <input type="text" id="editRole" name="role" readonly
                 class="w-full border border-slate-200 bg-slate-50 rounded-xl px-3.5 py-2 text-xs outline-none font-semibold text-slate-500 cursor-not-allowed" />
        </div>
      </div>

      <div>
        <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Home Address</label>
        <textarea id="editAddress" name="address" rows="2" 
                  class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-xl p-3 text-xs outline-none font-semibold text-slate-700 resize-none transition"></textarea>
      </div>

      <div class="flex flex-col gap-2">
        <div class="flex items-center gap-2.5 p-3 bg-slate-50 border border-slate-100 rounded-2xl">
          <input type="checkbox" id="editEditAllowed" name="editAllowed" class="w-4 h-4 rounded border-slate-300 text-indigo-650 focus:ring-indigo-500" />
          <label for="editEditAllowed" class="text-xs font-bold text-slate-700">Allow student to self-update profile details</label>
        </div>

        <div class="flex items-center gap-2.5 p-3 bg-slate-50 border border-slate-100 rounded-2xl">
          <input type="checkbox" id="isActive" name="isActive" class="w-4 h-4 rounded border-slate-300 text-indigo-650 focus:ring-indigo-500" />
          <label for="isActive" class="text-xs font-bold text-slate-700">Account Active (Permit login access)</label>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-3 pt-3">
        <button type="button" onclick="closeEditModal()" 
                class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold text-xs py-3 rounded-xl transition">
          Cancel
        </button>
        <button type="submit" 
                class="bg-indigo-650 hover:bg-indigo-700 text-white font-bold text-xs py-3 rounded-xl transition shadow-sm">
          Save Changes
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  /** 
   * 🔍 Live Table Search 
   */
  document.getElementById("searchInput").addEventListener("input", function () {
    const filter = this.value.toLowerCase();
    const rows = document.querySelectorAll("#userTableBody tr");
    rows.forEach(row => {
      const text = row.innerText.toLowerCase();
      row.style.display = text.includes(filter) ? "" : "none";
    });
  });

  /** 
   * ✏️ Open and Populate Modal 
   */
  function openEditModal(id, name, username, email, number, fatherName, motherName, rollNumber, address, role, editAllowed, isActive) {
    document.getElementById("editUserId").value = id;
    document.getElementById("editName").value = name;
    document.getElementById("editUsername").value = username;
    document.getElementById("editEmail").value = email;
    document.getElementById("editNumber").value = number;
    document.getElementById("editFatherName").value = fatherName;
    document.getElementById("editMotherName").value = motherName;
    document.getElementById("editRollNumber").value = rollNumber;
    document.getElementById("editAddress").value = address;
    document.getElementById("editRole").value = role;
    
    document.getElementById("editEditAllowed").checked = (editAllowed === true || editAllowed === 'true');
    document.getElementById("isActive").checked = (isActive === true || isActive === 'true');

    const modal = document.getElementById("editModal");
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    document.body.style.overflow = "hidden";
  }

  /** 
   * ❌ Close Modal 
   */
  function closeEditModal() {
    const modal = document.getElementById("editModal");
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    document.body.style.overflow = "";
  }

  /** 
   * 💾 Handle Form Submission (AJAX) 
   */
  document.getElementById("editUserForm").addEventListener("submit", async function (e) {
    e.preventDefault();
    const id = document.getElementById("editUserId").value;
    
    const data = {
      name: document.getElementById("editName").value,
      username: document.getElementById("editUsername").value,
      email: document.getElementById("editEmail").value,
      number: document.getElementById("editNumber").value,
      fatherName: document.getElementById("editFatherName").value,
      motherName: document.getElementById("editMotherName").value,
      rollNumber: document.getElementById("editRollNumber").value,
      address: document.getElementById("editAddress").value,
      role: document.getElementById("editRole").value,
      editAllowed: document.getElementById("editEditAllowed").checked,
      isActive: document.getElementById("isActive").checked
    };

    try {
      const res = await fetch(`/api/students/edit/${id}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data)
      });

      const result = await res.json();
      
      if (result.success) {
        showToast("Student details updated successfully!", "success");
        closeEditModal();
        setTimeout(() => location.reload(), 1000);
      } else {
        showToast(result.message || "Failed to update details", "error");
      }
    } catch (err) {
      showToast("An error occurred while saving details", "error");
    }
  });
</script>
