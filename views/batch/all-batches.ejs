<div class="w-full px-6 py-8">
  <!-- Flash messages -->
  <%- include('../flash.ejs') %>

  <!-- Simplified Page Header -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 pb-5 border-b border-slate-200 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-900 tracking-tight flex items-center gap-2">
        <span>🎓 Manage Batches</span>
      </h1>
      <p class="text-slate-500 text-xs mt-1">Create and configure academic streams, schedules, and grade uploads</p>
    </div>

    <button id="openModalBtn" 
            class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-xl font-bold text-xs shadow-sm transition">
      <i class="fas fa-plus"></i> Add New Batch
    </button>
  </div>

  <!-- Batches Grid List -->
  <% if (batches.length > 0) { %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% batches.forEach(batch => { %>
        <div class="bg-white border border-slate-200 rounded-3xl p-6 shadow-sm hover:shadow-md transition duration-300 flex flex-col justify-between relative overflow-hidden <%= batch.isActive === false ? 'border-rose-200 bg-rose-50/10' : '' %>">
          
          <!-- Decorative subtle colored border for course type -->
          <% 
            let borderBg = 'bg-slate-600';
            let badgeClass = 'bg-slate-50 text-slate-700 border-slate-200';
            const cType = (batch.courseType || '').toUpperCase();
            if (cType === 'JEE') {
              borderBg = 'bg-blue-600';
              badgeClass = 'bg-blue-50 text-blue-700 border-blue-200';
            } else if (cType === 'NEET') {
              borderBg = 'bg-emerald-600';
              badgeClass = 'bg-emerald-50 text-emerald-700 border-emerald-200';
            } else if (cType === 'FOUNDATION') {
              borderBg = 'bg-violet-600';
              badgeClass = 'bg-violet-50 text-violet-700 border-violet-200';
            } else if (cType === 'NDA') {
              borderBg = 'bg-amber-600';
              badgeClass = 'bg-amber-50 text-amber-700 border-amber-200';
            }
          %>
          <div class="absolute top-0 left-0 w-2.5 h-full <%= borderBg %>"></div>

          <div class="pl-3 flex-1 flex flex-col justify-between">
            <div>
              <!-- Header batch info -->
              <div class="flex justify-between items-start gap-4 mb-3">
                <div>
                  <h3 class="text-xl font-bold text-slate-800 line-clamp-1"><%= batch.name %></h3>
                  <p class="text-slate-500 text-xs mt-1 font-bold">Academic Year: <%= batch.year %></p>
                </div>

                <!-- Status Badge -->
                <% if (batch.isActive === false) { %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-rose-50 text-rose-700 border border-rose-200">
                    Inactive
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold <%= badgeClass %>">
                    <%= batch.courseType %> Active
                  </span>
                <% } %>
              </div>

              <!-- Structured Quick Action Links -->
              <div class="grid grid-cols-2 gap-3 my-5 border-t border-b border-slate-200 py-4">
                <!-- Manage Section -->
                <div class="space-y-2 border-r border-slate-200 pr-2">
                  <p class="text-[10px] uppercase font-extrabold text-slate-500 tracking-wider">Students & Classes</p>
                  <div class="flex flex-col gap-1">
                    <a href="/api/batches/add/<%= batch._id %>" class="inline-flex items-center gap-1.5 text-xs text-slate-700 hover:text-indigo-600 hover:bg-indigo-50/50 p-1.5 rounded-lg transition duration-200 font-semibold">
                      <i class="fas fa-user-plus text-indigo-500 text-[10px] w-4 text-center"></i> Add Student
                    </a>
                    <a href="/api/students/all/<%= batch._id %>" class="inline-flex items-center gap-1.5 text-xs text-slate-700 hover:text-indigo-600 hover:bg-indigo-50/50 p-1.5 rounded-lg transition duration-200 font-semibold">
                      <i class="fas fa-users text-indigo-500 text-[10px] w-4 text-center"></i> View Students
                    </a>
                    <button type="button" onclick="openDownloadFieldsModal('<%= batch._id %>', '<%= batch.name %>')" class="inline-flex items-center gap-1.5 text-xs text-slate-700 hover:text-indigo-600 hover:bg-indigo-50/50 p-1.5 rounded-lg transition duration-200 font-semibold text-left outline-none">
                      <i class="fas fa-file-excel text-emerald-600 text-[10px] w-4 text-center"></i> Download Data
                    </button>
                    <a href="/api/timetable/<%= batch._id %>" class="inline-flex items-center gap-1.5 text-xs text-slate-700 hover:text-indigo-600 hover:bg-indigo-50/50 p-1.5 rounded-lg transition duration-200 font-semibold">
                      <i class="fas fa-clock text-indigo-500 text-[10px] w-4 text-center"></i> Timetable
                    </a>
                  </div>
                </div>

                <!-- Test Marks Section -->
                <div class="space-y-2 pl-3">
                  <p class="text-[10px] uppercase font-extrabold text-slate-500 tracking-wider">Academic Portal</p>
                  <div class="flex flex-col gap-1">
                    <a href="/marks/tests/<%= batch._id %>" class="inline-flex items-center gap-1.5 text-xs text-slate-700 hover:text-indigo-600 hover:bg-indigo-50/50 p-1.5 rounded-lg transition duration-200 font-semibold">
                      <i class="fas fa-chart-bar text-violet-500 text-[10px] w-4 text-center"></i> Tests Dashboard
                    </a>
                    <button onclick="openUploadModal('<%= batch._id %>')" class="inline-flex items-center gap-1.5 text-xs text-slate-700 hover:text-indigo-600 hover:bg-indigo-50/50 p-1.5 rounded-lg transition duration-200 font-semibold text-left outline-none">
                      <i class="fas fa-upload text-violet-500 text-[10px] w-4 text-center"></i> Upload Grades
                    </button>
                    <a href="/marks/download/<%= batch._id %>" class="inline-flex items-center gap-1.5 text-xs text-slate-700 hover:text-indigo-600 hover:bg-indigo-50/50 p-1.5 rounded-lg transition duration-200 font-semibold">
                      <i class="fas fa-file-excel text-violet-500 text-[10px] w-4 text-center"></i> Download Template
                    </a>
                  </div>
                </div>
              </div>

              <!-- Student Data Collection Section -->
              <div class="mt-4 pt-4 border-t border-slate-200">
                <p class="text-[10px] uppercase font-extrabold text-slate-500 tracking-wider mb-2">Student Data Collection</p>
                <% if (typeof batchFormMap !== 'undefined' && batchFormMap[batch._id.toString()]) { %>
                  <% const form = batchFormMap[batch._id.toString()]; %>
                  <div class="space-y-2">
                    <div class="flex justify-between items-center bg-slate-50 p-2.5 rounded-xl border border-slate-200">
                      <span class="font-bold text-slate-800 text-xs truncate max-w-[170px]" title="<%= form.title %>"><%= form.title %></span>
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-emerald-50 text-emerald-700 border border-emerald-200">
                        Form Active
                      </span>
                    </div>
                    <div class="flex flex-wrap gap-2 pt-1">
                      <button onclick="openShareModal('<%= form._id %>')" class="inline-flex items-center gap-1.5 text-xs bg-indigo-50 hover:bg-indigo-100 text-indigo-700 font-bold px-3 py-2 rounded-xl transition">
                        <i class="fas fa-share-alt text-[10px]"></i> Share Link
                      </button>
                      <a href="/forms/<%= form._id %>/submissions" class="inline-flex items-center gap-1.5 text-xs bg-blue-50 hover:bg-blue-100 text-blue-700 font-bold px-3 py-2 rounded-xl transition">
                        <i class="fas fa-list-ul text-[10px]"></i> Submissions
                      </a>
                    </div>
                  </div>
                <% } else { %>
                  <form action="/forms/create-for-batch/<%= batch._id %>" method="POST">
                    <button type="submit" class="w-full inline-flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-xs px-4 py-2.5 rounded-xl transition shadow-sm">
                      <i class="fas fa-file-signature text-[12px]"></i> Collect Data (Create Form)
                    </button>
                  </form>
                <% } %>
              </div>
            </div>

            <!-- Card Footer Main CTA -->
            <div class="mt-4 pt-4 border-t border-slate-200 flex justify-end">
              <a href="/api/batches/<%= batch._id %>" 
                 class="inline-flex items-center gap-1 bg-slate-100 hover:bg-indigo-600 hover:text-white text-slate-700 font-bold text-xs px-4 py-2.5 rounded-xl transition border border-slate-200 shadow-sm">
                View Batch Dashboard <i class="fas fa-chevron-right text-[10px]"></i>
              </a>
            </div>
          </div>

        </div>
      <% }) %>
    </div>
  <% } else { %>
    <!-- Empty State -->
    <div class="bg-white border border-dashed border-slate-200 rounded-3xl p-12 text-center max-w-xl mx-auto mt-8">
      <div class="inline-flex items-center justify-center p-4 bg-indigo-50 text-indigo-500 rounded-full mb-4">
        <i class="fas fa-graduation-cap text-4xl"></i>
      </div>
      <h3 class="text-lg font-bold text-slate-800 mb-1">No Batches Configured</h3>
      <p class="text-slate-500 text-sm mb-6">Create class batches and enrollment catalogs to configure curriculum calendars and grades sheets.</p>
      <button id="openModalBtnEmpty" 
              class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-xl font-bold text-sm shadow-sm transition">
        <i class="fas fa-plus"></i> Create First Batch
      </button>
    </div>
  <% } %>
</div>

<!-- Modal Create Batch -->
<div id="batchModal" class="hidden fixed inset-0 bg-slate-950/40 flex items-center justify-center z-50 p-4 transition-all duration-300">
  <div class="bg-white rounded-3xl shadow-xl w-full max-w-md p-6 relative border border-slate-100">
    <button id="closeModalBtn" class="absolute top-4 right-4 text-slate-400 hover:text-slate-650 transition">
      <i class="fas fa-times text-lg"></i>
    </button>

    <div class="text-center mb-6">
      <span class="inline-flex p-3 bg-indigo-50 text-indigo-600 rounded-2xl mb-2">
        <i class="fas fa-layer-group text-xl"></i>
      </span>
      <h2 class="text-xl font-extrabold text-slate-850">Create New Batch</h2>
      <p class="text-slate-400 text-xs mt-1">Configure name, exam curriculum, and catalog year</p>
    </div>

    <form id="batchForm" class="space-y-4">
      <div>
        <label for="name" class="block text-slate-700 font-bold mb-1.5 text-xs uppercase tracking-wider">Batch Name</label>
        <input type="text" id="name" placeholder="e.g. 11th JEE Alpha" 
               class="w-full px-4 py-3 border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl text-sm outline-none transition duration-200" required />
      </div>

      <div>
        <label for="courseType" class="block text-slate-700 font-bold mb-1.5 text-xs uppercase tracking-wider">Course Type</label>
        <select id="courseType" 
                class="w-full px-4 py-3 border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl text-sm outline-none transition duration-200 bg-white" required>
          <option value="">Select Course Type</option>
          <option value="JEE">JEE</option>
          <option value="NEET">NEET</option>
          <option value="FOUNDATION">FOUNDATION</option>
          <option value="NDA">NDA</option>
        </select>
      </div>

      <div>
        <label for="year" class="block text-slate-700 font-bold mb-1.5 text-xs uppercase tracking-wider">Year</label>
        <input type="text" id="year" placeholder="e.g. 2026" 
               class="w-full px-4 py-3 border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl text-sm outline-none transition duration-200" required />
      </div>

      <div class="pt-2">
        <button type="submit" 
                class="w-full py-3.5 bg-indigo-650 hover:bg-indigo-700 text-white font-bold rounded-2xl shadow-sm hover:shadow transition duration-200 text-sm">
          Create Batch
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Upload Marks -->
<div id="uploadModal" class="hidden fixed inset-0 bg-slate-950/40 flex items-center justify-center z-50 p-4 transition-all duration-300">
  <div class="bg-white rounded-3xl shadow-xl w-full max-w-md p-6 relative border border-slate-100">
    <button id="closeUploadModalBtn" class="absolute top-4 right-4 text-slate-400 hover:text-slate-650 transition">
      <i class="fas fa-times text-lg"></i>
    </button>

    <div class="text-center mb-6">
      <span class="inline-flex p-3 bg-indigo-50 text-indigo-600 rounded-2xl mb-2">
        <i class="fas fa-file-excel text-xl"></i>
      </span>
      <h2 class="text-xl font-extrabold text-slate-850">Upload Grades Sheet</h2>
      <p class="text-slate-400 text-xs mt-1">Import grades using the matching batch template</p>
    </div>

    <form id="uploadForm" enctype="multipart/form-data" class="space-y-4">
      <input type="hidden" id="uploadBatchId" name="batchId" />

      <div>
        <label class="block text-slate-700 font-bold mb-1.5 text-xs uppercase tracking-wider">Test Title</label>
        <input type="text" id="testTitle" name="testTitle" placeholder="e.g. Weekly Test 5" 
               class="w-full px-4 py-3 border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl text-sm outline-none transition duration-200" required />
      </div>

      <div>
        <label class="block text-slate-700 font-bold mb-1.5 text-xs uppercase tracking-wider">Spreadsheet (.xlsx)</label>
        <input type="file" id="excelFile" name="excelFile" accept=".xlsx" 
               class="w-full px-4 py-3 border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl text-sm outline-none transition duration-200 bg-white" required />
      </div>

      <div class="pt-2">
        <button type="submit" id="uploadFormSubmitBtn"
                class="w-full py-3.5 bg-indigo-650 hover:bg-indigo-700 text-white font-bold rounded-2xl shadow-sm hover:shadow transition duration-200 text-sm">
          Upload Grades
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  const uploadModal = document.getElementById("uploadModal");
  const closeUploadModalBtn = document.getElementById("closeUploadModalBtn");
  const uploadForm = document.getElementById("uploadForm");

  function openUploadModal(batchId) {
    document.getElementById("uploadBatchId").value = batchId;
    uploadModal.classList.remove("hidden");
  }

  closeUploadModalBtn.addEventListener("click", () => {
    uploadModal.classList.add("hidden");
  });

  window.addEventListener("click", (e) => {
    if (e.target === uploadModal) uploadModal.classList.add("hidden");
  });

  uploadForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    const batchId = document.getElementById("uploadBatchId").value;
    const formData = new FormData(uploadForm);
    const submitBtn = document.getElementById("uploadFormSubmitBtn");

    submitBtn.disabled = true;
    submitBtn.innerText = "Processing File...";

    try {
      const res = await fetch(`/marks/upload/${batchId}`, {
        method: "POST",
        body: formData,
        headers: { "Accept": "application/json" }
      });

      const data = await res.json();
      if (res.ok) {
        if (typeof showToast === 'function') {
          showToast(data.message, "success");
        } else {
          alert(data.message);
        }
        uploadModal.classList.add("hidden");
        // Reload list after a second to display updated stats
        setTimeout(() => location.reload(), 1000);
      } else {
        if (typeof showToast === 'function') {
          showToast(data.message || "Failed to upload file", "error");
        } else {
          alert(data.message || "Failed to upload file");
        }
      }
    } catch (err) {
      if (typeof showToast === 'function') {
        showToast("Error uploading file", "error");
      } else {
        alert("Error uploading file");
      }
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerText = "Upload Grades";
    }
  });
</script>

<script>
  // Open and close batch create modal
  const modal = document.getElementById("batchModal");
  const openModalBtn = document.getElementById("openModalBtn");
  const openModalBtnEmpty = document.getElementById("openModalBtnEmpty");
  const closeModalBtn = document.getElementById("closeModalBtn");

  const openAction = () => {
    modal.classList.remove("hidden");
  };

  openModalBtn?.addEventListener("click", openAction);
  openModalBtnEmpty?.addEventListener("click", openAction);

  closeModalBtn.addEventListener("click", () => {
    modal.classList.add("hidden");
  });

  window.addEventListener("click", (e) => {
    if (e.target === modal) modal.classList.add("hidden");
  });

  // Handle batch form submission
  document.getElementById("batchForm").addEventListener("submit", async (e) => {
    e.preventDefault();

    const name = document.getElementById("name").value.trim();
    const courseType = document.getElementById("courseType").value;
    const year = document.getElementById("year").value.trim();

    if (!name || !courseType || !year) {
      if (typeof showToast === 'function') {
        showToast("Please fill all fields before submitting.", "error");
      } else {
        alert("Please fill all fields before submitting.");
      }
      return;
    }

    try {
      const res = await fetch("/api/batches/create", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name, courseType, year }),
      });

      const data = await res.json();
      if (res.ok) {
        if (typeof showToast === 'function') {
          showToast("Batch created successfully!", "success");
        } else {
          alert("Batch created successfully!");
        }
        modal.classList.add("hidden");
        setTimeout(() => location.reload(), 1000);
      } else {
        if (typeof showToast === 'function') {
          showToast(data.message || "Failed to create batch", "error");
        } else {
          alert(data.message || "Failed to create batch");
        }
      }
    } catch (err) {
      if (typeof showToast === 'function') {
        showToast("Error creating batch", "error");
      } else {
        alert("Error creating batch");
      }
    }
  });
</script>

<!-- Share Modal -->
<div id="shareModal" class="hidden fixed inset-0 bg-slate-950/40 flex items-center justify-center z-50 p-4 transition-all duration-300">
  <div class="bg-white rounded-3xl shadow-xl w-full max-w-sm p-6 relative border border-slate-100">
    <button onclick="closeShareModal()" class="absolute top-4 right-4 text-slate-400 hover:text-slate-650 transition">
      <i class="fas fa-times text-lg"></i>
    </button>

    <div class="text-center mb-6">
      <span class="inline-flex p-3 bg-indigo-50 text-indigo-600 rounded-2xl mb-2">
        <i class="fas fa-share-alt text-xl"></i>
      </span>
      <h2 class="text-xl font-extrabold text-slate-850">Share Admission Form</h2>
      <p class="text-slate-500 text-xs mt-1">Copy link or share via email/WhatsApp with students</p>
    </div>

    <!-- Link Display Box -->
    <div class="bg-slate-50 border border-slate-150 rounded-2xl p-3 mb-4 flex items-center justify-between gap-2">
      <p id="shareLink" class="text-xs text-indigo-650 font-semibold truncate select-all flex-1"></p>
      <button onclick="copyShareLink()" class="bg-indigo-600 hover:bg-indigo-700 text-white text-[11px] font-bold px-3 py-1.5 rounded-xl transition flex-shrink-0">
        Copy
      </button>
    </div>

    <div class="space-y-2">
      <!-- WhatsApp -->
      <a id="whatsappShare" target="_blank"
         class="flex items-center justify-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white font-bold text-xs py-3 rounded-xl transition w-full">
        <i class="fab fa-whatsapp text-[14px]"></i> Share on WhatsApp
      </a>

      <!-- Email -->
      <a id="emailShare" target="_blank"
         class="flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs py-3 rounded-xl transition w-full">
        <i class="far fa-envelope text-[14px]"></i> Share via Email
      </a>

      <!-- Close -->
      <button onclick="closeShareModal()"
              class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold text-xs py-3 rounded-xl w-full transition">
        Close
      </button>
    </div>
  </div>
</div>

<script>
  let currentShareLink = "";
  function openShareModal(formId) {
    currentShareLink = `${window.location.origin}/forms/fill/${formId}`;
    document.getElementById('shareLink').textContent = currentShareLink;
    document.getElementById('whatsappShare').href = 
      `https://wa.me/?text=${encodeURIComponent(currentShareLink)}`;
    document.getElementById('emailShare').href =
      `mailto:?subject=Admission Form&body=${encodeURIComponent(currentShareLink)}`;
    document.getElementById('shareModal').classList.remove('hidden');
  }
  function closeShareModal() {
    document.getElementById('shareModal').classList.add('hidden');
  }
  function copyShareLink() {
    navigator.clipboard.writeText(currentShareLink)
      .then(() => {
        if (typeof showToast === 'function') {
          showToast("Form link copied to clipboard!", "success");
        } else {
          alert("Form link copied!");
        }
      })
      .catch(() => alert("Unable to copy link"));
  }

  // Close share modal on clicking outside
  window.addEventListener("click", (e) => {
    const shareModal = document.getElementById("shareModal");
    const downloadModal = document.getElementById("downloadFieldsModal");
    if (e.target === shareModal) {
      closeShareModal();
    }
    if (e.target === downloadModal) {
      closeDownloadFieldsModal();
    }
  });

  function openDownloadFieldsModal(batchId, batchName) {
    document.getElementById("downloadBatchName").innerText = batchName;
    document.getElementById("downloadFieldsForm").action = `/api/batches/data/download-custom/${batchId}`;
    
    const modal = document.getElementById("downloadFieldsModal");
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    document.body.style.overflow = "hidden";
  }

  function closeDownloadFieldsModal() {
    const modal = document.getElementById("downloadFieldsModal");
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    document.body.style.overflow = "";
  }

  function selectAllFields(val) {
    const checkboxes = document.querySelectorAll("#downloadFieldsForm input[type='checkbox']");
    checkboxes.forEach(cb => cb.checked = val);
  }
</script>

<!-- 📥 Download Fields Selector Modal -->
<div id="downloadFieldsModal" class="hidden fixed inset-0 bg-slate-950/40 flex items-center justify-center z-50 p-4 transition-all duration-300">
  <div class="bg-white rounded-3xl shadow-xl w-full max-w-md p-6 relative border border-slate-100 transform transition-all duration-300">
    <button onclick="closeDownloadFieldsModal()" class="absolute top-4 right-4 text-slate-400 hover:text-slate-650 transition">
      <i class="fas fa-times text-lg"></i>
    </button>

    <div class="mb-5">
      <h2 class="text-xl font-bold text-slate-800">Download Student Data</h2>
      <p class="text-slate-500 text-xs mt-1">Select the student fields you want to include in the Excel file for <strong id="downloadBatchName" class="text-slate-700"></strong>.</p>
    </div>

    <form id="downloadFieldsForm" action="" method="POST" class="space-y-4">
      <div class="space-y-2.5 max-h-[50vh] overflow-y-auto pr-1">
        <!-- Field Checkboxes -->
        <label class="flex items-center gap-3 p-3 bg-slate-50 hover:bg-slate-100 rounded-xl cursor-pointer border border-slate-100 transition">
          <input type="checkbox" name="fields" value="name" checked class="w-4 h-4 text-indigo-600 border-slate-300 rounded focus:ring-indigo-500" />
          <div class="text-xs font-semibold text-slate-700">Full Name</div>
        </label>
        <label class="flex items-center gap-3 p-3 bg-slate-50 hover:bg-slate-100 rounded-xl cursor-pointer border border-slate-100 transition">
          <input type="checkbox" name="fields" value="rollNumber" checked class="w-4 h-4 text-indigo-600 border-slate-300 rounded focus:ring-indigo-500" />
          <div class="text-xs font-semibold text-slate-700">Roll Number</div>
        </label>
        <label class="flex items-center gap-3 p-3 bg-slate-50 hover:bg-slate-100 rounded-xl cursor-pointer border border-slate-100 transition">
          <input type="checkbox" name="fields" value="username" checked class="w-4 h-4 text-indigo-600 border-slate-300 rounded focus:ring-indigo-500" />
          <div class="text-xs font-semibold text-slate-700">Username</div>
        </label>
        <label class="flex items-center gap-3 p-3 bg-slate-50 hover:bg-slate-100 rounded-xl cursor-pointer border border-slate-100 transition">
          <input type="checkbox" name="fields" value="email" checked class="w-4 h-4 text-indigo-600 border-slate-300 rounded focus:ring-indigo-500" />
          <div class="text-xs font-semibold text-slate-700">Email Address</div>
        </label>
        <label class="flex items-center gap-3 p-3 bg-slate-50 hover:bg-slate-100 rounded-xl cursor-pointer border border-slate-100 transition">
          <input type="checkbox" name="fields" value="number" checked class="w-4 h-4 text-indigo-600 border-slate-300 rounded focus:ring-indigo-500" />
          <div class="text-xs font-semibold text-slate-700">Mobile Number</div>
        </label>
        <label class="flex items-center gap-3 p-3 bg-slate-50 hover:bg-slate-100 rounded-xl cursor-pointer border border-slate-100 transition">
          <input type="checkbox" name="fields" value="fatherName" class="w-4 h-4 text-indigo-600 border-slate-300 rounded focus:ring-indigo-500" />
          <div class="text-xs font-semibold text-slate-700">Father's Name</div>
        </label>
        <label class="flex items-center gap-3 p-3 bg-slate-50 hover:bg-slate-100 rounded-xl cursor-pointer border border-slate-100 transition">
          <input type="checkbox" name="fields" value="motherName" class="w-4 h-4 text-indigo-600 border-slate-300 rounded focus:ring-indigo-500" />
          <div class="text-xs font-semibold text-slate-700">Mother's Name</div>
        </label>
        <label class="flex items-center gap-3 p-3 bg-slate-50 hover:bg-slate-100 rounded-xl cursor-pointer border border-slate-100 transition">
          <input type="checkbox" name="fields" value="address" class="w-4 h-4 text-indigo-600 border-slate-300 rounded focus:ring-indigo-500" />
          <div class="text-xs font-semibold text-slate-700">Address</div>
        </label>
        <label class="flex items-center gap-3 p-3 bg-slate-50 hover:bg-slate-100 rounded-xl cursor-pointer border border-slate-100 transition">
          <input type="checkbox" name="fields" value="role" class="w-4 h-4 text-indigo-600 border-slate-300 rounded focus:ring-indigo-500" />
          <div class="text-xs font-semibold text-slate-700">Role</div>
        </label>
        <label class="flex items-center gap-3 p-3 bg-slate-50 hover:bg-slate-100 rounded-xl cursor-pointer border border-slate-100 transition">
          <input type="checkbox" name="fields" value="isActive" class="w-4 h-4 text-indigo-600 border-slate-300 rounded focus:ring-indigo-500" />
          <div class="text-xs font-semibold text-slate-700">Is Active Status</div>
        </label>
      </div>

      <!-- Select All / Deselect All Actions -->
      <div class="flex justify-between items-center text-xs py-1">
        <button type="button" onclick="selectAllFields(true)" class="text-indigo-600 font-bold hover:underline">Select All</button>
        <button type="button" onclick="selectAllFields(false)" class="text-slate-500 font-bold hover:underline">Clear All</button>
      </div>

      <div class="grid grid-cols-2 gap-3 pt-2">
        <button type="button" onclick="closeDownloadFieldsModal()" 
                class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold text-xs py-3.5 rounded-xl transition">
          Cancel
        </button>
        <button type="submit" onclick="setTimeout(() => closeDownloadFieldsModal(), 500)"
                class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-xs py-3.5 rounded-xl transition shadow-md shadow-indigo-100">
          Export to Excel (.xlsx)
        </button>
      </div>
    </form>
  </div>
</div>
