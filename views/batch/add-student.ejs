<div class="w-full px-6 py-8 space-y-6">

  <!-- Flash messages -->
  <%- include('../flash.ejs') %>

  <!-- Top Dashboard Banner -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8 bg-white border border-slate-100 p-6 rounded-3xl shadow-sm">
    <div>
      <div class="flex items-center gap-2 text-sm text-slate-500 font-medium mb-1">
        <a href="/api/batches" class="hover:text-indigo-650 transition">Batches</a>
        <span>&bull;</span>
        <a href="/api/batches/<%= batchId %>" class="hover:text-indigo-650 transition">Batch Dashboard</a>
        <span>&bull;</span>
        <span class="text-slate-805 font-bold">New Student Enrollment</span>
      </div>
      <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight flex items-center gap-3">
        <span>👤 Enroll New Student</span>
      </h1>
      <p class="text-slate-500 text-sm mt-1">Configure student personal info, contact info, and custom course fee structure parameters</p>
    </div>

    <a href="/api/batches/<%= batchId %>" class="inline-flex items-center gap-1.5 bg-slate-100 hover:bg-slate-200 text-slate-700 px-4 py-2.5 rounded-xl font-bold text-xs transition">
      <i class="fas fa-chevron-left text-[10px]"></i> Back
    </a>
  </div>

  <div class="bg-white border border-slate-100 rounded-3xl p-6 md:p-8 shadow-sm">
    <form id="studentForm" class="space-y-6">
      
      <!-- Section: Student Information -->
      <div>
        <h3 class="text-xs font-extrabold text-indigo-650 uppercase tracking-widest flex items-center gap-1.5 pb-2 border-b border-slate-100 mb-5">
          <i class="fas fa-user"></i> Student Personal & Contact Info
        </h3>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Full Name <span class="text-red-500">*</span></label>
            <input type="text" id="name" placeholder="e.g. Rahul Sharma" required
                   class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
          </div>
          
          <div>
            <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Email Address <span class="text-red-500">*</span></label>
            <input type="email" id="email" placeholder="e.g. rahul@gmail.com" required
                   class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
          </div>

          <div>
            <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Mobile Number <span class="text-red-500">*</span></label>
            <input type="text" id="number" placeholder="e.g. 9876543210" required
                   class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
          </div>

          <div>
            <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Father's Name</label>
            <input type="text" id="fatherName" placeholder="Father's Full Name" 
                   class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
          </div>

          <div>
            <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Mother's Name</label>
            <input type="text" id="motherName" placeholder="Mother's Full Name" 
                   class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
          </div>
        </div>
      </div>

      <!-- Address -->
      <div class="space-y-2">
        <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider">Residential Address</label>
        <textarea id="address" placeholder="Write full address details..." 
                  class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl p-4 text-xs outline-none font-semibold text-slate-750 h-20 resize-none transition"></textarea>
      </div>

      <!-- Section: Course Fee configuration -->
      <div>
        <h3 class="text-xs font-extrabold text-indigo-650 uppercase tracking-widest flex items-center gap-1.5 pb-2 border-b border-slate-100 mb-5">
          <i class="fas fa-wallet"></i> Course Fee Structure Parameters
        </h3>
        
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
          <div>
            <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Admission Fee (Rs)</label>
            <input type="number" id="admissionFee" placeholder="0" min="0" 
                   class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
          </div>

          <div>
            <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Tuition Fee (Rs)</label>
            <input type="number" id="tuitionFee" placeholder="0" min="0" 
                   class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
          </div>

          <div>
            <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Transport Fee (Rs)</label>
            <input type="number" id="transportFee" placeholder="0" min="0" 
                   class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
          </div>

          <div>
            <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Other Fee (Rs)</label>
            <input type="number" id="otherFee" placeholder="0" min="0" 
                   class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="pt-6 border-t border-slate-100 flex items-center justify-end gap-3">
        <button type="submit" class="bg-indigo-650 hover:bg-indigo-700 text-white font-bold text-sm px-6 py-2.5 rounded-xl transition shadow-md">
          Enroll Student
        </button>
      </div>

    </form>
  </div>

</div>

<!-- Loading Spinner -->
<div id="loader" class="fixed inset-0 bg-slate-950/40 flex items-center justify-center z-50 hidden">
  <div class="w-16 h-16 border-4 border-white border-t-transparent rounded-full animate-spin"></div>
</div>

<script>
  document.getElementById("studentForm").addEventListener("submit", async (e) => {
    e.preventDefault();

    // SHOW spinner
    document.getElementById("loader").classList.remove("hidden");

    const name = document.getElementById("name").value.trim();
    const email = document.getElementById("email").value.trim();
    const batchId = '<%= batchId %>';
    const number = document.getElementById("number").value.trim();
    const fatherName = document.getElementById("fatherName").value.trim();
    const motherName = document.getElementById("motherName").value.trim();
    const address = document.getElementById("address").value.trim();
    const admissionFee = document.getElementById("admissionFee").value || "0";
    const tuitionFee = document.getElementById("tuitionFee").value || "0";
    const transportFee = document.getElementById("transportFee").value || "0";
    const otherFee = document.getElementById("otherFee").value || "0";

    try {
      const res = await fetch("/api/students/create", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          name, email, batchId, number,
          fatherName, motherName, address,
          admissionFee, tuitionFee, transportFee, otherFee
        }),
      });
      const data = await res.json();
      
      if (data.success) {
        showToast("Student enrolled successfully!", "success");
        setTimeout(() => {
          location.href = `/api/batches/${batchId}`;
        }, 1200);
      } else {
        showToast(data.message || "Failed to enroll student", "error");
      }
    } catch (err) {
      showToast("Something went wrong", "error");
    } finally {
      // HIDE spinner
      document.getElementById("loader").classList.add("hidden");
    }
  });
</script>

