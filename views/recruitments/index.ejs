<div class="w-full px-6 py-8 space-y-6">

  <!-- Flash messages -->
  <%- include('../flash.ejs') %>

  <!-- Top Dashboard Banner -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8 bg-white border border-slate-100 p-6 rounded-3xl shadow-sm">
    <div>
      <div class="flex items-center gap-2 text-sm text-slate-500 font-medium mb-1">
        <span class="text-slate-805 font-bold">Recruitments</span>
      </div>
      <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight flex items-center gap-3">
        <span>💼 Careers & Recruitments</span>
      </h1>
      <p class="text-slate-500 text-sm mt-1">Manage job openings, post openings, review applications, and track progress</p>
    </div>

    <div class="flex items-center gap-2">
      <a href="/admin/recruitments/new" class="inline-flex items-center gap-1.5 bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-xl font-bold text-xs shadow-sm transition">
        <i class="fas fa-plus text-[10px]"></i> Create Recruitment
      </a>
    </div>
  </div>

  <section class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm overflow-hidden">
    <div class="flex items-center justify-between gap-4 pb-4 border-b border-slate-100 flex-wrap">
      <div>
        <h2 class="text-lg font-bold text-slate-800">Job Postings</h2>
        <p class="text-xs text-slate-500 mt-0.5">Active and closed career openings posted by Garud HR</p>
      </div>
      <div class="inline-flex items-center gap-2 rounded-full bg-slate-50 border border-slate-150 px-3 py-1 text-xs font-bold text-slate-700">
        <span class="h-2 w-2 rounded-full bg-teal-650 animate-pulse"></span>
        <span><%= recruitments.length %> Total Openings</span>
      </div>
    </div>

    <div class="overflow-x-auto border border-slate-100 rounded-2xl shadow-sm mt-4">
      <table class="w-full text-left text-sm text-slate-650">
        <thead class="bg-slate-50 border-b border-slate-100 font-bold uppercase tracking-wider text-xs text-slate-700">
          <tr>
            <th class="py-4 px-6">Title</th>
            <th class="py-4 px-6">Department</th>
            <th class="py-4 px-6">Location</th>
            <th class="py-4 px-6 text-center">Applications</th>
            <th class="py-4 px-6 text-center">Status</th>
            <th class="py-4 px-6 text-center">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% if (!recruitments.length) { %>
            <tr>
              <td colspan="6" class="py-8 px-6 text-center text-slate-550 font-semibold italic">No recruitment postings created yet.</td>
            </tr>
          <% } %>

          <% recruitments.forEach((r) => { %>
            <tr class="hover:bg-slate-50/50 transition">
              <td class="py-3.5 px-6 font-bold text-slate-850">
                <%= r.title %>
              </td>
              <td class="py-3.5 px-6 font-semibold text-slate-700">
                <%= r.department %>
              </td>
              <td class="py-3.5 px-6 font-semibold text-slate-700">
                <%= r.location %>
              </td>
              <td class="py-3.5 px-6 text-center">
                <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-bold text-slate-700 border border-slate-200"><%= r.applicationCount %></span>
              </td>
              <td class="py-3.5 px-6 text-center">
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-[10px] font-bold border <%= r.status === 'Open' ? 'bg-emerald-50 text-emerald-700 border-emerald-150' : 'bg-rose-50 text-rose-700 border-rose-150' %>">
                  <%= r.status %>
                </span>
              </td>
              <td class="py-3.5 px-6 text-center">
                <div class="flex items-center justify-center gap-2">
                  <a href="/admin/recruitments/<%= r._id %>" class="inline-flex items-center bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold text-xs px-3 py-1.5 rounded-xl transition">
                    View
                  </a>
                  <a href="/admin/recruitments/<%= r._id %>/edit" class="inline-flex items-center bg-amber-50 hover:bg-amber-100 text-amber-705 font-bold text-xs px-3 py-1.5 rounded-xl border border-amber-150 transition">
                    Edit
                  </a>
                  <button
                    type="button"
                    class="inline-flex items-center bg-emerald-50 hover:bg-emerald-100 text-emerald-705 font-bold text-xs px-3 py-1.5 rounded-xl border border-emerald-150 transition share-recruitment-btn"
                    data-share-url="/recruitments/<%= r._id %>"
                    data-share-title="<%= r.title %>"
                  >
                    Share
                  </button>
                  <form action="/admin/recruitments/<%= r._id %>/delete" method="POST" onsubmit="return confirm('Delete this recruitment posting and all candidate applications permanently?');" class="inline-block">
                    <button class="inline-flex items-center bg-rose-50 hover:bg-rose-100 text-rose-700 font-bold text-xs px-3 py-1.5 rounded-xl border border-rose-150 transition" type="submit">
                      Delete
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <p id="shareRecruitmentMsg" class="text-xs font-bold text-emerald-700 bg-emerald-50 border border-emerald-150 p-3 rounded-xl hidden"></p>

</div>

<script>
  (function() {
    const shareButtons = document.querySelectorAll(".share-recruitment-btn");
    const shareMsg = document.getElementById("shareRecruitmentMsg");

    const setShareMessage = (text, isError = false) => {
      if (!shareMsg) return;
      shareMsg.textContent = text;
      shareMsg.classList.remove("hidden", "text-emerald-700", "text-rose-700", "bg-emerald-50", "bg-rose-50", "border-emerald-150", "border-rose-150");
      if (isError) {
        shareMsg.classList.add("text-rose-705", "bg-rose-50", "border-rose-150");
      } else {
        shareMsg.classList.add("text-emerald-705", "bg-emerald-50", "border-emerald-150");
      }
      shareMsg.classList.remove("hidden");
    };

    shareButtons.forEach((button) => {
      button.addEventListener("click", async () => {
        const sharePath = button.dataset.shareUrl;
        const shareTitle = button.dataset.shareTitle || "Recruitment";
        const shareUrl = `${window.location.origin}${sharePath}`;

        try {
          if (navigator.share) {
            await navigator.share({
              title: `${shareTitle} - Garud Careers`,
              text: "Check this recruitment opening at Garud Classes",
              url: shareUrl,
            });
            setShareMessage("Recruitment link shared successfully.");
            return;
          }

          await navigator.clipboard.writeText(shareUrl);
          setShareMessage("Recruitment link copied to clipboard. You can paste and share it.");
        } catch (error) {
          setShareMessage("Could not share automatically. Please copy the public recruitment URL manually.", true);
        }
      });
    });
  })();
</script>
