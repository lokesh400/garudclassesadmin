<div class="w-full px-6 py-8 space-y-6">

  <!-- Flash messages -->
  <%- include('../flash.ejs') %>

  <!-- Top Dashboard Banner -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8 bg-white border border-slate-100 p-6 rounded-3xl shadow-sm">
    <div>
      <div class="flex items-center gap-2 text-sm text-slate-500 font-medium mb-1">
        <a href="/admin/recruitments" class="hover:text-indigo-650 transition">Recruitments</a>
        <span>&bull;</span>
        <span class="text-slate-805 font-bold">New Post</span>
      </div>
      <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight flex items-center gap-3">
        <span>💼 Create Recruitment Posting</span>
      </h1>
      <p class="text-slate-500 text-sm mt-1">Publish a new job opening with complete details for candidates.</p>
    </div>

    <a href="/admin/recruitments" class="inline-flex items-center gap-1.5 bg-slate-100 hover:bg-slate-200 text-slate-700 px-4 py-2.5 rounded-xl font-bold text-xs transition">
      <i class="fas fa-chevron-left text-[10px]"></i> Back
    </a>
  </div>

  <form action="/admin/recruitments/add" method="POST" enctype="multipart/form-data" class="bg-white border border-slate-100 rounded-3xl p-6 md:p-8 shadow-sm space-y-6">
    <div class="grid md:grid-cols-2 gap-6">
      <div>
        <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Job Title <span class="text-red-500">*</span></label>
        <input name="title" placeholder="e.g. Mathematics Faculty" 
               class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" required />
      </div>
      <div>
        <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Department</label>
        <input name="department" placeholder="e.g. Academics" 
               class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
      </div>

      <div>
        <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Experience Required</label>
        <input name="experience" placeholder="e.g. 2-4 years" 
               class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
      </div>
      <div>
        <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Salary Range</label>
        <input name="salaryRange" placeholder="e.g. 4LPA - 6LPA" 
               class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
      </div>

      <div>
        <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Location <span class="text-red-500">*</span></label>
        <input name="location" placeholder="e.g. Jaipur" 
               class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" required />
      </div>

      <div>
        <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Employment Type</label>
        <select name="employmentType" class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none bg-white font-semibold text-slate-700 transition">
          <option value="Full-time">Full-time</option>
          <option value="Part-time">Part-time</option>
          <option value="Contract">Contract</option>
          <option value="Internship">Internship</option>
        </select>
      </div>

      <div>
        <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Openings</label>
        <input type="number" min="1" name="openings" value="1" placeholder="Openings" 
               class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
      </div>
      <div>
        <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Last Date To Apply</label>
        <input type="date" name="lastDateToApply" 
               class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none font-semibold text-slate-700 transition" />
      </div>
    </div>

    <div>
      <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Job Description <span class="text-red-500">*</span></label>
      <textarea name="description" placeholder="Write role responsibilities, requirements, and expectations" 
                class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl p-4 text-xs outline-none font-semibold text-slate-700 h-36 resize-none transition" required></textarea>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <div>
        <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Job Description PDF</label>
        <div class="mt-1 flex items-center justify-center border border-slate-200 border-dashed rounded-2xl p-6 bg-slate-50/50">
          <div class="space-y-1 text-center">
            <i class="fas fa-file-pdf text-slate-400 text-2xl mb-2"></i>
            <div class="flex text-xs text-slate-600">
              <label for="jd-upload" class="relative cursor-pointer bg-white rounded-md font-semibold text-indigo-600 hover:text-indigo-500">
                <span>Upload a JD file</span>
                <input id="jd-upload" name="jd" type="file" accept=".pdf" class="sr-only">
              </label>
            </div>
            <p class="text-[10px] text-slate-500 font-medium">PDF up to 10MB</p>
          </div>
        </div>
        <p id="jd-file-selected" class="text-[10px] font-bold text-indigo-600 mt-2 hidden"></p>
      </div>

      <div>
        <label class="block mb-1 text-xs font-bold text-slate-500 uppercase tracking-wider">Status</label>
        <select name="status" class="w-full border border-slate-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 rounded-2xl px-4 py-2.5 text-xs outline-none bg-white font-semibold text-slate-700 transition">
          <option value="Open">Open</option>
          <option value="Closed">Closed</option>
        </select>
      </div>
    </div>

    <div class="pt-4 border-t border-slate-100 flex justify-end">
      <button class="bg-indigo-650 hover:bg-indigo-700 text-white font-bold text-sm px-6 py-2.5 rounded-xl transition shadow-md" type="submit">
        Save Job Posting
      </button>
    </div>
  </form>
</div>

<script>
  (function() {
    const fileInput = document.getElementById('jd-upload');
    const selectedLabel = document.getElementById('jd-file-selected');
    if (fileInput && selectedLabel) {
      fileInput.addEventListener('change', (e) => {
        if (e.target.files && e.target.files[0]) {
          selectedLabel.textContent = "📄 Selected File: " + e.target.files[0].name;
          selectedLabel.classList.remove('hidden');
        } else {
          selectedLabel.classList.add('hidden');
        }
      });
    }
  })();
</script>
