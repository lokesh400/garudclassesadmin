<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Apply – <%= recruitment.title %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Tailwind CDN -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Custom Animations -->
  <style>
    @keyframes floatIn {
      from {
        opacity: 0;
        transform: translateY(30px) scale(0.97);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    .animate-float {
      animation: floatIn 0.6s ease-out forwards;
    }
  </style>
</head>

<body class="min-h-screen bg-gradient-to-br from-blue-600 via-indigo-600 to-purple-700 flex items-center justify-center p-4">

  <!-- Background blur circles -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-20 -left-20 w-96 h-96 bg-white/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-white/10 rounded-full blur-3xl"></div>
  </div>

  <!-- Card -->
  <div class="relative w-full max-w-2xl bg-white/90 backdrop-blur-xl rounded-2xl shadow-2xl p-8 animate-float">

    <!-- Header -->
    <div class="mb-6 text-center">
      <h1 class="text-3xl font-bold text-gray-800">
        Apply for
      </h1>
      <p class="text-xl font-semibold text-indigo-600 mt-1">
        <%= recruitment.title %>
      </p>
      <p class="text-sm text-gray-500 mt-2">
        Fill in your details carefully. We’ll get back to you soon.
      </p>
    </div>

    <!-- Form -->
    <form
      action="/admin/recruitments/<%= recruitment._id %>/apply"
      method="POST"
      enctype="multipart/form-data"
      class="space-y-5"
    >

      <!-- Name -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Full Name
        </label>
        <input
          name="name"
          required
          class="w-full rounded-lg border border-gray-300 px-4 py-2 focus:ring-2 focus:ring-indigo-500 focus:outline-none transition"
          placeholder="John Doe"
        />
      </div>

      <!-- Email -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Email Address
        </label>
        <input
          name="email"
          type="email"
          required
          class="w-full rounded-lg border border-gray-300 px-4 py-2 focus:ring-2 focus:ring-indigo-500 focus:outline-none transition"
          placeholder="john@example.com"
        />
      </div>

      <!-- Phone -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Phone Number
        </label>
        <input
          name="phone"
          required
          class="w-full rounded-lg border border-gray-300 px-4 py-2 focus:ring-2 focus:ring-indigo-500 focus:outline-none transition"
          placeholder="+91 XXXXX XXXXX"
        />
      </div>

      <!-- Experience -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Experience
        </label>
        <input
          name="experience"
          class="w-full rounded-lg border border-gray-300 px-4 py-2 focus:ring-2 focus:ring-indigo-500 focus:outline-none transition"
          placeholder="e.g. 2 years"
        />
      </div>

      <!-- Resume Upload -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Resume (PDF only)
        </label>
        <input
          type="file"
          name="resume"
          accept=".pdf"
          required
          class="block w-full text-sm text-gray-600
                 file:mr-4 file:py-2 file:px-4
                 file:rounded-lg file:border-0
                 file:text-sm file:font-semibold
                 file:bg-indigo-50 file:text-indigo-600
                 hover:file:bg-indigo-100 transition"
        />
      </div>

      <!-- Cover Letter -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Cover Letter
        </label>
        <textarea
          name="coverLetter"
          rows="4"
          class="w-full rounded-lg border border-gray-300 px-4 py-2 focus:ring-2 focus:ring-indigo-500 focus:outline-none transition"
          placeholder="Tell us why you are a good fit for this role..."
        ></textarea>
      </div>

      <!-- Submit Button -->
      <div class="pt-4">
        <button
          type="submit"
          class="w-full bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-semibold py-3 rounded-lg shadow-lg hover:scale-[1.02] hover:shadow-xl active:scale-95 transition transform"
        >
          Submit Application 🚀
        </button>
      </div>

    </form>

    <!-- Footer -->
    <p class="text-xs text-center text-gray-500 mt-6">
      By submitting, you agree that your data will be used for recruitment purposes only.
    </p>

  </div>

</body>
</html>
