<div class="bg-white p-6 rounded shadow max-w-3xl mx-auto">
  <h1 class="text-2xl font-bold mb-2"><%= recruitment.title %></h1>

  <p class="text-gray-600 mb-4">
    <strong>Department:</strong> <%= recruitment.department %> |
    <strong>Location:</strong> <%= recruitment.location %>
  </p>

  <div class="mb-4">
    <span class="px-3 py-1 rounded text-sm 
      <%= recruitment.status === "Open" ? "bg-green-200" : "bg-red-200" %>">
      <%= recruitment.status %>
    </span>
  </div>

  <h2 class="text-lg font-semibold mt-4">Job Description</h2>
  <p class="text-gray-700 whitespace-pre-line mt-2">
    <%= recruitment.description %>
  </p>

  <div class="mt-4">
    <p><strong>Experience:</strong> <%= recruitment.experience %></p>
    <p><strong>Salary:</strong> <%= recruitment.salaryRange %></p>
  </div>

  <% if (recruitment.jdFile) { %>
    <div class="mt-6">
      <a href="/<%= recruitment.jdFile %>" target="_blank"
         class="text-blue-600 underline">
        Download Job Description (PDF)
      </a>
    </div>
  <% } %>

  <% if (recruitment.status === "Open") { %>
    <div class="mt-6">
      <a href="/admin/recruitments/<%= recruitment._id %>/apply"
         class="bg-blue-600 text-white px-6 py-2 rounded">
        Apply Now
      </a>
    </div>
  <% } else { %>
    <p class="mt-6 text-red-500 font-medium">
      Recruitment Closed
    </p>
  <% } %>
</div>
