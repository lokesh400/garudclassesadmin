<div class="w-full px-6 py-8 space-y-6">
  <%- include('../flash.ejs') %>

  <!-- Header -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 bg-white border border-slate-100 p-6 rounded-3xl shadow-sm">
    <div>
      <div class="flex items-center gap-2 text-xs text-slate-500 font-medium mb-1">
        <a href="/admin" class="hover:text-indigo-600 transition">Dashboard</a>
        <span>&bull;</span>
        <span class="text-slate-800 font-bold">Onboarding Pipeline</span>
      </div>
      <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight flex items-center gap-3">
        <span>🧑‍💼 Onboarding Pipeline</span>
      </h1>
      <p class="text-slate-500 text-sm mt-1">Manage candidates in the onboarding process before promoting them to Staff.</p>
    </div>
    <a href="/admin/onboarding/new"
       class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-xl font-bold text-xs transition shadow-md shadow-indigo-600/10 whitespace-nowrap">
      <i class="fas fa-plus text-[10px]"></i> Register New Candidate
    </a>
  </div>

  <!-- Stats Row -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <% const stats = [
      { label: 'Total Candidates', value: candidates.length, icon: 'fa-users', color: 'indigo' },
      { label: 'Offer Sent', value: candidates.filter(c => c.offerStatus === 'Sent').length, icon: 'fa-paper-plane', color: 'amber' },
      { label: 'Offer Accepted', value: candidates.filter(c => c.offerStatus === 'Accepted').length, icon: 'fa-signature', color: 'emerald' },
      { label: 'Offer Rejected', value: candidates.filter(c => c.offerStatus === 'Rejected').length, icon: 'fa-times-circle', color: 'rose' },
    ]; %>
    <% stats.forEach(s => { %>
      <div class="bg-white border border-slate-100 rounded-2xl p-4 shadow-sm flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-<%= s.color %>-50 border border-<%= s.color %>-100 flex items-center justify-center">
          <i class="fas <%= s.icon %> text-<%= s.color %>-600 text-sm"></i>
        </div>
        <div>
          <p class="text-xl font-extrabold text-slate-900"><%= s.value %></p>
          <p class="text-[10px] text-slate-500 font-semibold uppercase tracking-wider"><%= s.label %></p>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Candidate Table -->
  <div class="bg-white border border-slate-100 rounded-3xl shadow-sm overflow-hidden">
    <% if (candidates.length === 0) { %>
      <div class="py-16 text-center">
        <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-4 border border-slate-100">
          <i class="fas fa-user-clock text-slate-300 text-2xl"></i>
        </div>
        <p class="text-slate-500 font-semibold text-sm">No candidates in the pipeline.</p>
        <a href="/admin/onboarding/new"
           class="mt-4 inline-flex items-center gap-1.5 bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2.5 rounded-xl font-bold text-xs transition shadow-sm">
          <i class="fas fa-plus text-[10px]"></i> Register First Candidate
        </a>
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
          <thead class="bg-slate-50 border-b border-slate-100 text-xs font-extrabold text-slate-500 uppercase tracking-wider">
            <tr>
              <th class="py-3.5 px-5">Name</th>
              <th class="py-3.5 px-5">Email</th>
              <th class="py-3.5 px-5">Department</th>
              <th class="py-3.5 px-5">Designation</th>
              <th class="py-3.5 px-5 text-center">Offer Status</th>
              <th class="py-3.5 px-5 text-center">Onboarding</th>
              <th class="py-3.5 px-5 text-center">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-50">
            <% candidates.forEach(c => { %>
              <tr class="hover:bg-slate-50/50 transition">
                <td class="py-3.5 px-5">
                  <div class="flex items-center gap-2.5">
                    <div class="w-8 h-8 rounded-xl bg-indigo-100 flex items-center justify-center text-indigo-700 font-extrabold text-xs shrink-0">
                      <%= (c.name || '?')[0].toUpperCase() %>
                    </div>
                    <span class="font-bold text-slate-800 text-xs"><%= c.name %></span>
                  </div>
                </td>
                <td class="py-3.5 px-5 text-xs text-slate-600 font-semibold"><%= c.email %></td>
                <td class="py-3.5 px-5 text-xs text-slate-600 font-semibold"><%= c.department || '-' %></td>
                <td class="py-3.5 px-5 text-xs text-slate-600 font-semibold"><%= c.designation || '-' %></td>
                <td class="py-3.5 px-5 text-center">
                  <% const offerColors = { None: 'slate', Sent: 'amber', Accepted: 'emerald', Rejected: 'rose' }; %>
                  <span class="inline-block px-2.5 py-1 rounded-xl text-[10px] font-extrabold bg-<%= offerColors[c.offerStatus] || 'slate' %>-100 text-<%= offerColors[c.offerStatus] || 'slate' %>-700 border border-<%= offerColors[c.offerStatus] || 'slate' %>-200">
                    <%= c.offerStatus %>
                  </span>
                </td>
                <td class="py-3.5 px-5 text-center">
                  <% const statusColors = { 'Pending': 'slate', 'Offer Sent': 'amber', 'Offer Accepted': 'emerald', 'Complete': 'indigo' }; %>
                  <span class="inline-block px-2.5 py-1 rounded-xl text-[10px] font-extrabold bg-<%= statusColors[c.onboardingStatus] || 'slate' %>-100 text-<%= statusColors[c.onboardingStatus] || 'slate' %>-700 border border-<%= statusColors[c.onboardingStatus] || 'slate' %>-200">
                    <%= c.onboardingStatus %>
                  </span>
                </td>
                <td class="py-3.5 px-5 text-center">
                  <a href="/admin/onboarding/<%= c._id %>"
                     class="inline-flex items-center gap-1 text-indigo-600 hover:text-indigo-800 font-bold text-xs transition">
                    <i class="fas fa-eye text-[10px]"></i> View
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>
