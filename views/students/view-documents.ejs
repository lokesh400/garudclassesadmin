<div class="w-full px-6 py-8">
  <!-- Flash messages -->
  <%- include('../flash.ejs') %>

  <!-- Back Button & Header Banner -->
  <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-8 pb-6 border-b border-slate-100">
    <div class="mb-4 md:mb-0">
      <a href="/api/students/all" class="inline-flex items-center gap-1.5 text-indigo-650 hover:text-indigo-700 transition font-bold text-sm mb-3">
        <i class="fas fa-arrow-left text-xs"></i> Back to Student List
      </a>
      <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight"><%= student.name %>'s Documents</h1>
      <p class="text-slate-500 mt-1.5 font-semibold text-xs uppercase tracking-wider">
        Roll No: <span class="font-mono text-slate-700"><%= student.rollNumber || '-' %></span> | Username: <span class="text-slate-750"><%= student.username %></span>
      </p>
    </div>
    
    <div class="bg-white px-4 py-3 rounded-2xl border border-slate-100 text-sm shadow-sm flex items-center gap-2">
      <span class="font-bold text-slate-655">Batch Enrollment:</span>
      <span class="px-2.5 py-0.5 bg-indigo-50 text-indigo-700 font-bold rounded-full text-xs">
        <%= student.batch ? student.batch.name : 'Unassigned' %>
      </span>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Left Column: Student Quick Info & Profile Photo Controls -->
    <div class="lg:col-span-1 space-y-6">
      <!-- Profile Card -->
      <div class="bg-white rounded-3xl shadow-sm border border-slate-100 p-6 flex flex-col items-center text-center">
        <div class="w-32 h-32 rounded-full overflow-hidden border-4 border-indigo-50 bg-slate-50 mb-4 shadow-sm relative group">
          <% if (student.image) { %>
            <img src="<%= student.image %>" alt="Profile Photo" class="w-full h-full object-cover">
          <% } else { %>
            <div class="w-full h-full flex items-center justify-center text-slate-300">
              <i class="fas fa-user-circle text-6xl"></i>
            </div>
          <% } %>
        </div>
        
        <h2 class="text-xl font-extrabold text-slate-855"><%= student.name %></h2>
        <p class="text-xs text-slate-500 font-bold mt-0.5"><%= student.email || 'No email specified' %></p>
        <p class="text-xs text-slate-600 font-mono font-bold mt-1"><%= student.number || '-' %></p>
        
        <div class="w-full border-t border-slate-100 my-5"></div>
        
        <div class="w-full text-left space-y-3 text-sm mb-5">
          <div>
            <span class="block text-[10px] uppercase font-bold text-slate-500 tracking-wider">Father's Name</span>
            <span class="font-semibold text-slate-700 mt-0.5 block"><%= student.fatherName || '-' %></span>
          </div>
          <div>
            <span class="block text-[10px] uppercase font-bold text-slate-500 tracking-wider">Mother's Name</span>
            <span class="font-semibold text-slate-700 mt-0.5 block"><%= student.motherName || '-' %></span>
          </div>
          <div>
            <span class="block text-[10px] uppercase font-bold text-slate-500 tracking-wider">Home Address</span>
            <span class="font-semibold text-slate-700 mt-0.5 block text-xs leading-relaxed"><%= student.address || '-' %></span>
          </div>
        </div>

        <!-- Inline Toggle for Profile Photo Re-upload -->
        <div class="w-full pt-4 border-t border-slate-100 flex items-center justify-between text-left">
          <div>
            <span class="text-[9px] font-bold text-slate-500 uppercase tracking-wider block">Photo Status</span>
            <span class="text-xs font-bold text-slate-700 mt-0.5 block" id="status-studentPhoto">
              <%= student.allowStudentPhotoReupload ? 'Unlocked' : 'Locked' %>
            </span>
          </div>
          <button 
            onclick="togglePermission('studentPhoto')"
            id="btn-studentPhoto"
            class="px-4 py-2 rounded-xl text-xs font-bold transition shadow-sm focus:outline-none <%= student.allowStudentPhotoReupload ? 'bg-rose-50 text-rose-700 hover:bg-rose-100/80' : 'bg-emerald-50 text-emerald-700 hover:bg-emerald-100/80' %>"
          >
            <%= student.allowStudentPhotoReupload ? 'Lock Upload' : 'Allow Upload' %>
          </button>
        </div>
      </div>
    </div>

    <!-- Right Column: Document Grid -->
    <div class="lg:col-span-2 space-y-6">
      <div class="bg-white rounded-3xl shadow-sm border border-slate-100 p-6">
        <h3 class="text-xl font-bold text-slate-850 mb-6 flex items-center gap-2">
          <i class="fas fa-file-signature text-slate-400 text-lg"></i> Uploaded Documents & Credentials
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <% 
            const docList = [
              { key: "class10Marksheet", label: "Class 10 Marksheet", data: student.class10Marksheet, allowed: student.allowClass10MarksheetReupload },
              { key: "class12Marksheet", label: "Class 12 Marksheet", data: student.class12Marksheet, allowed: student.allowClass12MarksheetReupload },
              { key: "aadharCard", label: "Aadhaar Card", data: student.aadharCard, allowed: student.allowAadharCardReupload },
              { key: "fatherAadharCard", label: "Father Aadhaar Card", data: student.fatherAadharCard, allowed: student.allowFatherAadharCardReupload },
              { key: "motherAadharCard", label: "Mother Aadhaar Card", data: student.motherAadharCard, allowed: student.allowMotherAadharCardReupload }
            ];
          %>

          <% docList.forEach(doc => { %>
            <div class="bg-slate-50/50 rounded-2xl border border-slate-150 p-4 flex flex-col justify-between hover:shadow-sm hover:border-slate-200 transition duration-200">
              <div>
                <div class="flex justify-between items-start mb-3">
                  <h4 class="font-bold text-slate-800 text-sm"><%= doc.label %></h4>
                  <% if (doc.data && doc.data.url) { %>
                    <span class="px-2.5 py-0.5 bg-emerald-50 text-emerald-700 text-[10px] font-bold uppercase tracking-wider rounded-full border border-emerald-150 flex items-center">
                      <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mr-1.5"></span>
                      Uploaded
                    </span>
                  <% } else { %>
                    <span class="px-2.5 py-0.5 bg-amber-50 text-amber-700 text-[10px] font-bold uppercase tracking-wider rounded-full border border-amber-150 flex items-center">
                      <span class="w-1.5 h-1.5 rounded-full bg-amber-500 mr-1.5"></span>
                      Pending
                    </span>
                  <% } %>
                </div>

                <!-- Preview Area -->
                <div class="w-full h-40 bg-slate-100 rounded-xl overflow-hidden flex items-center justify-center border border-slate-200 shadow-inner my-3 relative">
                  <% if (doc.data && doc.data.url) { %>
                    <% const isPdf = doc.data.url.toLowerCase().endsWith(".pdf") || doc.data.url.toLowerCase().includes(".pdf?"); %>
                    <% if (isPdf) { %>
                      <div class="flex flex-col items-center text-center p-4">
                        <i class="fas fa-file-pdf text-red-500 text-4xl"></i>
                        <span class="text-xs text-slate-500 mt-2 font-semibold">PDF Document</span>
                      </div>
                    <% } else { %>
                      <img src="<%= doc.data.url %>" alt="<%= doc.label %>" class="w-full h-full object-cover hover:scale-105 transition duration-200">
                    <% } %>
                  <% } else { %>
                    <div class="flex flex-col items-center text-center p-4 text-slate-400">
                      <i class="fas fa-folder-open text-3xl mb-1.5 text-slate-300"></i>
                      <span class="text-xs font-semibold">No document uploaded</span>
                    </div>
                  <% } %>
                </div>
              </div>

              <!-- Button actions & Inline Toggle -->
              <div class="mt-4 space-y-3">
                <% if (doc.data && doc.data.url) { %>
                  <a 
                    href="<%= doc.data.url %>" 
                    target="_blank" 
                    class="w-full inline-flex items-center justify-center gap-1.5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-bold rounded-xl shadow-sm transition"
                  >
                    <i class="fas fa-external-link-alt text-[10px]"></i> View Document
                  </a>
                <% } else { %>
                  <button 
                    disabled 
                    class="w-full inline-flex items-center justify-center py-2.5 bg-slate-100 text-slate-400 text-xs font-bold rounded-xl cursor-not-allowed"
                  >
                    Not Available
                  </button>
                <% } %>

                <!-- Document re-upload permission lock -->
                <div class="flex items-center justify-between pt-3 border-t border-slate-150">
                  <div class="text-left">
                    <span class="text-[9px] font-bold text-slate-400 uppercase tracking-wider block">Lock Status</span>
                    <span class="text-xs font-bold text-slate-700 mt-0.5 block" id="status-<%= doc.key %>">
                      <%= doc.allowed ? 'Unlocked' : 'Locked' %>
                    </span>
                  </div>
                  <button 
                    onclick="togglePermission('<%= doc.key %>')" 
                    id="btn-<%= doc.key %>"
                    class="px-3 py-1.5 rounded-xl text-[10px] font-bold transition shadow-sm focus:outline-none <%= doc.allowed ? 'bg-rose-50 text-rose-700 hover:bg-rose-100' : 'bg-emerald-50 text-emerald-700 hover:bg-emerald-100' %>"
                  >
                    <%= doc.allowed ? 'Lock Upload' : 'Allow Upload' %>
                  </button>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  async function togglePermission(type) {
    const btn = document.getElementById(`btn-${type}`);
    const statusText = document.getElementById(`status-${type}`);
    const initialText = btn.innerText;
    
    btn.disabled = true;
    btn.innerText = "Saving...";

    try {
      const response = await fetch(`/api/students/documents/<%= student._id %>/toggle-reupload`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ type })
      });

      const res = await response.json();
      btn.disabled = false;

      if (res.success) {
        // Update button & text style dynamically
        if (res.isAllowed) {
          statusText.innerText = "Unlocked";
          btn.innerText = "Lock Upload";
          btn.className = "px-3 py-1.5 rounded-xl text-[10px] font-bold transition shadow-sm focus:outline-none bg-rose-50 text-rose-700 hover:bg-rose-100";
          if (type === "studentPhoto") {
            btn.className = "px-4 py-2 rounded-xl text-xs font-bold transition shadow-sm focus:outline-none bg-rose-50 text-rose-700 hover:bg-rose-100";
          }
        } else {
          statusText.innerText = "Locked";
          btn.innerText = "Allow Upload";
          btn.className = "px-3 py-1.5 rounded-xl text-[10px] font-bold transition shadow-sm focus:outline-none bg-emerald-50 text-emerald-700 hover:bg-emerald-100";
          if (type === "studentPhoto") {
            btn.className = "px-4 py-2 rounded-xl text-xs font-bold transition shadow-sm focus:outline-none bg-emerald-50 text-emerald-700 hover:bg-emerald-100";
          }
        }
        
        if (typeof showToast === 'function') {
          showToast(`Permission updated successfully!`, "success");
        }
      } else {
        if (typeof showToast === 'function') {
          showToast(res.message || "Failed to update permission", "error");
        } else {
          alert("Failed to toggle permission: " + res.message);
        }
        btn.innerText = initialText;
      }
    } catch (err) {
      if (typeof showToast === 'function') {
        showToast("Error updating permission", "error");
      } else {
        alert("An error occurred. Please try again.");
      }
      btn.disabled = false;
      btn.innerText = initialText;
    }
  }
</script>
