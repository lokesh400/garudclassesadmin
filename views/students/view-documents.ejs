<div class="max-w-6xl mx-auto px-4 py-8">
  <!-- Back Button & Header -->
  <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-8 pb-6 border-b border-gray-200">
    <div class="mb-4 md:mb-0">
      <a href="/api/students/all" class="inline-flex items-center text-blue-600 hover:text-blue-800 transition font-medium mb-3">
        <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Student List
      </a>
      <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight"><%= student.name %>'s Documents</h1>
      <p class="text-gray-500 mt-1 font-mono text-sm">Roll No: <%= student.rollNumber || '-' %> | Username: <%= student.username %></p>
    </div>
    
    <div class="bg-gray-100 px-4 py-2.5 rounded-lg border border-gray-200 text-sm">
      <span class="font-bold text-gray-700">Batch:</span>
      <span class="ml-1 px-2.5 py-1 bg-blue-100 text-blue-800 font-semibold rounded text-xs">
        <%= student.batch ? student.batch.name : 'No Batch' %>
      </span>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Left Column: Student Quick Info & Profile Photo Controls -->
    <div class="lg:col-span-1 space-y-6">
      <!-- Profile Card -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 flex flex-col items-center text-center">
        <div class="w-32 h-32 rounded-full overflow-hidden border-4 border-blue-50 bg-gray-100 mb-4 shadow-inner relative group">
          <% if (student.image) { %>
            <img src="<%= student.image %>" alt="Profile Photo" class="w-full h-full object-cover">
          <% } else { %>
            <div class="w-full h-full flex items-center justify-center text-gray-300">
              <svg class="w-16 h-16" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path>
              </svg>
            </div>
          <% } %>
        </div>
        
        <h2 class="text-xl font-bold text-gray-800"><%= student.name %></h2>
        <p class="text-sm text-gray-500 mt-1"><%= student.email || 'No email specified' %></p>
        <p class="text-sm text-gray-500 font-medium"><%= student.number || '-' %></p>
        
        <div class="w-full border-t border-gray-100 my-4"></div>
        
        <div class="w-full text-left space-y-2 text-sm mb-4">
          <div><span class="font-semibold text-gray-600">Father's Name:</span> <span class="text-gray-800"><%= student.fatherName || '-' %></span></div>
          <div><span class="font-semibold text-gray-600">Mother's Name:</span> <span class="text-gray-800"><%= student.motherName || '-' %></span></div>
          <div><span class="font-semibold text-gray-600">Address:</span> <span class="text-gray-800"><%= student.address || '-' %></span></div>
        </div>

        <!-- Inline Toggle for Profile Photo Re-upload -->
        <div class="w-full pt-4 border-t border-gray-100 flex items-center justify-between text-left">
          <div>
            <span class="text-xs font-bold text-gray-500 uppercase tracking-wider block">Photo Lock</span>
            <span class="text-sm font-semibold text-gray-800" id="status-studentPhoto">
              <%= student.allowStudentPhotoReupload ? 'Unlocked' : 'Locked' %>
            </span>
          </div>
          <button 
            onclick="togglePermission('studentPhoto')"
            id="btn-studentPhoto"
            class="px-4 py-1.5 rounded-lg text-xs font-bold transition shadow-sm focus:outline-none focus:ring-2 focus:ring-offset-2 <%= student.allowStudentPhotoReupload ? 'bg-red-100 text-red-700 hover:bg-red-200 focus:ring-red-400' : 'bg-green-100 text-green-700 hover:bg-green-200 focus:ring-green-400' %>"
          >
            <%= student.allowStudentPhotoReupload ? 'Lock Upload' : 'Allow Upload' %>
          </button>
        </div>
      </div>
    </div>

    <!-- Right Column: Document Grid -->
    <div class="lg:col-span-2 space-y-6">
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <h3 class="text-xl font-bold text-gray-800 mb-6">Uploaded Documents & Credentials</h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <% 
            const docList = [
              { key: "class10Marksheet", label: "Class 10 Marksheet", data: student.class10Marksheet, allowed: student.allowClass10MarksheetReupload },
              { key: "class12Marksheet", label: "Class 12 Marksheet", data: student.class12Marksheet, allowed: student.allowClass12MarksheetReupload },
              { key: "aadharCard", label: "Aadhaar Card", data: student.aadharCard, allowed: student.allowAadharCardReupload },
              { key: "fatherAadharCard", label: "Father Aadhaar Card", data: student.fatherAadharCard, allowed: student.allowFatherAadharCardReupload },
              { key: "motherAadharCard", label: "Mother Aadhaar Card", data: student.motherAadharCard, allowed: student.allowMotherAadharCardReupload }
            ];
          %>

          <% docList.forEach(doc => { %>
            <div class="bg-gray-50 rounded-xl border border-gray-200 p-4 flex flex-col justify-between hover:shadow-md transition">
              <div>
                <div class="flex justify-between items-start mb-3">
                  <h4 class="font-bold text-gray-800 text-sm"><%= doc.label %></h4>
                  <% if (doc.data && doc.data.url) { %>
                    <span class="px-2 py-0.5 bg-green-100 text-green-800 text-xs font-semibold rounded-full flex items-center">
                      <span class="w-1.5 h-1.5 rounded-full bg-green-500 mr-1.5"></span>
                      Uploaded
                    </span>
                  <% } else { %>
                    <span class="px-2 py-0.5 bg-yellow-100 text-yellow-800 text-xs font-semibold rounded-full flex items-center">
                      <span class="w-1.5 h-1.5 rounded-full bg-yellow-500 mr-1.5"></span>
                      Pending
                    </span>
                  <% } %>
                </div>

                <!-- Preview Area -->
                <div class="w-full h-40 bg-gray-200 rounded-lg overflow-hidden flex items-center justify-center border border-gray-300 shadow-inner my-2">
                  <% if (doc.data && doc.data.url) { %>
                    <% const isPdf = doc.data.url.toLowerCase().endsWith(".pdf") || doc.data.url.toLowerCase().includes(".pdf?"); %>
                    <% if (isPdf) { %>
                      <div class="flex flex-col items-center text-center p-4">
                        <svg class="w-12 h-12 text-red-500" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 2h6v3a1 1 0 001 1h3v6H6V6z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-xs text-gray-500 mt-2 font-medium">PDF Document</span>
                      </div>
                    <% } else { %>
                      <img src="<%= doc.data.url %>" alt="<%= doc.label %>" class="w-full h-full object-cover">
                    <% } %>
                  <% } else { %>
                    <div class="flex flex-col items-center text-center p-4 text-gray-400">
                      <svg class="w-10 h-10 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m-9 1V4a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"></path>
                      </svg>
                      <span class="text-xs font-medium">No document uploaded</span>
                    </div>
                  <% } %>
                </div>
              </div>

              <!-- Button actions & Inline Toggle -->
              <div class="mt-4 space-y-3">
                <% if (doc.data && doc.data.url) { %>
                  <a 
                    href="<%= doc.data.url %>" 
                    target="_blank" 
                    class="w-full inline-flex items-center justify-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-xs font-semibold rounded-lg shadow-sm transition"
                  >
                    <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                    </svg>
                    View Document
                  </a>
                <% } else { %>
                  <button 
                    disabled 
                    class="w-full inline-flex items-center justify-center px-4 py-2 bg-gray-200 text-gray-400 text-xs font-semibold rounded-lg cursor-not-allowed"
                  >
                    Not Available
                  </button>
                <% } %>

                <!-- Document re-upload permission lock -->
                <div class="flex items-center justify-between pt-2.5 border-t border-gray-200">
                  <div class="text-left">
                    <span class="text-3xs font-extrabold text-gray-400 uppercase tracking-wider block">Lock Status</span>
                    <span class="text-xs font-bold text-gray-700" id="status-<%= doc.key %>">
                      <%= doc.allowed ? 'Unlocked' : 'Locked' %>
                    </span>
                  </div>
                  <button 
                    onclick="togglePermission('<%= doc.key %>')" 
                    id="btn-<%= doc.key %>"
                    class="px-3 py-1 rounded-md text-3xs font-bold transition shadow-sm focus:outline-none <%= doc.allowed ? 'bg-red-100 text-red-700 hover:bg-red-200' : 'bg-green-100 text-green-700 hover:bg-green-200' %>"
                  >
                    <%= doc.allowed ? 'Lock Upload' : 'Allow Upload' %>
                  </button>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  async function togglePermission(type) {
    const btn = document.getElementById(`btn-${type}`);
    const statusText = document.getElementById(`status-${type}`);
    const initialText = btn.innerText;
    
    // Disable button during requests
    btn.disabled = true;
    btn.innerText = "Saving...";

    try {
      const response = await fetch(`/api/students/documents/<%= student._id %>/toggle-reupload`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ type })
      });

      const res = await response.json();
      btn.disabled = false;

      if (res.success) {
        // Update button & text style dynamically
        if (res.isAllowed) {
          statusText.innerText = "Unlocked";
          btn.innerText = "Lock Upload";
          btn.className = "px-3 py-1 rounded-md text-3xs font-bold transition shadow-sm focus:outline-none bg-red-100 text-red-700 hover:bg-red-200";
          if (type === "studentPhoto") {
            btn.className = "px-4 py-1.5 rounded-lg text-xs font-bold transition shadow-sm focus:outline-none focus:ring-2 focus:ring-offset-2 bg-red-100 text-red-700 hover:bg-red-200 focus:ring-red-400";
          }
        } else {
          statusText.innerText = "Locked";
          btn.innerText = "Allow Upload";
          btn.className = "px-3 py-1 rounded-md text-3xs font-bold transition shadow-sm focus:outline-none bg-green-100 text-green-700 hover:bg-green-200";
          if (type === "studentPhoto") {
            btn.className = "px-4 py-1.5 rounded-lg text-xs font-bold transition shadow-sm focus:outline-none focus:ring-2 focus:ring-offset-2 bg-green-100 text-green-700 hover:bg-green-200 focus:ring-green-400";
          }
        }
      } else {
        alert("Failed to toggle permission: " + res.message);
        btn.innerText = initialText;
      }
    } catch (err) {
      console.error(err);
      alert("An error occurred. Please try again.");
      btn.disabled = false;
      btn.innerText = initialText;
    }
  }
</script>
