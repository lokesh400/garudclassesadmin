<div class="w-full px-6 py-8">
  <!-- Header Section -->
  <div class="flex flex-col md:flex-row md:items-center justify-between pb-6 border-b border-slate-200 mb-8 gap-4">
    <div>
      <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight">Registration Forms</h1>
      <p class="text-slate-500 text-sm mt-1.5">Manage administrative admission forms, share registration links, and track candidate submissions.</p>
    </div>
    <% if(currUser && (currUser.role === 'superadmin' || currUser.role === 'admin')) { %> 
      <a href="/forms/create" 
         class="inline-flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-sm px-5 py-3 rounded-2xl transition shadow-md shadow-indigo-100 outline-none">
        <i class="fas fa-plus text-[15px]"></i> New Form
      </a>
    <% } %>
  </div>

  <%- include('../flash.ejs') %>

  <!-- Grid Cards Layout -->
  <% if (forms.length > 0) { %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% forms.forEach(form => { %>
        <div class="bg-white border border-slate-200 rounded-3xl p-6 shadow-sm hover:shadow-md transition duration-300 flex flex-col justify-between relative overflow-hidden">
          
          <!-- Top color accent -->
          <div class="absolute top-0 left-0 w-full h-2.5 bg-indigo-600"></div>

          <div class="mt-3 flex-1 flex flex-col justify-between">
            <div>
              <!-- Form Title -->
              <h3 class="text-xl font-bold text-slate-800 line-clamp-1 mb-2">
                <%= form.title %>
              </h3>

              <!-- Description -->
              <p class="text-slate-500 text-xs line-clamp-2 leading-relaxed mb-4 min-h-[32px]">
                <%= form.description || "No description provided." %>
              </p>

              <!-- Metadata Info -->
              <div class="text-[11px] font-bold text-slate-400 border-t border-slate-100 pt-3 mb-4 space-y-1.5">
                <div class="flex items-center gap-2">
                  <i class="far fa-calendar-alt text-indigo-500 text-sm w-4 text-center"></i>
                  <span>Created: <%= new Date(form.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
                </div>
                <% if (form.batch) { %>
                  <div class="flex items-center gap-2 text-indigo-600">
                    <i class="fas fa-layer-group text-sm w-4 text-center"></i>
                    <span>Linked Batch: Form collection active</span>
                  </div>
                <% } %>
                <% if (form.event) { %>
                  <div class="flex items-center gap-2 text-violet-600">
                    <i class="fas fa-calendar-check text-sm w-4 text-center"></i>
                    <span>Linked Event: Admission active</span>
                  </div>
                <% } %>
              </div>
            </div>

            <!-- Buttons Group -->
            <div class="grid grid-cols-2 gap-2 mt-auto border-t border-slate-100 pt-4">
              <% if(currUser && (currUser.role === 'superadmin' || currUser.role === 'admin')) { %> 
                <a href="/forms/<%= form._id %>/submissions"
                   class="inline-flex items-center justify-center gap-1.5 bg-indigo-50 hover:bg-indigo-100 text-indigo-700 font-bold text-xs py-3 rounded-xl transition text-center">
                  <i class="fas fa-clipboard-list text-[11px]"></i> Submissions
                </a>

                <a href="/forms/edit/<%= form._id %>"
                   class="inline-flex items-center justify-center gap-1.5 bg-slate-50 hover:bg-slate-100 text-slate-700 font-bold text-xs py-3 rounded-xl transition text-center border border-slate-200">
                  <i class="fas fa-edit text-[11px]"></i> Edit Form
                </a>
              <% } %>

              <!-- Share button -->
              <button 
                onclick="openShareModal('<%= form._id %>')"
                class="col-span-2 inline-flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-xs py-3 rounded-xl transition shadow-sm shadow-indigo-100 mt-1">
                <i class="fas fa-share-alt"></i> Share Registration Form
              </button>

              <% if(currUser && (currUser.role === 'superadmin' )) { %> 
                <form action="/forms/delete/<%= form._id %>" method="POST"
                      onsubmit="return confirm('Are you sure you want to delete this form and all associated candidate submissions?')"
                      class="col-span-2 mt-1">
                  <button 
                    class="w-full inline-flex items-center justify-center gap-2 bg-rose-50 hover:bg-rose-100 text-rose-600 font-bold text-xs py-3 rounded-xl transition">
                    <i class="fas fa-trash-alt"></i> Delete Form
                  </button>
                </form>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <!-- Empty Slate -->
    <div class="bg-white border border-slate-200 rounded-3xl p-12 text-center shadow-sm">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-slate-50 text-slate-400 rounded-2xl mb-4 border border-slate-100">
        <i class="fas fa-file text-2xl"></i>
      </div>
      <h3 class="text-lg font-bold text-slate-800">No forms found</h3>
      <p class="text-slate-500 text-xs mt-1.5 max-w-sm mx-auto">Create a dynamic student registration form to start collecting records.</p>
      <% if(currUser && (currUser.role === 'superadmin' || currUser.role === 'admin')) { %> 
        <a href="/forms/create" 
           class="mt-6 inline-flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-xs px-4 py-2.5 rounded-xl transition shadow-md shadow-indigo-100">
          Create Form Now
        </a>
      <% } %>
    </div>
  <% } %>

  <!-- 🔗 Share Modal -->
  <div id="shareModal" class="hidden fixed inset-0 bg-slate-955/40 flex items-center justify-center z-50 p-4 transition-all duration-300">
    <div class="bg-white rounded-3xl shadow-xl w-full max-w-md p-6 relative border border-slate-100 transform transition-all duration-300">
      <button onclick="closeShareModal()" class="absolute top-4 right-4 text-slate-405 hover:text-slate-600 transition">
        <i class="fas fa-times text-lg"></i>
      </button>

      <div class="mb-5">
        <h2 class="text-xl font-bold text-slate-800">Share Form</h2>
        <p class="text-slate-500 text-xs mt-1">Copy the registration link or share it directly.</p>
      </div>

      <!-- Link Box -->
      <div class="bg-slate-50 rounded-2xl border border-slate-100 p-4 mb-5 flex items-center justify-between gap-3">
        <div id="shareLink" class="text-xs font-semibold text-slate-600 select-all truncate"></div>
        <button onclick="copyShareLink()" class="text-indigo-600 hover:text-indigo-700 font-bold text-xs shrink-0 flex items-center gap-1 outline-none">
          <i class="far fa-copy text-sm"></i> Copy Link
        </button>
      </div>

      <!-- Socials / Quick Action -->
      <div class="grid grid-cols-2 gap-3">
        <!-- WhatsApp -->
        <a id="whatsappShare" href="" target="_blank"
           class="flex items-center justify-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white font-bold text-xs py-3.5 rounded-xl transition w-full">
          <i class="fab fa-whatsapp text-[14px]"></i> Share on WhatsApp
        </a>
        
        <!-- Email -->
        <a id="emailShare" href=""
           class="flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs py-3.5 rounded-xl transition w-full">
          <i class="far fa-envelope text-[14px]"></i> Share via Email
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  let currentShareLink = "";
  function openShareModal(formId) {
    currentShareLink = `${window.location.origin}/forms/fill/${formId}`;
    document.getElementById('shareLink').textContent = currentShareLink;
    document.getElementById('whatsappShare').href = 
      `https://wa.me/?text=${encodeURIComponent(currentShareLink)}`;
    document.getElementById('emailShare').href =
      `mailto:?subject=Registration Form Link&body=${encodeURIComponent(currentShareLink)}`;
    
    const modal = document.getElementById('shareModal');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = "hidden";
  }

  function closeShareModal() {
    const modal = document.getElementById('shareModal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = "";
  }

  function copyShareLink() {
    navigator.clipboard.writeText(currentShareLink)
      .then(() => {
        if (typeof showToast === 'function') {
          showToast("Form link copied to clipboard!", "success");
        } else {
          alert("Form link copied!");
        }
      })
      .catch(() => alert("Unable to copy link"));
  }

  // Close modal on click outside
  window.addEventListener("click", (e) => {
    const shareModal = document.getElementById("shareModal");
    if (e.target === shareModal) closeShareModal();
  });
</script>
